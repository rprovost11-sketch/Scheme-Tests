; Section 6.4 - Pairs and Lists
;
; (cons obj1 obj2)      — creates a pair
; (car pair)            — first element
; (cdr pair)            — second element
; (set-car! pair obj)   — mutate first element
; (set-cdr! pair obj)   — mutate second element
; (pair? obj)           — #t for any pair (including improper lists)
; (null? obj)           — #t only for '()
; (list? obj)           — #t for proper lists (including '())
; (make-list k)         — list of k elements (unspecified fill)
; (make-list k fill)    — list of k copies of fill
; (list obj ...)        — construct list from arguments
; (length list)         — length of proper list
; (append list ...)     — concatenate lists
; (reverse list)        — reverse a proper list
; (list-tail list k)    — drop first k elements
; (list-ref list k)     — element at index k
; (list-set! list k obj) — set element at index k
; (list-copy list)      — shallow copy
; (memq obj list)       — find obj using eq?
; (memv obj list)       — find obj using eqv?
; (member obj list)     — find obj using equal?
; (member obj list cmp) — find obj using cmp
; (assq obj alist)      — find in alist using eq?
; (assv obj alist)      — find in alist using eqv?
; (assoc obj alist)     — find in alist using equal?
; (assoc obj alist cmp) — find in alist using cmp

; ==========================================================================
; cons — creates a pair
; ==========================================================================

>>> (cons 1 2)

==> (1 . 2)

>>> (cons 1 '())

==> (1)

>>> (cons 1 '(2 3))

==> (1 2 3)

>>> (cons 'a '(b c d))

==> (a b c d)

>>> (cons '() '())

==> (())

>>> (cons #t #f)

==> (#t . #f)

>>> (cons (cons 1 2) (cons 3 4))

==> ((1 . 2) 3 . 4)

; ==========================================================================
; pair? — true for any cons cell
; ==========================================================================

>>> (pair? '(1 2 3))

==> #t

>>> (pair? (cons 1 2))

==> #t

>>> (pair? '(1 . 2))

==> #t

>>> (pair? '(1))

==> #t

>>> (pair? '())

==> #f

>>> (pair? 42)

==> #f

>>> (pair? #t)

==> #f

>>> (pair? 'sym)

==> #f

>>> (pair? "str")

==> #f

>>> (pair? #(1 2))

==> #f

; ==========================================================================
; car — first element of a pair
; ==========================================================================

>>> (car '(1 2 3))

==> 1

>>> (car '(a b c))

==> a

>>> (car (cons 1 2))

==> 1

>>> (car '((1 2) 3))

==> (1 2)

>>> (car '(()))

==> ()

; Error: car on non-pair

>>> (car '())

%%% %any-error%

>>> (car 42)

%%% %any-error%

>>> (car #t)

%%% %any-error%

; ==========================================================================
; cdr — second element of a pair
; ==========================================================================

>>> (cdr '(1 2 3))

==> (2 3)

>>> (cdr '(1))

==> ()

>>> (cdr (cons 1 2))

==> 2

>>> (cdr '(a b c))

==> (b c)

; Error: cdr on non-pair

>>> (cdr '())

%%% %any-error%

>>> (cdr 42)

%%% %any-error%

; ==========================================================================
; caar, cadr, cdar, cddr, ... (up to four letters)
; ==========================================================================

>>> (cadr '(1 2 3))

==> 2

>>> (caddr '(1 2 3))

==> 3

>>> (cadddr '(1 2 3 4))

==> 4

>>> (cadr '(a (b c) d))

==> (b c)

>>> (caar '((1 2) 3))

==> 1

>>> (cdar '((1 2) 3))

==> (2)

>>> (cadar '((1 2) 3))

==> 2

>>> (cddr '(1 2 3 4))

==> (3 4)

>>> (caddr '(a b c d))

==> c

>>> (cdddr '(1 2 3 4))

==> (4)

>>> (cdadr '(1 (2 3) 4))

==> (3)

; ==========================================================================
; set-car! and set-cdr! — mutation
; ==========================================================================

>>> (define p (cons 1 2))

>>> (set-car! p 10)

>>> (car p)

==> 10

>>> (cdr p)

==> 2

>>> (set-cdr! p 20)

>>> (cdr p)

==> 20

>>> (define lst (list 1 2 3))

>>> (set-car! lst 99)

>>> lst

==> (99 2 3)

>>> (set-cdr! lst '(x y))

>>> lst

==> (99 x y)

; Error: set-car! on non-pair

>>> (set-car! '() 1)

%%% %any-error%

>>> (set-cdr! 42 1)

%%% %any-error%

; ==========================================================================
; null? — true only for '()
; ==========================================================================

>>> (null? '())

==> #t

>>> (null? '(1))

==> #f

>>> (null? #f)

==> #f

>>> (null? 0)

==> #f

>>> (null? "")

==> #f

>>> (null? #t)

==> #f

; ==========================================================================
; list? — true for proper lists (including '())
; ==========================================================================

>>> (list? '())

==> #t

>>> (list? '(1 2 3))

==> #t

>>> (list? '(1 . 2))

==> #f

>>> (list? 42)

==> #f

>>> (list? '(1 2 . 3))

==> #f

; Circular list — list? must not loop forever

>>> (define circ (list 1 2 3))

>>> (set-cdr! (cddr circ) circ)

>>> (list? circ)

==> #f

; ==========================================================================
; make-list
; ==========================================================================

>>> (make-list 0)

==> ()

>>> (length (make-list 3))

==> 3

>>> (make-list 3 0)

==> (0 0 0)

>>> (make-list 5 'x)

==> (x x x x x)

>>> (make-list 1 #t)

==> (#t)

>>> (make-list 0 'ignored)

==> ()

; ==========================================================================
; list — construct from arguments
; ==========================================================================

>>> (list)

==> ()

>>> (list 1)

==> (1)

>>> (list 1 2 3)

==> (1 2 3)

>>> (list 'a 'b 'c)

==> (a b c)

>>> (list 1 "two" #\3 #t)

==> (1 "two" #\3 #t)

>>> (list (list 1 2) (list 3 4))

==> ((1 2) (3 4))

; ==========================================================================
; length
; ==========================================================================

>>> (length '())

==> 0

>>> (length '(1))

==> 1

>>> (length '(1 2 3))

==> 3

>>> (length '(a b c d e))

==> 5

>>> (length (make-list 100 0))

==> 100

; Error: length on improper list

>>> (length '(1 . 2))

%%% %any-error%

>>> (length 42)

%%% %any-error%

; ==========================================================================
; append
; ==========================================================================

>>> (append '(1 2) '(3 4))

==> (1 2 3 4)

>>> (append '(a b) '(c d) '(e f))

==> (a b c d e f)

>>> (append '() '(1 2))

==> (1 2)

>>> (append '(1 2) '())

==> (1 2)

>>> (append '() '())

==> ()

>>> (append)

==> ()

>>> (append '(1 2))

==> (1 2)

; Last argument may be any object (creates improper list)

>>> (append '(1 2) 3)

==> (1 2 . 3)

>>> (append '(a) '(b) 'c)

==> (a b . c)

; append does not copy the last argument

>>> (define last '(3 4))

>>> (define appended (append '(1 2) last))

>>> (eq? (cddr appended) last)

==> #t

; ==========================================================================
; reverse
; ==========================================================================

>>> (reverse '())

==> ()

>>> (reverse '(1))

==> (1)

>>> (reverse '(1 2 3))

==> (3 2 1)

>>> (reverse '(a b c d e))

==> (e d c b a)

>>> (reverse (reverse '(1 2 3)))

==> (1 2 3)

; reverse returns a fresh list

>>> (define orig '(1 2 3))

>>> (define rev (reverse orig))

>>> (equal? orig '(1 2 3))

==> #t

>>> rev

==> (3 2 1)

; ==========================================================================
; list-tail
; ==========================================================================

>>> (list-tail '(a b c d) 0)

==> (a b c d)

>>> (list-tail '(a b c d) 1)

==> (b c d)

>>> (list-tail '(a b c d) 2)

==> (c d)

>>> (list-tail '(a b c d) 4)

==> ()

>>> (list-tail '() 0)

==> ()

; Error: index out of range

>>> (list-tail '(a b) 3)

%%% %any-error%

; ==========================================================================
; list-ref
; ==========================================================================

>>> (list-ref '(a b c d) 0)

==> a

>>> (list-ref '(a b c d) 1)

==> b

>>> (list-ref '(a b c d) 3)

==> d

>>> (list-ref '((1 2) (3 4)) 0)

==> (1 2)

>>> (list-ref '((1 2) (3 4)) 1)

==> (3 4)

; Error: index out of range

>>> (list-ref '(a b) 2)

%%% %any-error%

; ==========================================================================
; list-set!
; ==========================================================================

>>> (define ls (list 'a 'b 'c))

>>> (list-set! ls 0 'x)

>>> ls

==> (x b c)

>>> (list-set! ls 2 'z)

>>> ls

==> (x b z)

>>> (list-set! ls 1 '(1 2 3))

>>> ls

==> (x (1 2 3) z)

; Error: index out of range

>>> (list-set! '(a b) 2 'x)

%%% %any-error%

; ==========================================================================
; list-copy — shallow copy
; ==========================================================================

>>> (define orig-lc '(1 2 3))

>>> (define copy-lc (list-copy orig-lc))

>>> (equal? orig-lc copy-lc)

==> #t

>>> (eq? orig-lc copy-lc)

==> #f

; Shallow: nested structure is shared

>>> (define nested '((1 2) (3 4)))

>>> (define nested-copy (list-copy nested))

>>> (eq? (car nested) (car nested-copy))

==> #t

; Modifying the copy doesn't affect the original

>>> (define mutable-orig (list 1 2 3))

>>> (define mutable-copy (list-copy mutable-orig))

>>> (set-car! mutable-copy 99)

>>> (car mutable-orig)

==> 1

>>> (car mutable-copy)

==> 99

>>> (list-copy '())

==> ()

; ==========================================================================
; memq — find using eq?
; ==========================================================================

>>> (memq 'a '(a b c))

==> (a b c)

>>> (memq 'b '(a b c))

==> (b c)

>>> (memq 'c '(a b c))

==> (c)

>>> (memq 'd '(a b c))

==> #f

>>> (memq '() '(a () b))

==> (() b)

; memq uses eq? — symbols are interned

>>> (memq 2 '(1 2 3))

==> (2 3) or ==> #f

; Numbers may not be eq?-comparable reliably

; ==========================================================================
; memv — find using eqv?
; ==========================================================================

>>> (memv 2 '(1 2 3))

==> (2 3)

>>> (memv 1/2 '(1/4 1/2 3/4))

==> (1/2 3/4)

>>> (memv #\b '(#\a #\b #\c))

==> (#\b #\c)

>>> (memv 'x '(a b c))

==> #f

; ==========================================================================
; member — find using equal?
; ==========================================================================

>>> (member '(2) '((1) (2) (3)))

==> ((2) (3))

>>> (member "b" '("a" "b" "c"))

==> ("b" "c")

>>> (member 2 '(1 2 3))

==> (2 3)

>>> (member '() '(1 () 2))

==> (() 2)

>>> (member 'x '(a b c))

==> #f

; member with custom comparator

>>> (member 2.0 '(1 2 3) =)

==> (2 3)

>>> (member "B" '("a" "b" "c") string-ci=?)

==> ("b" "c")

; ==========================================================================
; assq — find in association list using eq?
; ==========================================================================

>>> (assq 'a '((a 1) (b 2) (c 3)))

==> (a 1)

>>> (assq 'b '((a 1) (b 2) (c 3)))

==> (b 2)

>>> (assq 'd '((a 1) (b 2) (c 3)))

==> #f

>>> (assq '() '((a 1) (() 2) (c 3)))

==> (() 2)

; ==========================================================================
; assv — find in alist using eqv?
; ==========================================================================

>>> (assv 2 '((1 a) (2 b) (3 c)))

==> (2 b)

>>> (assv 5 '((1 a) (2 b) (3 c)))

==> #f

>>> (assv 1/2 '((1/4 a) (1/2 b) (3/4 c)))

==> (1/2 b)

>>> (assv #\b '((#\a x) (#\b y) (#\c z)))

==> (#\b y)

; ==========================================================================
; assoc — find in alist using equal?
; ==========================================================================

>>> (assoc '(b) '((a 1) ((b) 2) (c 3)))

==> ((b) 2)

>>> (assoc "b" '(("a" 1) ("b" 2) ("c" 3)))

==> ("b" 2)

>>> (assoc 2 '((1 a) (2 b) (3 c)))

==> (2 b)

>>> (assoc 'd '((a 1) (b 2) (c 3)))

==> #f

; assoc with custom comparator

>>> (assoc 2.0 '((1 a) (2 b) (3 c)) =)

==> (2 b)

>>> (assoc "B" '(("a" 1) ("b" 2) ("c" 3)) string-ci=?)

==> ("b" 2)

; ==========================================================================
; Proper vs improper lists
; ==========================================================================

>>> (pair? '(1 . 2))

==> #t

>>> (list? '(1 . 2))

==> #f

>>> (pair? '(1 2 . 3))

==> #t

>>> (list? '(1 2 . 3))

==> #f

>>> (cdr '(1 2 . 3))

==> (2 . 3)

>>> (cddr '(1 2 . 3))

==> 3

; ==========================================================================
; Nested list operations
; ==========================================================================

>>> (car (cdr '(1 2 3)))

==> 2

>>> (car (cddr '(1 2 3)))

==> 3

>>> (length (append '(1 2) '(3 4) '(5)))

==> 5

>>> (reverse (map (lambda (x) (* x x)) '(1 2 3 4)))

==> (16 9 4 1)

; ==========================================================================
; Association list building and lookup
; ==========================================================================

>>> (define env '((x . 1) (y . 2) (z . 3)))

>>> (cdr (assq 'y env))

==> 2

>>> (define (lookup key alist)
...   (let ((pair (assoc key alist)))
...     (if pair (cdr pair) #f)))

>>> (lookup 'x env)

==> 1

>>> (lookup 'z env)

==> 3

>>> (lookup 'w env)

==> #f

; ==========================================================================
; ADDITIONAL R7RS COMPLIANCE TESTS
; ==========================================================================

; ===
; append — only the LAST argument is shared; earlier arguments are copied
; (R7RS 6.4: "the resulting list ... shares structure with the last argument")
; ===

>>> (define a1 (list 1 2))

>>> (define a2 (list 3 4))

>>> (define a3 (append a1 a2))

>>> (eq? a3 a1)
... ; an earlier list is copied, so its pairs are not shared with the result
==> #f

>>> (eq? (cdr a3) (cdr a1))

==> #f

; the last argument IS shared (same pairs)

>>> (eq? (cddr a3) a2)

==> #t

; mutating the copied portion does not affect the original first arg

>>> (set-car! a3 99)

>>> (car a1)

==> 1

>>> (car a3)

==> 99

; with three or more lists, only the final one is shared

>>> (define b1 (list 'x))

>>> (define b2 (list 'y))

>>> (define b3 (list 'z))

>>> (define bcat (append b1 b2 b3))

>>> (eq? (cddr bcat) b3)

==> #t

>>> (eq? (cdr bcat) b2)

==> #f

; appending the empty list as the only/last arg returns it; a single arg
; is returned as-is (not copied)

>>> (eq? (append a2) a2)

==> #t

; ===
; list-copy — atoms returned unchanged; improper lists copied with shared
; final cdr (eqv?) (R7RS 6.4)
; ===

; A non-list object is returned unchanged (eqv?)

>>> (eqv? 5 (list-copy 5))

==> #t

>>> (eq? 'sym (list-copy 'sym))

==> #t

>>> (let ((s "str")) (eq? s (list-copy s)))

==> #t

; Improper list: result is improper and equal? to original

>>> (equal? (list-copy '(1 2 . 3)) '(1 2 . 3))

==> #t

>>> (cdr (cdr (list-copy '(1 2 . 3))))

==> 3

; The final cdr (the improper tail) is shared in the sense of eqv?

>>> (define improp (cons 1 (cons 2 'tail)))

>>> (define improp-copy (list-copy improp))

>>> (eq? improp improp-copy)

==> #f

>>> (eqv? (cddr improp) (cddr improp-copy))

==> #t

; The car objects are shared (eqv?), only pairs are fresh

>>> (define shared-car (list (list 1 2) (list 3 4)))

>>> (define sc-copy (list-copy shared-car))

>>> (eq? (car shared-car) (car sc-copy))

==> #t

>>> (eq? (cadr shared-car) (cadr sc-copy))

==> #t

; ===
; member / assoc 3-arg compare — comparator is called as (compare obj elt)
; obj is the FIRST argument, the list element is the SECOND (R7RS 6.4)
; ===

; A comparator sensitive to which side a value is on

>>> (member 1 '(2 3 4) (lambda (obj elt) (< obj elt)))

==> (2 3 4)

>>> (member 10 '(2 3 4) (lambda (obj elt) (< obj elt)))

==> #f

; assoc passes (compare obj car-of-pair)

>>> (assoc 2 '((1 a) (2 b) (3 c)) (lambda (obj key) (= obj key)))

==> (2 b)

>>> (assoc 2 '((1 a) (4 b) (3 c)) (lambda (obj key) (= obj key)))

==> #f

>>> (assoc 5 '((1 a) (10 b) (3 c)) (lambda (obj key) (< obj key)))

==> (10 b)

; spec example: assoc with = comparator over inexact key

>>> (assoc 2.0 '((1 1) (2 4) (3 9)) =)

==> (2 4)

; ===
; make-list with fill — every element is the SAME object as fill (eqv?)
; ===

>>> (define fillobj (list 'z))

>>> (define ml (make-list 3 fillobj))

>>> (eq? (car ml) fillobj)

==> #t

>>> (eq? (cadr ml) fillobj)

==> #t

>>> (eq? (caddr ml) fillobj)

==> #t

; all elements are the same object as each other

>>> (eq? (car ml) (caddr ml))

==> #t

; mutating the shared fill object is visible through every element

>>> (set-car! fillobj 'mutated)

>>> (car (car ml))

==> mutated

>>> (car (caddr ml))

==> mutated

; ==========================================================================
; R7RS section 6.4 -- worked examples from the standard (Chibi-verified).
; ==========================================================================

>>> (pair? '(a . b))

==> #t

>>> (pair? '(a b c))

==> #t

>>> (pair? '#(a b))

==> #f

>>> (cons '(a) '(b c d))

==> ((a) b c d)

>>> (cons "a" '(b c))

==> ("a" b c)

>>> (cons 'a 3)

==> (a . 3)

>>> (cons '(a b) 'c)

==> ((a b) . c)

>>> (car '(1 . 2))

==> 1

>>> (car '((a) b c d))

==> (a)

>>> (cdr '((a) b c d))

==> (b c d)

>>> (cdr '(1 . 2))

==> 2

>>> (list 'a (+ 3 4) 'c)

==> (a 7 c)

>>> (length '(a b c))

==> 3

>>> (length '(a (b) (c d e)))

==> 3

>>> (append '(x) '(y))

==> (x y)

>>> (append '(a (b)) '((c)))

==> (a (b) (c))

>>> (append '(a b) '(c . d))

==> (a b c . d)

>>> (append '() 'a)

==> a

>>> (list? '(a b c))

==> #t

>>> (list? '(a . b))

==> #f

>>> (let ((x (list 'a))) (set-cdr! x x) (list? x))

==> #f

>>> (make-list 2 3)

==> (3 3)

>>> (reverse '(a b c))

==> (c b a)

>>> (reverse '(a (b c) d (e (f))))

==> ((e (f)) d (b c) a)

>>> (list-ref '(a b c d) 2)

==> c

>>> (list-ref '(a b c d) (exact (round 1.8)))

==> c

>>> (let ((ls (list 'one 'two 'five!))) (list-set! ls 2 'three) ls)

==> (one two three)

>>> (assq (list 'a) '(((a)) ((b)) ((c))))

==> #f

>>> (assoc (list 'a) '(((a)) ((b)) ((c))))

==> ((a))

>>> (assv 5 '((2 3) (5 7) (11 13)))

==> (5 7)

>>> (memq (list 'a) '(b (a) c))

==> #f

>>> (member (list 'a) '(b (a) c))

==> ((a) c)

>>> (memv 101 '(100 101 102))

==> (101 102)

