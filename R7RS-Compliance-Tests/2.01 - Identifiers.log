; Section 2.1 - Identifiers
;
; R7RS identifier grammar:
;   ordinary  : <initial> <subsequent>*
;   initial   : letter | ! $ % & * / : < = > ? ^ _ ~
;   subsequent: initial | digit | + - . @
;   peculiar  : +  |  -  |  ...  |  -> <subsequent>*
;   quoted    : | <symbol-element>* |
;
; R7RS is case-sensitive.

; ==========================================================================
; Ordinary identifiers
; ==========================================================================

; --- Letters and digits in subsequent position ---

>>> (define abc 1)

>>> abc

==> 1

>>> (define abc123 2)

>>> abc123

==> 2

; Hyphens are valid subsequent characters (a-b-c is one identifier, not subtraction)

>>> (define a-b-c 3)

>>> a-b-c

==> 3

; Dot is a valid subsequent character

>>> (define a.b.c 4)

>>> a.b.c

==> 4

; @ is a valid subsequent character

>>> (define a@b 5)

>>> a@b

==> 5

; + and - are valid subsequent characters when not the first character

>>> (define a+b 6)

>>> a+b

==> 6

>>> (define a-b 7)

>>> a-b

==> 7

; ==========================================================================
; Case sensitivity  (Hello, hello, HELLO are three distinct identifiers)
; ==========================================================================

>>> (define Hello 10)

>>> (define hello 11)

>>> (define HELLO 12)

>>> Hello

==> 10

>>> hello

==> 11

>>> HELLO

==> 12

; ==========================================================================
; All 14 special initial characters as standalone identifiers
; (these shadow standard bindings where applicable)
; ==========================================================================

>>> (define ! 20)

>>> !

==> 20

>>> (define $ 21)

>>> $

==> 21

>>> (define % 22)

>>> %

==> 22

>>> (define & 23)

>>> &

==> 23

>>> (define * 24)

>>> *

==> 24

>>> (define / 25)

>>> /

==> 25

>>> (define : 26)

>>> :

==> 26

>>> (define < 27)

>>> <

==> 27

>>> (define = 28)

>>> =

==> 28

>>> (define > 29)

>>> >

==> 29

>>> (define ? 30)

>>> ?

==> 30

>>> (define ^ 31)

>>> ^

==> 31

>>> (define _ 32)

>>> _

==> 32

>>> (define ~ 33)

>>> ~

==> 33

; All 14 special initials combined in one identifier

>>> (define !$%&*/:<=>?^_~ 34)

>>> !$%&*/:<=>?^_~

==> 34

; Special initials mixed with letters and subsequent characters

>>> (define my!flag 35)

>>> my!flag

==> 35

>>> (define set-x! 36)

>>> set-x!

==> 36

>>> (define x->y 37)

>>> x->y

==> 37

>>> (define make-<thing> 38)

>>> make-<thing>

==> 38

; ==========================================================================
; Peculiar identifiers
; ==========================================================================

; + and - as standalone identifiers (shadow arithmetic builtins)

>>> (define + 40)

>>> +

==> 40

>>> (define - 41)

>>> -

==> 41

; Ellipsis ... is a valid identifier

>>> (define ... 42)

>>> ...

==> 42

; -> alone (zero subsequent characters) is a valid peculiar identifier

>>> (define -> 43)

>>> ->

==> 43

; -> with subsequent characters

>>> (define ->foo 44)

>>> ->foo

==> 44

>>> (define ->+ 45)

>>> ->+

==> 45

>>> (define ->123 46)

>>> ->123

==> 46

; ==========================================================================
; Vertical-bar quoted identifiers  | symbol-element* |
; ==========================================================================

; Empty symbol

>>> (define || 50)

>>> ||

==> 50

; Spaces inside |...|

>>> (define |hello world| 51)

>>> |hello world|

==> 51

; Digit as first character (not valid as an ordinary identifier)

>>> (define |3| 52)

>>> |3|

==> 52

>>> (define |123abc| 53)

>>> |123abc|

==> 53

; Delimiter characters inside |...|

>>> (define |(| 54)

>>> |(|

==> 54

>>> (define |)| 55)

>>> |)|

==> 55

>>> (define |[| 56)

>>> |[|

==> 56

>>> (define |]| 57)

>>> |]|

==> 57

; Semicolon inside |...| must not be treated as a line comment

>>> (define |a;b| 58)

>>> |a;b|

==> 58

>>> (define |;comment-looking| 59)

>>> |;comment-looking|

==> 59

; Whitespace variants inside |...|

>>> (define |with spaces and more| 60)

>>> |with spaces and more|

==> 60

; ==========================================================================
; Mnemonic (named) escapes inside |...|
; \a alarm (U+0007), \b backspace (U+0008), \t tab (U+0009)
; \n newline (U+000A), \r return (U+000D)
; ==========================================================================

>>> (define |\t| 70)

>>> |\t|

==> 70

>>> (define |\n| 71)

>>> |\n|

==> 71

>>> (define |\a| 72)

>>> |\a|

==> 72

>>> (define |\b| 73)

>>> |\b|

==> 73

>>> (define |\r| 74)

>>> |\r|

==> 74

; Escaped double-quote inside |...|

>>> (define |\"| 75)

>>> |\"|

==> 75

; Escaped backslash inside |...|

>>> (define |\\| 76)

>>> |\\|

==> 76

; Escaped pipe inside |...|  (\| represents a literal | character)

>>> (define |\|| 77)

>>> |\||

==> 77

; ==========================================================================
; Hex escapes  \xHEX;  inside |...|
; ==========================================================================

; \x65; = e (U+0065): |H\x65;llo| parses as the symbol Hello

>>> (define |H\x65;llo| 80)

>>> Hello

==> 80

; \x9; = tab (U+0009), same character as \t: cross-notation equivalence

>>> (define |\t\t| 81)

>>> |\x9;\x9;|

==> 81

; Reverse: defined with hex escapes, recalled with mnemonic escapes

>>> (define |\x9;\x9;| 82)

>>> |\t\t|

==> 82

; \x3BB; = λ (U+03BB, Greek lowercase lambda): Unicode in quoted symbol

>>> (define |\x3BB;| 83)

>>> |\x3BB;|

==> 83

; Multi-char hex sequence spelling a word: \x48;\x65;\x6C;\x6C;\x6F; = Hello

>>> (define |\x48;\x65;\x6C;\x6C;\x6F;| 84)

>>> Hello

==> 84

; ==========================================================================
; Cross-notation equivalence using eq?
; These verify that different surface representations name the same symbol.
; ==========================================================================

; |H\x65;llo| and Hello are the same symbol

>>> (eq? '|H\x65;llo| 'Hello)

==> #t

; \t and \x9; in |...| both represent tab, so these are the same symbol

>>> (eq? '|\t| '|\x9;|)

==> #t

; |\x48;\x65;\x6C;\x6C;\x6F;| and Hello are the same symbol

>>> (eq? '|\x48;\x65;\x6C;\x6C;\x6F;| 'Hello)

==> #t

; Two quoted instances of the same symbol are eq?

>>> (eq? 'abc 'abc)

==> #t

; Distinct symbols are not eq?

>>> (eq? 'Hello 'hello)

==> #f

>>> (eq? 'hello 'HELLO)

==> #f

; ==========================================================================
; #!fold-case and #!no-fold-case directives (R7RS 2.1)
; These reader directives toggle case-folding for subsequent identifiers.
; Default is no-fold-case (case-sensitive).
; ==========================================================================

; --- #!fold-case: all subsequent identifiers folded to lowercase ---

#!fold-case

; ALPHA is folded to alpha on read, so this defines alpha = 90

>>> (define ALPHA 90)

>>> alpha

==> 90

; ALPHA is also folded to alpha when recalled

>>> ALPHA

==> 90

; Mixed-case identifier: Define is folded to define, FoObAr is folded to foobar

>>> (define FoObAr 91)

>>> foobar

==> 91

; Under fold-case, uppercase and lowercase spell the same symbol

>>> (eq? 'ALPHA 'alpha)

==> #t

>>> (eq? 'FoObAr 'foobar)

==> #t

>>> (eq? 'HELLO 'hello)

==> #t

; --- #!no-fold-case: restore case-sensitive behavior ---

#!no-fold-case

; Beta and BETA are now distinct identifiers again

>>> (define Beta 92)

>>> Beta

==> 92

>>> (define BETA 93)

>>> BETA

==> 93

>>> Beta

==> 92

; Confirm case-sensitivity is restored

>>> (eq? 'Beta 'BETA)

==> #f

>>> (eq? 'Beta 'beta)

==> #f

; --- #!fold-case / #!no-fold-case can be toggled multiple times ---

#!fold-case

>>> (define GAMMA 94)

>>> gamma

==> 94

#!no-fold-case

>>> (define Delta 95)

>>> Delta

==> 95

; Under fold-case, GAMMA and gamma were the same; now no-fold-case is active
; but the binding established under fold-case used the folded name (gamma)

>>> gamma

==> 94

; Delta defined under no-fold-case is case-sensitive

>>> (eq? 'Delta 'delta)

==> #f

; ==========================================================================
; Whitespace as token delimiter
; Whitespace between tokens is required where tokens would otherwise merge,
; and separates what might otherwise look like one identifier into two.
; ==========================================================================

; ab and c are two distinct identifiers; abc is a third, unrelated to either

>>> (define ab 1)

>>> (define c 2)

>>> (define abc 3)

>>> ab

==> 1

>>> c

==> 2

>>> abc

==> 3

>>> (eq? 'ab 'abc)

==> #f

>>> (eq? 'c 'abc)

==> #f

; A list expression containing two whitespace-delimited identifiers

>>> (list ab c)

==> (1 2)

; Whitespace inside |...| is part of the symbol; |ab c| is one symbol distinct from ab and c

>>> (define |ab c| 4)

>>> |ab c|

==> 4

>>> (eq? '|ab c| 'ab)

==> #f

>>> (eq? '|ab c| 'abc)

==> #f

; Multiple whitespace characters between tokens are equivalent to one

>>> (list    ab      c)

==> (1 2)

; Tab as whitespace delimiter

>>> (list	ab	c)

==> (1 2)

