; Section 2.2 - Whitespace and Comments
;
; Whitespace includes space, tab, and newline (and possibly others).
; It is used to delimit tokens and is otherwise not significant.
; Three comment forms: line (;), block (#| ... |#), and datum (#;).

; ==========================================================================
; Whitespace
; ==========================================================================

; --- Space as delimiter ---

>>> (+ 1 2)

==> 3

; Multiple spaces are equivalent to one space

>>> (+   1   2)

==> 3

; --- Tab as delimiter ---

>>> (+	1	2)

==> 3

; --- Newline as whitespace inside an expression ---

>>> (+ 1
...    2)

==> 3

>>> (list
...   1
...   2
...   3)

==> (1 2 3)

; --- Whitespace is not needed between self-delimiting tokens ---
; ( ) ' ` , ,@ are self-delimiting; no space required around them

>>> (car'(1 2))

==> 1

>>> (cdr'(1 2))

==> (2)

>>> (cons 0'(1 2))

==> (0 1 2)

; --- Whitespace inside a string is literal, not a delimiter ---

>>> (string-length "hello world")

==> 11

>>> (string-length "a	b")

==> 3

>>> (string-ref "a b" 1)

==> #\space

; ==========================================================================
; Line comments  ;
; ==========================================================================

; A semicolon starts a comment extending to the end of the line

>>> 42 ; this entire portion is a comment

==> 42

>>> (+ 1 2) ; so is this

==> 3

; Line comment in the middle of a multi-line expression

>>> (+ 1   ; first addend
...    2)  ; second addend

==> 3

; Multiple consecutive comment lines before an expression

>>> ; first comment line
... ; second comment line
... ; third comment line
... 99

==> 99

; An empty comment: semicolon with nothing after it

>>> 7 ;

==> 7

; Comment on a line by itself does not affect the next expression

>>> ; standalone comment

>>> 5

==> 5

; --- Semicolon is NOT a comment in these contexts ---

; Inside a string literal

>>> (string-length "hello; world")

==> 12

>>> (string-ref "a;b" 1)

==> #\;

; Inside a |...| quoted symbol

>>> (define |has;semicolon| 1)

>>> |has;semicolon|

==> 1

; As a character literal — #\; is the semicolon character

>>> (char? #\;)

==> #t

>>> (char=? #\; #\;)

==> #t

; Inside a block comment — the semicolon is part of the ignored text

>>> #| ; this is not a line comment |# 55

==> 55

; Semicolon inside a datum that is being skipped by #;

; The entire list (a ; b) can't be parsed with the ; ending the line mid-list;
; the ; comment runs to end of line so this requires continuation

>>> (+ #; (a ; b) 1 2)

%%% *

>>> (+ #; (a ; skipped comment
...        b) 1 2)

==> 3

; ==========================================================================
; Block comments  #| ... |#
; ==========================================================================

; A basic block comment is entirely ignored

>>> #| this is a block comment |# 42

==> 42

; Empty block comment

>>> #||# 43

==> 43

; Block comment between tokens inside an expression

>>> (+ 1 #| ignored |# 2)

==> 3

; Block comment at the very start

>>> #| leading comment |# (+ 1 2)

==> 3

; Block comment immediately adjacent to tokens — no surrounding whitespace needed

>>> (+#|comment|#1 2)

==> 3

>>> (#|comment|#+ 1 2)

==> 3

; Block comment between the open paren and the operator

>>> ( #| comment |# + 1 2)

==> 3

; Multi-line block comment

>>> (+ 1 #| this comment
...       spans three
...       lines |# 2)

==> 3

; Block comment on a line by itself

>>> #| this whole line is a comment |#

>>> (+ 1 2)

==> 3

; --- Nesting: R7RS requires #| ... |# to nest ---

; A nested |# closes only the inner comment; outer comment continues

>>> (+ #| outer #| inner |# still in outer |# 1 2)

==> 3

; Three levels of nesting

>>> (+ #| a #| b #| c |# b |# a |# 1 2)

==> 3

; Four levels of nesting

>>> (+ #| 1 #| 2 #| 3 #| 4 |# 3 |# 2 |# 1 |# 10 20)

==> 30

; Nested comment that contains tokens that look like real code

>>> (+ #| (* 100 200) #| (/ 1 0) |# (error "boom") |# 1 2)

==> 3

; Nested comment where the inner comment has its own #| |# pairs

>>> (list #| x #| y |# z |# 1 2)

==> (1 2)

; --- #| does NOT start a block comment in these contexts ---

; Inside a string literal

>>> (string-length "#| not a comment |#")

==> 19

>>> (string-ref "#|" 0)

==> #\#

; Inside a line comment — the #| is ignored along with the rest of the line

>>> (+ 10 20) ; #| this does not open a block comment

==> 30

>>> (+ 1 2) ; #| open
... ; |# close — neither line above opened a real block comment

==> 3

; ==========================================================================
; Datum comments  #;
; ==========================================================================

; #; causes the reader to read and discard the immediately following datum.
; Intervening whitespace and comments between #; and its datum are ignored.

; --- Skipping each datum type ---

; Skip an exact integer

>>> (+ #; 99 1 2)

==> 3

; Skip a negative number

>>> (+ #; -99 1 2)

==> 3

; Skip a real number

>>> (+ #; 3.14 1 2)

==> 3

; Skip a string

>>> (+ #; "hello world" 1 2)

==> 3

; Skip a boolean

>>> (+ #; #t 1 2)

==> 3

>>> (+ #; #f 1 2)

==> 3

; Skip a character

>>> (+ #; #\a 1 2)

==> 3

; Skip an identifier

>>> (+ #; foo 1 2)

==> 3

; Skip a list — the entire list is a single datum

>>> (+ #; (a b c d) 1 2)

==> 3

; Skip a nested list

>>> (+ #; (a (b (c d) e) f) 1 2)

==> 3

; Skip a vector

>>> (+ #; #(10 20 30) 1 2)

==> 3

; Skip a bytevector

>>> (+ #; #u8(1 2 3) 1 2)

==> 3

; Skip a quoted form — 'x is an abbreviation for (quote x), which is one datum

>>> (+ #; 'foo 1 2)

==> 3

; Skip a quasiquoted form

>>> (+ #; `(1 2 3) 1 2)

==> 3

; Skip an unquote form

>>> (+ #; ,foo 1 2)

==> 3

; --- Datum comments inside expressions ---

; Datum comment removes one argument from a call

>>> (list #; 1 2 3)

==> (2 3)

>>> (list 1 #; 2 3)

==> (1 3)

>>> (list 1 2 #; 3)

==> (1 2)

; Multiple datum comments in one expression

>>> (+ #; 10 #; 20 1 2)

==> 3

>>> (list #; 1 #; 2 #; 3 4)

==> (4)

; Datum comment on a multi-line list

>>> (+ #; (a
...        b
...        c) 1 2)

==> 3

; --- Whitespace and other comments between #; and its datum ---

; Whitespace between #; and the datum

>>> (+ #;   99 1 2)

==> 3

; A block comment between #; and its datum — the block comment is skipped,
; the datum is what follows the block comment

>>> (+ #; #| this is not the datum |# 99 1 2)

==> 3

; Block comment between #; and a list datum

>>> (list 1 #; #| skip |# (2 3) 4)

==> (1 4)

; A line comment between #; and its datum — #; skips the comment and finds
; the datum on the continuation line

>>> (list 1 #; ; the datum is on the next line
...       2 3)

==> (1 3)

; --- The datum skipped by #; may itself contain comments ---

; The skipped datum contains a block comment internally

>>> (+ #; (a #| block |# b) 1 2)

==> 3

; The skipped datum contains a datum comment internally

>>> (+ #; (a #; b c) 1 2)

==> 3

; The skipped datum contains a line comment (requires multi-line)

>>> (+ #; (a  ; comment inside the skipped datum
...         b) 1 2)

==> 3

; --- #; does NOT activate inside other comment forms ---

; Inside a block comment

>>> (+ #| #; 99 |# 1 2)

==> 3

; Inside a line comment

>>> (+ 1 2) ; #; 99 everything here is a comment

==> 3

; --- Stacking datum comments: the ambiguous case ---
;
; #; #; x y
;
; Interpretation A: #; treats the next complete datum as one unit.
;   If #;datum is itself a datum, then the first #; skips (#; x) as a unit,
;   leaving y.  Result: (list y ...)
;
; Interpretation B: each #; independently reads and discards one datum.
;   The first #; encounters the second #; (a reader directive, not a datum),
;   which discards x; the first #; then discards y.
;   Result: nothing consumed from the surrounding expression beyond x and y.
;
; Both interpretations are conforming.

>>> (list #; #; 1 2 3)

==> (2 3) or ==> (3)

>>> (list 0 #; #; 10 20 30)

==> (0 20 30) or ==> (0 30)

; ==========================================================================
; Interaction cases
; ==========================================================================

; --- Semicolon inside #| ... |# ---
; A semicolon inside a block comment does not start a line comment;
; the block comment continues past what would be a line-comment boundary.

>>> (+ #| first line ; with semicolon
...    second line still in comment |# 1 2)

==> 3

; Many semicolons inside a block comment

>>> (+ #| ; ; ; ; ; ; |# 1 2)

==> 3

; --- #| inside a ; line comment ---
; A #| sequence inside a line comment does not open a block comment.
; The |# on the next line is also inside a line comment; nothing is opened.

>>> (+ 1 2) ; this #| does not open a block comment
... ; |# this |# does not close anything either

==> 3

; --- Line comment close does not affect block comment ---
; A newline that ends a line comment does not close an enclosing block comment.

>>> (+ #| line: ; ends here
...    but block comment continues |# 1 2)

==> 3

; --- #; skipping a datum that begins with a block comment ---
; The block comment between #; and the datum is treated as whitespace;
; the datum is the first non-comment token after #;.

>>> (list 1 #; #| not the datum |# (2 3) 4)

==> (1 4)

; --- #; inside a block comment does not activate ---

>>> (list #| #; 99 |# 1 2)

==> (1 2)

; --- Mixed nesting: block comments containing datum comment markers ---

>>> (+ #| #; this #; is #| all |# comment |# 1 2)

==> 3

; --- Block comment immediately before/after other comment forms ---

; Block comment followed immediately by line comment

>>> #|block|# ; line comment
... 77

==> 77

; Line comment followed by block comment on the next line

>>> ; line comment
... #| block comment |# 88

==> 88

; --- Datum comment followed immediately by a block comment datum ---
; The datum being skipped is itself a block comment? No: a block comment
; is not a datum.  #; skips through it to find the real datum.

>>> (list 1 #; #|skip me|# 2 3)

==> (1 3)

; --- Whitespace significance adjacent to comment boundaries ---

; No space before #; still works

>>> (list 1#;2 3)

==> (1 3)

; No space after |# still works

>>> (+ 1#|skip|#2)

==> 3

; No space before or after block comment in operator position

>>> (#|leading|#+#|trailing|# 1 2)

==> 3

; ==========================================================================
; ADDITIONAL R7RS COMPLIANCE TESTS
; ==========================================================================

; ==========================================================================
; Comments are treated exactly like whitespace (R7RS 2.2)
; A comment can therefore separate tokens that would otherwise merge.
; ==========================================================================

; A line comment terminates a token: 1<newline>2 are two separate datums,
; the line comment runs to end of line and the next datum is on the next line

>>> (+ 1 ;
... 2)

==> 3

; A block comment acts as a token separator between two numbers

>>> (list 1#|sep|#2 3)

==> (1 2 3)

; A datum comment that removes the operator-position datum leaves the next
; datum as the operator

>>> (#;car cdr '(1 2 3))

==> (2 3)

; ==========================================================================
; #; skipping the final datum of a form (R7RS 2.2)
; ==========================================================================

; #; on the last element removes it entirely

>>> (+ 1 2 #; 3)

==> 3

; #; skipping the only remaining argument

>>> (list #; 1)

==> ()

; ==========================================================================
; Nested block comment whose inner text contains an unbalanced-looking |#
; only when it is escaped within a string — strings are not scanned inside
; block comments, but the |# still must pair. Here we verify deeper nesting
; and that the FIRST |# after the LAST #| closes the innermost level.
; ==========================================================================

; Five levels of nesting

>>> (+ #| 1 #| 2 #| 3 #| 4 #| 5 |# 4 |# 3 |# 2 |# 1 |# 100 200)

==> 300

; Nested block comment immediately adjacent (no whitespace) to its opener

>>> (+ #|#|inner|#|# 1 2)

==> 3

; ==========================================================================
; A block comment may span the position between every pair of tokens
; ==========================================================================

>>> #|a|#(#|b|#+#|c|#1#|d|#2#|e|#)#|f|#

==> 3

; ==========================================================================
; #| does not nest with a string's contents, and a string inside an
; expression after a block comment is read normally
; ==========================================================================

>>> (string-append #| skip |# "ab" #| skip |# "cd")

==> "abcd"

; ==========================================================================
; Datum comment in front of a quote/quasiquote abbreviation consumes the
; whole abbreviated datum
; ==========================================================================

>>> (list #; 'skipped 'kept)

==> (kept)

>>> (list #; `(a ,b) 'kept)

==> (kept)

>>> (list 'a #; ,@xs 'b)

==> (a b)

; ==========================================================================
; A line comment as the entire content of a continuation line
; ==========================================================================

>>> (+ 1
... ; this line is only a comment
...    2)

==> 3

; ==========================================================================
; Whitespace-only and comment-only top-level input produces no value;
; the following real expression is unaffected
; ==========================================================================

>>> #| just a comment, nothing else |#

>>> (* 6 7)

==> 42


; ==========================================================================
; ADDITIONAL R7RS COMPLIANCE TESTS
; ==========================================================================

; ===
; A block comment does NOT scan for string contents (R7RS 2.2)
; Only #| and |# pairs are recognized inside a block comment; a double
; quote is just ordinary text, so the first |# closes the comment.
; ===

>>> (+ #| a "string-looking |# 1 2)

==> 3

; ===
; A datum comment may skip a character literal whose name contains a
; delimiter-like spelling (R7RS 2.2 + 6.6): #\( is one datum.
; ===

>>> (list #; #\( 1 2)

==> (1 2)

>>> (list #; #\) 1 2)

==> (1 2)

>>> (list #; #\space 1 2)

==> (1 2)

; ===
; A line comment ends exactly at the newline; the datum on the next line
; is unaffected even with no intervening blank (R7RS 2.2).
; ===

>>> (+ 1 ; comment
... 2 ; another comment
... 3)

==> 6

; ===
; #; skipping a datum whose first token is itself a #!fold-case-shaped
; token is not relevant here; instead verify #; before a vector datum
; that contains nested block comments (R7RS 2.2).
; ===

>>> (list 1 #; #(a #| x |# b) 2)

==> (1 2)

; ===
; Datum comment removing the dotted-pair tail's datum: the #; consumes the
; element after the dot so it is NOT a valid improper list anymore -> error
; OR the reader removes the element leaving a proper list. R7RS leaves the
; interaction unspecified; only the clearly-correct case is tested here:
; #; before a normal element of a proper list.
; ===

>>> (list 'a #; 'b 'c)

==> (a c)

; ===
; A block comment spanning a string boundary in surrounding code: the
; string after the comment is read normally and its quotes are intact.
; ===

>>> (string-length #|skip|# "ab|#cd")

==> 6

; ===
; Empty datum-comment target is impossible: #; with end-of-input or with
; only a closing paren following has no datum to skip -> error.
; ===

>>> (list 1 2 #;)

%%% %any-error%

; ==========================================================================
; ADDITIONAL R7RS COMPLIANCE TESTS
; ==========================================================================

; ===
; Whitespace occurring inside a symbol delimited by vertical lines is
; significant (R7RS 2.2). A space between |...| bars is part of the symbol.
; ===

>>> (symbol->string (quote |a b|))

==> "a b"

>>> (string-length (symbol->string (quote |a b|)))

==> 3

; A single space between the bars yields a one-character symbol name

>>> (string-length (symbol->string (quote | |)))

==> 1

; A tab inside the |...| symbol is significant as well: t w o <tab> w o r d s

>>> (string-length (symbol->string (quote |two	words|)))

==> 9

; ===
; A vertical-bar-delimited symbol with no significant characters denotes the
; same symbol as the ordinary spelling (R7RS 2.2 / 7.1.1).
; ===

>>> (eq? (quote |Hello|) (quote Hello))

==> #t

; ===
; The #!fold-case and #!no-fold-case directives may appear anywhere comments
; are permitted and are treated as comments (R7RS 2.2). Here we verify only
; the "treated as whitespace/comment between tokens" aspect: the directive
; separates tokens and contributes nothing to the surrounding form.
; ===

>>> (+ #!fold-case 1 2)

==> 3

>>> (+ #!no-fold-case 1 2)

==> 3

>>> (list #!fold-case 1 2)

==> (1 2)
