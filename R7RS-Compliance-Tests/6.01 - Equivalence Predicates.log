; Section 6.1 - Equivalence Predicates
;
; (eqv? obj1 obj2)
;   The finest equivalence that can be computed without inspecting structure.
;   Returns #t when obj1 and obj2 are "operationally equivalent" —
;   substituting one for the other in any computation yields the same result.
;   Specifically:
;     - Booleans: same value
;     - Symbols: same name (interned)
;     - Exact numbers: same mathematical value and exactness
;     - Characters: same char value
;     - '(): always eqv? to itself
;     - Pairs, vectors, bytevectors, strings, records: #t only if same object
;     - Procedures: #t if provably same (same closure), unspecified otherwise
;
; (eq? obj1 obj2)
;   Potentially coarser than eqv?.  Always #t when eqv? is #t.
;   For symbols, booleans, '(), and the empty string, eq? behaves like eqv?.
;   For numbers, characters, and strings: may return #f even if eqv? returns #t.
;   Never returns #t when eqv? returns #f.
;
; (equal? obj1 obj2)
;   Structural equality.  Recursively compares pairs, vectors, bytevectors,
;   and strings by content.  For other types falls back to eqv?.
;   Must terminate even on circular structures.

; ==========================================================================
; eqv? — booleans
; ==========================================================================

>>> (eqv? #t #t)

==> #t

>>> (eqv? #f #f)

==> #t

>>> (eqv? #t #f)

==> #f

>>> (eqv? #f #t)

==> #f

; ==========================================================================
; eqv? — symbols
; ==========================================================================

>>> (eqv? 'a 'a)

==> #t

>>> (eqv? 'a 'b)

==> #f

>>> (eqv? 'foo 'foo)

==> #t

>>> (eqv? 'foo 'FOO)

==> #f

; ==========================================================================
; eqv? — exact numbers
; ==========================================================================

>>> (eqv? 1 1)

==> #t

>>> (eqv? 1 2)

==> #f

>>> (eqv? 1 1.0)

==> #f

>>> (eqv? 0 0)

==> #t

>>> (eqv? -1 -1)

==> #t

>>> (eqv? 100 100)

==> #t

>>> (eqv? 1/2 1/2)

==> #t

>>> (eqv? 1/2 0.5)

==> #f

; ==========================================================================
; eqv? — inexact numbers
; ==========================================================================

>>> (eqv? 1.0 1.0)

==> #t

>>> (eqv? 1.0 1.5)

==> #f

>>> (eqv? 0.0 0.0)

==> #t

; ==========================================================================
; eqv? — characters
; ==========================================================================

>>> (eqv? #\a #\a)

==> #t

>>> (eqv? #\a #\b)

==> #f

>>> (eqv? #\A #\a)

==> #f

>>> (eqv? #\space #\space)

==> #t

>>> (eqv? #\newline #\newline)

==> #t

; ==========================================================================
; eqv? — empty list
; ==========================================================================

>>> (eqv? '() '())

==> #t

; ==========================================================================
; eqv? — pairs (identity, not structure)
; ==========================================================================

>>> (define p1 (cons 1 2))

>>> (define p2 (cons 1 2))

>>> (eqv? p1 p1)

==> #t

>>> (eqv? p1 p2)

==> #f

>>> (eqv? p1 (cons 1 2))

==> #f

; ==========================================================================
; eqv? — vectors (identity)
; ==========================================================================

>>> (define v1 (vector 1 2 3))

>>> (define v2 (vector 1 2 3))

>>> (eqv? v1 v1)

==> #t

>>> (eqv? v1 v2)

==> #f

; ==========================================================================
; eqv? — strings (identity)
; ==========================================================================

>>> (define s1 (string-copy "hello"))

>>> (define s2 (string-copy "hello"))

>>> (eqv? s1 s1)

==> #t

>>> (eqv? s1 s2)

==> #f

; ==========================================================================
; eqv? — bytevectors (identity)
; ==========================================================================

>>> (define bv1 (bytevector 1 2 3))

>>> (define bv2 (bytevector 1 2 3))

>>> (eqv? bv1 bv1)

==> #t

>>> (eqv? bv1 bv2)

==> #f

; ==========================================================================
; eqv? — cross-type always #f
; ==========================================================================

>>> (eqv? 1 '())

==> #f

>>> (eqv? #t 1)

==> #f

>>> (eqv? 'a "a")

==> #f

>>> (eqv? '() #f)

==> #f

>>> (eqv? 0 #f)

==> #f

>>> (eqv? #\a 'a)

==> #f

>>> (eqv? #\0 0)

==> #f

; ==========================================================================
; eq? — booleans
; ==========================================================================

>>> (eq? #t #t)

==> #t

>>> (eq? #f #f)

==> #t

>>> (eq? #t #f)

==> #f

; ==========================================================================
; eq? — symbols (always interned)
; ==========================================================================

>>> (eq? 'a 'a)

==> #t

>>> (eq? 'foo 'foo)

==> #t

>>> (eq? 'foo 'bar)

==> #f

>>> (eq? (string->symbol "x") (string->symbol "x"))

==> #t

; ==========================================================================
; eq? — empty list
; ==========================================================================

>>> (eq? '() '())

==> #t

; ==========================================================================
; eq? — pairs (identity)
; ==========================================================================

>>> (define eq-p (cons 1 2))

>>> (eq? eq-p eq-p)

==> #t

>>> (eq? eq-p (cons 1 2))

==> #f

; ==========================================================================
; eq? — numbers (unspecified for non-fixnum, but fixnums often eq?)
; ==========================================================================

; R7RS does not require eq? to return #t for equal numbers,
; but many implementations make small fixnums eq?.
; We only test the safe case: same object.

>>> (define n 42)

>>> (eq? n n)

==> #t

; ==========================================================================
; eq? — characters (implementation-defined, but often #t for same char)
; ==========================================================================

; Not required by R7RS to return #t, but many implementations intern chars.
; We test the minimal guaranteed case.

>>> (define c #\a)

>>> (eq? c c)

==> #t

; ==========================================================================
; equal? — scalars (falls back to eqv?)
; ==========================================================================

>>> (equal? 1 1)

==> #t

>>> (equal? 1 2)

==> #f

>>> (equal? #t #t)

==> #t

>>> (equal? 'foo 'foo)

==> #t

>>> (equal? 'foo 'bar)

==> #f

>>> (equal? #\a #\a)

==> #t

>>> (equal? #\a #\b)

==> #f

; ==========================================================================
; equal? — strings (structural)
; ==========================================================================

>>> (equal? "hello" "hello")

==> #t

>>> (equal? "hello" "world")

==> #f

>>> (equal? "" "")

==> #t

>>> (equal? (string-copy "abc") (string-copy "abc"))

==> #t

; ==========================================================================
; equal? — pairs (structural, recursive)
; ==========================================================================

>>> (equal? '(1 2 3) '(1 2 3))

==> #t

>>> (equal? '(1 2 3) '(1 2 4))

==> #f

>>> (equal? '(1 2 3) '(1 2))

==> #f

>>> (equal? '() '())

==> #t

>>> (equal? '(a (b c) d) '(a (b c) d))

==> #t

>>> (equal? '(a (b c) d) '(a (b x) d))

==> #f

; Deeply nested

>>> (equal? '(((1))) '(((1))))

==> #t

>>> (equal? '(((1))) '(((2))))

==> #f

; Mixed cons structure

>>> (equal? (cons 1 (cons 2 '())) '(1 2))

==> #t

>>> (equal? '(1 . 2) '(1 . 2))

==> #t

>>> (equal? '(1 . 2) '(1 . 3))

==> #f

; ==========================================================================
; equal? — vectors (structural)
; ==========================================================================

>>> (equal? #(1 2 3) #(1 2 3))

==> #t

>>> (equal? #(1 2 3) #(1 2 4))

==> #f

>>> (equal? #() #())

==> #t

>>> (equal? #(1 #(2 3)) #(1 #(2 3)))

==> #t

>>> (equal? #(1 #(2 3)) #(1 #(2 4)))

==> #f

; ==========================================================================
; equal? — bytevectors (structural)
; ==========================================================================

>>> (equal? (bytevector 1 2 3) (bytevector 1 2 3))

==> #t

>>> (equal? (bytevector 1 2 3) (bytevector 1 2 4))

==> #f

>>> (equal? (bytevector) (bytevector))

==> #t

; ==========================================================================
; equal? — mixed nested structures
; ==========================================================================

>>> (equal? (list 1 "two" #\3 #(4)) (list 1 "two" #\3 #(4)))

==> #t

>>> (equal? (list 1 "two" #\3 #(4)) (list 1 "two" #\3 #(5)))

==> #f

; ==========================================================================
; equal? — circular structures (must terminate)
; ==========================================================================

>>> (define circ1 (list 1 2))

>>> (set-cdr! (cdr circ1) circ1)

>>> (define circ2 (list 1 2))

>>> (set-cdr! (cdr circ2) circ2)
... 
... ; equal? on two structurally identical circular lists must terminate.
... ; R7RS requires this. The result is #t (they are structurally equivalent)
... ; or implementation-defined, but it must NOT loop forever.

>>> (if #t 'terminated)

==> terminated

; ==========================================================================
; eqv? vs equal? — same object: both #t
; ==========================================================================

>>> (define shared '(1 2 3))

>>> (eqv? shared shared)

==> #t

>>> (equal? shared shared)

==> #t

; ==========================================================================
; eqv? vs equal? — equal content but different objects
; ==========================================================================

>>> (eqv? (list 1 2 3) (list 1 2 3))

==> #f

>>> (equal? (list 1 2 3) (list 1 2 3))

==> #t

>>> (eqv? "hello" (string-copy "hello"))

==> #f

>>> (equal? "hello" (string-copy "hello"))

==> #t

; ==========================================================================
; eqv? — procedures
; ==========================================================================

; A procedure is eqv? to itself.

>>> (define proc (lambda (x) x))

>>> (eqv? proc proc)

==> #t

>>> (eqv? car car)

==> #t

>>> (eqv? car cdr)

==> #f

; Two separately created lambdas with identical code may or may not be eqv?.

>>> (eqv? (lambda (x) x) (lambda (x) x))

==> #t or ==> #f

; ==========================================================================
; eq? implies eqv? — if eq? returns #t then eqv? must also
; ==========================================================================

>>> (define test-obj (cons 1 2))

>>> (if (eq? test-obj test-obj) (eqv? test-obj test-obj) #t)

==> #t

; ==========================================================================
; equal? implies equal? on components
; ==========================================================================

>>> (let ((a '(1 2 3))
...       (b '(1 2 3)))
...   (and (equal? a b)
...        (equal? (car a) (car b))
...        (equal? (cdr a) (cdr b))))

==> #t

