; Section 5.4 - Syntax Definitions
;
; (define-syntax <keyword> <transformer>)
;
; Binds <keyword> to a macro transformer.  The transformer is most
; commonly a syntax-rules expression but may be any expression that
; evaluates to a transformer object.
;
; At top level: creates a global syntactic binding visible to all
; subsequent top-level forms.
;
; In a body (lambda, let, etc.): creates a local syntactic binding
; visible throughout the body (including to earlier-appearing definitions,
; as with letrec* — mutual recursion between syntax definitions is allowed).
;
; A syntax binding occupies the same namespace as variable bindings.
; A define-syntax can shadow a variable binding and vice-versa.

; ==========================================================================
; define-syntax — basic top-level macro
; ==========================================================================

>>> (define-syntax my-when
...   (syntax-rules ()
...     ((my-when test expr ...)
...      (if test (begin expr ...) (if #f #f)))))

>>> (my-when #t 'yes)

==> yes

>>> (my-when #f 'never)
... 
... ; unspecified — no error

>>> (my-when #t 1 2 3)

==> 3

; ==========================================================================
; define-syntax — macro visible globally after definition
; ==========================================================================

>>> (define-syntax my-unless
...   (syntax-rules ()
...     ((my-unless test expr ...)
...      (if test (if #f #f) (begin expr ...)))))

>>> (my-unless #f 'triggered)

==> triggered

>>> (my-unless #t 'not-triggered)
... 
... ; unspecified

>>> (define (use-my-unless x)
...   (my-unless (= x 0) (* x 2)))

>>> (use-my-unless 5)

==> 10

; ==========================================================================
; define-syntax — macro with multiple rules
; ==========================================================================

>>> (define-syntax my-cond
...   (syntax-rules (else)
...     ((my-cond (else e ...)) (begin e ...))
...     ((my-cond (test e ...) rest ...)
...      (if test (begin e ...) (my-cond rest ...)))))

>>> (my-cond (#f 'no) (#t 'yes) (else 'default))

==> yes

>>> (my-cond (#f 'no) (else 'default))

==> default

>>> (my-cond (else 'only))

==> only

; ==========================================================================
; define-syntax — recursive macro (uses itself in expansion)
; ==========================================================================

>>> (define-syntax my-and
...   (syntax-rules ()
...     ((my-and)           #t)
...     ((my-and e)         e)
...     ((my-and e1 e2 ...)
...      (if e1 (my-and e2 ...) #f))))

>>> (my-and)

==> #t

>>> (my-and 1 2 3)

==> 3

>>> (my-and 1 #f 3)

==> #f

>>> (my-and 'a 'b 'c 'd)

==> d

; ==========================================================================
; define-syntax — used inside a procedure definition
; ==========================================================================

>>> (define-syntax inc!
...   (syntax-rules ()
...     ((inc! var)   (set! var (+ var 1)))
...     ((inc! var n) (set! var (+ var n)))))

>>> (define counter 0)

>>> (inc! counter)

>>> counter

==> 1

>>> (inc! counter 5)

>>> counter

==> 6

; ==========================================================================
; define-syntax — macro expanding to a definition
; ==========================================================================

>>> (define-syntax def-double
...   (syntax-rules ()
...     ((def-double name val)
...      (define name (* val 2)))))

>>> (def-double twenty 10)

>>> twenty

==> 20

>>> (def-double hundred 50)

>>> hundred

==> 100

; ==========================================================================
; define-syntax — macro expanding to a procedure definition
; ==========================================================================

>>> (define-syntax def-pred
...   (syntax-rules ()
...     ((def-pred name test)
...      (define (name x) (if (test x) #t #f)))))

>>> (def-pred my-positive? positive?)

>>> (my-positive? 5)

==> #t

>>> (my-positive? -1)

==> #f

>>> (def-pred my-zero? zero?)

>>> (my-zero? 0)

==> #t

; ==========================================================================
; Internal define-syntax — local syntactic binding in a body
; ==========================================================================

>>> (let ()
...   (define-syntax local-sq
...     (syntax-rules ()
...       ((local-sq x) (* x x))))
...   (local-sq 7))

==> 49

>>> (define (with-local-macro x)
...   (define-syntax double-it
...     (syntax-rules ()
...       ((double-it v) (* v 2))))
...   (double-it x))

>>> (with-local-macro 6)

==> 12

; ==========================================================================
; Internal define-syntax — not visible outside body
; ==========================================================================

; A local define-syntax is scoped to its body, like let-syntax.

>>> (let ()
...   (define-syntax inner-mac
...     (syntax-rules ()
...       ((inner-mac) 'inside)))
...   (inner-mac))

==> inside

; inner-mac is not accessible here (outside the let body)

; ==========================================================================
; Internal define-syntax — can reference later definitions (letrec* scope)
; ==========================================================================

; Within a body, define-syntax and define share the same letrec* scope.
; A macro can expand to use a variable defined later in the same body.

>>> ((lambda ()
...    (define-syntax use-later
...      (syntax-rules ()
...        ((use-later) later-var)))
...    (define later-var 42)
...    (use-later)))

==> 42

; ==========================================================================
; Internal define-syntax — mutual recursion between syntax definitions
; ==========================================================================

; The recursion must bottom out at EXPAND time, so the macros recurse on
; syntactic structure (argument count), not a run-time numeric comparison --
; (if (= n 0) ...) never terminates expansion because the expander cannot
; evaluate (- n 1).  Here my-e?/my-o? consume one argument per step; an even
; argument count is "even", an odd count is "odd".

>>> (let ()
...   (define-syntax my-e?
...     (syntax-rules ()
...       ((my-e?) #t)
...       ((my-e? x rest ...) (my-o? rest ...))))
...   (define-syntax my-o?
...     (syntax-rules ()
...       ((my-o?) #f)
...       ((my-o? x rest ...) (my-e? rest ...))))
...   (list (my-e? a a a a) (my-o? a a a)))

==> (#t #t)

; ==========================================================================
; define-syntax — shadowing a built-in syntax form
; ==========================================================================

; define-syntax can shadow existing syntactic keywords.

>>> (define-syntax if
...   (syntax-rules ()
...     ((if test then else)
...      (cond (test then) (else else)))
...     ((if test then)
...      (cond (test then)))))

>>> (if #t 'yes 'no)

==> yes

>>> (if #f 'yes 'no)

==> no

; ==========================================================================
; define-syntax — shadowing a variable binding
; ==========================================================================

; A syntactic keyword binding shadows a variable of the same name.
; Using the name as an expression (not in call position) is an error.

>>> (define shadow-name 42)

>>> shadow-name

==> 42

>>> (define-syntax shadow-name
...   (syntax-rules ()
...     ((shadow-name x) (* x 2))))

>>> (shadow-name 5)

==> 10

; ==========================================================================
; define-syntax — transformer is evaluated in definition environment
; ==========================================================================

; The transformer expression (e.g. syntax-rules form) is evaluated when
; define-syntax is evaluated.  It captures the environment at that point.

; The template references n, a run-time let binding -- an out-of-phase
; identifier (the transformer runs at expand time, where n has no value).
; This is an error (Chez: "out-of-phase identifier"; we accept any error).
; The common syntax-rules case is exercised by always-42 just below.

>>> (define-syntax capture-env
...   (let ((n 10))
...     (syntax-rules ()
...       ((capture-env) n))))

%%% %any-error%

>>> (define-syntax always-42
...   (syntax-rules ()
...     ((always-42) 42)))

>>> (always-42)

==> 42

; ==========================================================================
; define-syntax — macro generating another define-syntax
; ==========================================================================

; The inner ... belongs to the GENERATED macro, so it must be escaped as
; (... ...) in the outer template -- otherwise the outer syntax-rules consumes
; it as its own ellipsis (Chez: "extra ellipsis in syntax form").

>>> (define-syntax def-alias-syntax
...   (syntax-rules ()
...     ((def-alias-syntax new-name old-name)
...      (define-syntax new-name
...        (syntax-rules ()
...          ((new-name arg (... ...)) (old-name arg (... ...))))))))

>>> (def-alias-syntax my-cons cons)

>>> (my-cons 1 '(2 3))

==> (1 2 3)

>>> (def-alias-syntax my-list list)

>>> (my-list 1 2 3)

==> (1 2 3)

; ==========================================================================
; define-syntax — hygiene across uses
; ==========================================================================

; Each use of a hygienic macro gets its own fresh introduced bindings.

>>> (define-syntax fresh-let
...   (syntax-rules ()
...     ((fresh-let val body)
...      (let ((tmp val)) body))))

>>> (let ((tmp 'outer))
...   (list (fresh-let 99 tmp)
...         tmp))

==> (outer outer)

; The first element is 'outer' because: fresh-let introduces its own
; hygienic 'tmp'; body is the expression 'tmp' which refers to the
; caller's 'tmp' (= 'outer), not the macro-introduced one.
; The macro's 'tmp' is hygienically distinct from the caller's 'tmp'.

; ==========================================================================
; define-syntax — used inside a cond clause
; ==========================================================================

>>> (define-syntax add1-mac
...   (syntax-rules ()
...     ((add1-mac x) (+ x 1))))

>>> (cond (#t (add1-mac 41)))

==> 42

; ==========================================================================
; define-syntax — used in let binding initializer
; ==========================================================================

>>> (define-syntax double-mac
...   (syntax-rules ()
...     ((double-mac x) (* x 2))))

>>> (let ((v (double-mac 21)))
...   v)

==> 42

; ==========================================================================
; define-syntax — error: keyword used as variable reference
; ==========================================================================

; A syntactic keyword used in expression position (not as the head of
; a form it was designed for) is an error.

>>> (define-syntax kw-only
...   (syntax-rules ()
...     ((kw-only x) x)))

>>> kw-only

%%% %any-error%

; ==========================================================================
; ADDITIONAL R7RS COMPLIANCE TESTS
; ==========================================================================

; === define-syntax with the alternate (custom-ellipsis) syntax-rules form

>>> (define-syntax ce-list
...   (syntax-rules ::: ()
...     ((ce-list x :::) (list x :::))))

>>> (ce-list 1 2 3)

==> (1 2 3)

>>> (ce-list)

==> ()

; === define-syntax — macro expanding to define-values

>>> (define-syntax def-two
...   (syntax-rules ()
...     ((def-two a b expr)
...      (define-values (a b) expr))))

>>> (def-two d2-x d2-y (values 11 22))

>>> (list d2-x d2-y)

==> (11 22)

; === define-syntax — macro whose template introduces a local helper define
; The introduced helper is hygienic and does not leak to the use site.

>>> (define-syntax with-tmp-sum
...   (syntax-rules ()
...     ((with-tmp-sum a b)
...      (let ()
...        (define helper (+ a b))
...        (* helper helper)))))

>>> (with-tmp-sum 3 4)

==> 49

; helper is not visible at the use site
>>> helper

%%% %any-error%

; === define-syntax — recursive expansion building a nested expression

>>> (define-syntax nested-add
...   (syntax-rules ()
...     ((nested-add x) x)
...     ((nested-add x y ...) (+ x (nested-add y ...)))))

>>> (nested-add 1 2 3 4 5)

==> 15

>>> (nested-add 10)

==> 10

; === define-syntax — ellipsis pattern that wraps each element (template group)

>>> (define-syntax tag-each
...   (syntax-rules ()
...     ((tag-each x ...) (list (list 'item x) ...))))

>>> (tag-each 'a 'b 'c)

==> ((item a) (item b) (item c))

>>> (tag-each)

==> ()

; === define-syntax — keyword used in operator position only
; The keyword is a valid macro use as a form head, but using bare keyword as
; a value is an error (re-confirm with a fresh keyword and a working use).

>>> (define-syntax op-only
...   (syntax-rules ()
...     ((op-only x y) (cons x y))))

>>> (op-only 1 2)

==> (1 . 2)

>>> op-only

%%% %any-error%

; === Internal define-syntax visible to a sibling internal define's body
; (define and define-syntax share one letrec* region in a body.)

>>> (let ()
...   (define-syntax plus2
...     (syntax-rules ()
...       ((plus2 n) (+ n 2))))
...   (define (apply-plus2 x) (plus2 x))
...   (apply-plus2 40))

==> 42

; === define-syntax — generated macro via (... ...) escape, used immediately

>>> (define-syntax make-listish
...   (syntax-rules ()
...     ((make-listish name)
...      (define-syntax name
...        (syntax-rules ()
...          ((name a (... ...)) (list a (... ...))))))))

>>> (make-listish my-vector-list)

>>> (my-vector-list 1 2 3)

==> (1 2 3)

>>> (my-vector-list)

==> ()

