; Section 3.2 - Disjointness of Types
;
; Every object satisfies at most one of the following predicates:
;   boolean?  bytevector?  char?  eof-object?  null?  number?
;   pair?  port?  procedure?  string?  symbol?  vector?
;
; For each type: verify the self-predicate returns #t and every other
; listed predicate returns #f.  12 types x 12 predicates = 144 tests,
; plus supplementary tests for edge cases and multiple representatives.

; Establish eof-object and port values used throughout

>>> (define the-eof (read (open-input-string "")))

>>> (define the-port (open-input-string ""))
...
... ; ==========================================================================
... ; boolean  (#t and #f)
... ; ==========================================================================

>>> (boolean? #t)

==> #t

>>> (boolean? #f)

==> #t

>>> (bytevector? #t)

==> #f

>>> (char? #t)

==> #f

>>> (eof-object? #t)

==> #f

>>> (null? #t)

==> #f

>>> (number? #t)

==> #f

>>> (pair? #t)

==> #f

>>> (port? #t)

==> #f

>>> (procedure? #t)

==> #f

>>> (string? #t)

==> #f

>>> (symbol? #t)

==> #f

>>> (vector? #t)

==> #f

