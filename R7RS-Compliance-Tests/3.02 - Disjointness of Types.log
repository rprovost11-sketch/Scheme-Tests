; ==========================================================================
; null  —  the empty list
;
; Critical: null? and pair? are disjoint.  The empty list is NOT a pair.
; ==========================================================================

>>> (null? '())

==> #t

>>> (boolean? '())

==> #f

>>> (bytevector? '())

==> #f

>>> (char? '())

==> #f

>>> (eof-object? '())

==> #f

>>> (number? '())

==> #f

; The empty list is NOT a pair — this is a commonly violated invariant

>>> (pair? '())

==> #f

>>> (port? '())

==> #f

>>> (procedure? '())

==> #f

>>> (string? '())

==> #f

>>> (symbol? '())

==> #f

>>> (vector? '())

==> #f

; The empty list is a proper list (list? checks for proper list structure)
; but list? is not one of the disjoint type predicates

>>> (list? '())

==> #t

>>> (pair? '())

==> #f

