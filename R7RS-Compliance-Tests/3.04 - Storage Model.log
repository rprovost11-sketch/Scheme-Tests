; Section 3.4 - Storage Model
;
; Variables are associated with locations; locations hold values.
; set! mutates a variable's location.
; Mutable objects (pairs, strings, vectors, bytevectors) created by
; constructors can have their contents changed in place.
; Literal constants are immutable; attempting to mutate them is an error.
; Aliasing: two references to the same object share its mutable state.

; ==========================================================================
; Variable mutation via set!
; ==========================================================================

>>> (define x 1)

>>> x

==> 1

>>> (set! x 2)

>>> x

==> 2

>>> (set! x "hello")

>>> x

==> "hello"

>>> (set! x '(1 2 3))

>>> x

==> (1 2 3)

; set! on a variable defined in an enclosing scope

>>> (define counter 0)

>>> (define (increment!) (set! counter (+ counter 1)))

>>> (increment!)

>>> counter

==> 1

>>> (increment!)

>>> (increment!)

>>> counter

==> 3

; ==========================================================================
; Pair mutation — set-car! and set-cdr!
; ==========================================================================

; set-car! replaces the car of a pair

>>> (define p (cons 1 2))

>>> (set-car! p 99)

>>> (car p)

==> 99

>>> (cdr p)

==> 2

; set-cdr! replaces the cdr of a pair

>>> (define q (cons 1 2))

>>> (set-cdr! q 99)

>>> (car q)

==> 1

>>> (cdr q)

==> 99

; Mutating within a list

>>> (define lst (list 1 2 3))

>>> (set-car! lst 10)

>>> lst

==> (10 2 3)

>>> (set-car! (cdr lst) 20)

>>> lst

==> (10 20 3)

>>> (set-cdr! (cddr lst) (list 4 5))

>>> lst

==> (10 20 3 4 5)

; set-cdr! can make a list into a dotted pair

>>> (define r (list 1 2))

>>> (set-cdr! r 99)

>>> r

==> (1 . 99)

; set-cdr! can make a circular list

>>> (define circ (list 1 2 3))

>>> (set-cdr! (cddr circ) circ)

>>> (car circ)

==> 1

>>> (cadr circ)

==> 2

>>> (caddr circ)

==> 3

>>> (cadddr circ)

==> 1

>>> (eq? circ (cdddr circ))

==> #t

; ==========================================================================
; String mutation — string-set!
; ==========================================================================

; string-set! replaces a character at a given index

>>> (define s (string-copy "hello"))

>>> (string-set! s 0 #\H)

>>> s

==> "Hello"

>>> (string-set! s 4 #\!)

>>> s

==> "Hell!"

; make-string produces a mutable string

>>> (define ms (make-string 5 #\x))

>>> ms

==> "xxxxx"

>>> (string-set! ms 2 #\O)

>>> ms

==> "xxOxx"

; ==========================================================================
; Vector mutation — vector-set!
; ==========================================================================

>>> (define v (vector 1 2 3))

>>> (vector-set! v 0 99)

>>> (vector-ref v 0)

==> 99

>>> v

==> #(99 2 3)

>>> (vector-set! v 2 42)

>>> v

==> #(99 2 42)

; make-vector produces a mutable vector

>>> (define mv (make-vector 4 0))

>>> (vector-set! mv 1 7)

>>> (vector-set! mv 3 9)

>>> mv

==> #(0 7 0 9)

; ==========================================================================
; Bytevector mutation — bytevector-u8-set!
; ==========================================================================

>>> (define bv (bytevector 10 20 30))

>>> (bytevector-u8-set! bv 0 99)

>>> (bytevector-u8-ref bv 0)

==> 99

>>> bv

==> #u8(99 20 30)

; make-bytevector produces a mutable bytevector

>>> (define mbv (make-bytevector 3 0))

>>> (bytevector-u8-set! mbv 1 128)

>>> (bytevector-u8-set! mbv 2 255)

>>> mbv

==> #u8(0 128 255)

; ==========================================================================
; Aliasing — two references to the same object share mutable state
; ==========================================================================

; Two variables bound to the same pair

>>> (define a (cons 1 2))

>>> (define b a)

>>> (eq? a b)

==> #t

>>> (set-car! a 99)

>>> (car b)

==> 99

>>> (set-cdr! b 77)

>>> (cdr a)

==> 77

; Aliasing with a list element

>>> (define shared (list 1 2))

>>> (define outer (list shared shared))

>>> (set-car! shared 99)

>>> (car (car outer))

==> 99

>>> (car (cadr outer))

==> 99

>>> (eq? (car outer) (cadr outer))

==> #t

; Aliasing with a vector element

>>> (define vec-a (vector 1 2 3))

>>> (define vec-b vec-a)

>>> (vector-set! vec-a 0 42)

>>> (vector-ref vec-b 0)

==> 42

; ==========================================================================
; set! rebinds a variable — distinct from mutating the object
; ==========================================================================

; set! changes what a variable refers to, not the object it referred to

>>> (define orig (cons 1 2))

>>> (define alias orig)

>>> (set! orig (cons 3 4))
...
... ; orig now refers to a new pair; alias still refers to the original

>>> orig

==> (3 . 4)

>>> alias

==> (1 . 2)

>>> (eq? orig alias)

==> #f

; Contrast with mutation: set-car! changes the object, visible through alias

>>> (define p1 (cons 1 2))

>>> (define p2 p1)

>>> (set-car! p1 99)

>>> p2

==> (99 . 2)

>>> (eq? p1 p2)

==> #t

; ==========================================================================
; Immutable literal constants — mutating them is an error
; ==========================================================================

; Quoted pairs are literal constants and must not be mutated

>>> (set-car! '(1 2 3) 99)

%%% %any-error%

>>> (set-cdr! '(1 2 3) 99)

%%% %any-error%

; Literal strings must not be mutated

>>> (string-set! "hello" 0 #\H)

%%% %any-error%

; Literal vectors must not be mutated

>>> (vector-set! #(1 2 3) 0 99)

%%% %any-error%

; Literal bytevectors must not be mutated

>>> (bytevector-u8-set! #u8(1 2 3) 0 99)

%%% %any-error%

; ==========================================================================
; ADDITIONAL R7RS COMPLIANCE TESTS
; ==========================================================================

; === §3.4: a fetched object is eqv? to the object last stored ===
; (vector-set! then vector-ref returns an object eqv? to what was stored)

>>> (define ev (vector 0))

>>> (vector-set! ev 0 'sym)

>>> (eqv? (vector-ref ev 0) 'sym)

==> #t

; set-car! then car returns an object eqv? to what was stored

>>> (define ep (cons 'a 'b))

>>> (set-car! ep 'z)

>>> (eqv? (car ep) 'z)

==> #t

; === §3.4: storing into a location does not change which object denotes it ===
; A string mutated by string-set! continues to be the same (eq?) object;
; the change is visible through an alias.

>>> (define id-s (string-copy "abc"))

>>> (define id-s2 id-s)

>>> (string-set! id-s 0 #\Z)

>>> (eq? id-s id-s2)

==> #t

>>> id-s2

==> "Zbc"

; === §3.4: the empty list is a unique object; it cannot be newly allocated ===

>>> (eq? '() '())

==> #t

>>> (eq? (cdr (list 1)) '())

==> #t

; === §3.4: all objects created by procedures (other than the immutable ===
; cases) are mutable. string-append produces a mutable string.

>>> (define app-s (string-append "ab" "cd"))

>>> (string-set! app-s 0 #\X)

>>> app-s

==> "Xbcd"

; list-copy produces a mutable list

>>> (define lc (list-copy '(1 2 3)))

>>> (set-car! lc 99)

>>> lc

==> (99 2 3)

; vector-copy produces a mutable vector

>>> (define vc (vector-copy #(1 2 3)))

>>> (vector-set! vc 0 99)

>>> vc

==> #(99 2 3)

; bytevector-copy produces a mutable bytevector

>>> (define bc (bytevector-copy #u8(1 2 3)))

>>> (bytevector-u8-set! bc 0 99)

>>> bc

==> #u8(99 2 3)

