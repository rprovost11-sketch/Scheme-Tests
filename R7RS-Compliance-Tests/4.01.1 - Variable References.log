; Section 4.1.1 - Variable References
;
; An identifier that appears as an expression is a variable reference.
; It evaluates to the value currently bound to the variable in the
; current environment.  It is an error to reference an unbound variable.

; ==========================================================================
; Basic variable reference
; ==========================================================================

>>> (define x 42)

>>> x

==> 42

>>> (define y "hello")

>>> y

==> "hello"

>>> (define b #t)

>>> b

==> #t

>>> (define c #\a)

>>> c

==> #\a

>>> (define n 3.14)

>>> n

==> 3.14

>>> (define p '(1 2 3))

>>> p

==> (1 2 3)

; ==========================================================================
; Variable reference returns the current value — after set! it returns
; the new value, not the original
; ==========================================================================

>>> (define v 1)

>>> v

==> 1

>>> (set! v 2)

>>> v

==> 2

>>> (set! v "changed")

>>> v

==> "changed"

>>> (set! v '(a b c))

>>> v

==> (a b c)

; ==========================================================================
; Variable references in expression contexts
; ==========================================================================

; As an argument to a procedure

>>> (define a 10)

>>> (define b 20)

>>> (+ a b)

==> 30

>>> (list a b)

==> (10 20)

; As the operator in a call — a variable can hold a procedure

>>> (define my-add +)

>>> (my-add 3 4)

==> 7

>>> (define my-car car)

>>> (my-car '(1 2 3))

==> 1

; Nested references

>>> (define m 5)

>>> (define n 6)

>>> (* (+ m n) (- n m))

==> 11

; ==========================================================================
; Built-in identifiers are variable references
; ==========================================================================

>>> (procedure? +)

==> #t

>>> (procedure? car)

==> #t

>>> (procedure? map)

==> #t

>>> (procedure? null?)

==> #t

; ==========================================================================
; Each variable reference is independent
; ==========================================================================

>>> (define r 1)

>>> (define s r)

>>> (set! r 99)
...
... ; s still holds the value r had at the time of the define, not r's new value

>>> r

==> 99

>>> s

==> 1

; ==========================================================================
; Unbound variable reference is an error
; ==========================================================================

>>> no-such-variable

%%% %any-error%

>>> (+ 1 no-such-variable)

%%% %any-error%

>>> (define (f) no-such-variable)

>>> (f)

%%% %any-error%

