; Section 4.3.2 - Pattern Language (syntax-rules)
;
; (syntax-rules (<literal> ...) <rule> ...)
; (syntax-rules <ellipsis> (<literal> ...) <rule> ...)   [alternate ellipsis]
;
; Each <rule> is (<pattern> <template>).
; The <pattern> begins with the macro keyword (ignored in matching).
; Remaining pattern elements:
;   <identifier>    — pattern variable: matches any subform, bound in template
;   <literal>       — must appear literally in the input (compared with free-id=?)
;   _               — wildcard: matches anything, not bound
;   (<pat> ...)     — matches a list
;   (<pat> <ellipsis>) — matches zero or more occurrences of <pat>
;   #(<pat> ...)    — matches a vector
;   <datum>         — self-quoting literal (number, bool, char, string)
;
; Templates:
;   <pattern-variable>         — inserts matched subform
;   (<element> ...)            — builds a list
;   (<element> <ellipsis> ...) — repeats element for each match of ellipsis var
;   #(<element> ...)           — builds a vector

; ==========================================================================
; syntax-rules — basic single pattern, no literals
; ==========================================================================

>>> (define-syntax my-quote
...   (syntax-rules ()
...     ((my-quote x) 'x)))

>>> (my-quote hello)

==> hello

>>> (my-quote (1 2 3))

==> (1 2 3)

; ==========================================================================
; syntax-rules — pattern variable matches any subform
; ==========================================================================

>>> (define-syntax identity-mac
...   (syntax-rules ()
...     ((identity-mac x) x)))

>>> (identity-mac 42)

==> 42

>>> (identity-mac (+ 1 2))

==> 3

>>> (identity-mac (lambda (x) x))

==> #<procedure>

; ==========================================================================
; syntax-rules — multiple pattern variables
; ==========================================================================

>>> (define-syntax my-if
...   (syntax-rules ()
...     ((my-if test then else)
...      (cond (test then) (else else)))))

>>> (my-if #t 'yes 'no)

==> yes

>>> (my-if #f 'yes 'no)

==> no

>>> (define-syntax my-list2
...   (syntax-rules ()
...     ((my-list2 a b) (cons a (cons b '())))))

>>> (my-list2 1 2)

==> (1 2)

>>> (my-list2 'x 'y)

==> (x y)

; ==========================================================================
; syntax-rules — multiple rules (first match wins)
; ==========================================================================

>>> (define-syntax my-and
...   (syntax-rules ()
...     ((my-and)         #t)
...     ((my-and e)       e)
...     ((my-and e1 e2)   (if e1 e2 #f))))

>>> (my-and)

==> #t

>>> (my-and 42)

==> 42

>>> (my-and #t 99)

==> 99

>>> (my-and #f 99)

==> #f

; ==========================================================================
; syntax-rules — recursive macro using ellipsis
; ==========================================================================

>>> (define-syntax my-or
...   (syntax-rules ()
...     ((my-or)           #f)
...     ((my-or e)         e)
...     ((my-or e1 e2 ...)
...      (let ((t e1))
...        (if t t (my-or e2 ...))))))

>>> (my-or)

==> #f

>>> (my-or 42)

==> 42

>>> (my-or #f 42)

==> 42

>>> (my-or #f #f 'found)

==> found

>>> (my-or #f #f #f)

==> #f

; ==========================================================================
; syntax-rules — ellipsis in pattern and template
; ==========================================================================

>>> (define-syntax my-list
...   (syntax-rules ()
...     ((my-list x ...) (list x ...))))

>>> (my-list)

==> ()

>>> (my-list 1)

==> (1)

>>> (my-list 1 2 3)

==> (1 2 3)

>>> (my-list 'a 'b 'c 'd 'e)

==> (a b c d e)

; ==========================================================================
; syntax-rules — ellipsis: pattern variable used in template expression
; ==========================================================================

>>> (define-syntax my-map-add1
...   (syntax-rules ()
...     ((my-map-add1 x ...) (list (+ x 1) ...))))

>>> (my-map-add1 1 2 3)

==> (2 3 4)

>>> (my-map-add1 10 20 30)

==> (11 21 31)

; ==========================================================================
; syntax-rules — ellipsis matching zero elements
; ==========================================================================

>>> (define-syntax zero-or-more
...   (syntax-rules ()
...     ((zero-or-more x ...) (length (list x ...)))))

>>> (zero-or-more)

==> 0

>>> (zero-or-more 'a)

==> 1

>>> (zero-or-more 'a 'b 'c)

==> 3

; ==========================================================================
; syntax-rules — fixed args before ellipsis
; ==========================================================================

>>> (define-syntax first-and-rest
...   (syntax-rules ()
...     ((first-and-rest head tail ...)
...      (list head (list tail ...)))))

>>> (first-and-rest 1 2 3 4)

==> (1 (2 3 4))

>>> (first-and-rest 'a)

==> (a ())

; ==========================================================================
; syntax-rules — multiple ellipsis groups in template
; ==========================================================================

>>> (define-syntax zip-lists
...   (syntax-rules ()
...     ((zip-lists (a ...) (b ...))
...      (list (list a b) ...))))

>>> (zip-lists (1 2 3) (a b c))

==> ((1 a) (2 b) (3 c))

>>> (zip-lists () ())

==> ()

; ==========================================================================
; syntax-rules — literal keywords in pattern
; ==========================================================================

; A literal in the literals list must appear literally in the input.
; It is not treated as a pattern variable.

>>> (define-syntax my-cond-kw
...   (syntax-rules (else)
...     ((my-cond-kw (else e)) e)
...     ((my-cond-kw (test e) rest ...)
...      (if test e (my-cond-kw rest ...)))))

>>> (my-cond-kw (#f 'no) (#t 'yes) (else 'default))

==> yes

>>> (my-cond-kw (#f 'no) (else 'default))

==> default

>>> (my-cond-kw (else 'only-else))

==> only-else

; ==========================================================================
; syntax-rules — literal: non-literal use of same name is a pattern variable
; ==========================================================================

; 'else' as a literal matches the identifier else; if not in literals list,
; it would be a pattern variable matching anything.

>>> (define-syntax no-literal
...   (syntax-rules ()
...     ((no-literal else-val) else-val)))

>>> (no-literal 99)

==> 99

>>> (no-literal else)

==> else

; 'else' matched as a pattern variable — result is the symbol else.

; ==========================================================================
; syntax-rules — underscore wildcard
; ==========================================================================

>>> (define-syntax ignore-first
...   (syntax-rules ()
...     ((ignore-first _ x) x)))

>>> (ignore-first 'discarded 42)

==> 42

>>> (ignore-first (this is ignored) 'kept)

==> kept

>>> (define-syntax assert-two
...   (syntax-rules ()
...     ((assert-two _ _) 'two-args)))

>>> (assert-two 1 2)

==> two-args

; ==========================================================================
; syntax-rules — hygiene: macro-introduced bindings don't leak
; ==========================================================================

; The 'tmp' introduced by the macro is hygienic — it does not capture
; any 'tmp' in the caller's environment.

>>> (define-syntax hygienic-swap!
...   (syntax-rules ()
...     ((hygienic-swap! a b)
...      (let ((tmp a))
...        (set! a b)
...        (set! b tmp)))))

>>> (define tmp 'original)
>>> (define x 1)
>>> (define y 2)
>>> (hygienic-swap! x y)
>>> (list x y tmp)

==> (2 1 original)

; ==========================================================================
; syntax-rules — hygiene: free variables in template refer to definition env
; ==========================================================================

; 'cons' referred to in the macro template resolves to the cons visible
; at macro definition time, not at use time.

>>> (define-syntax make-pair-mac
...   (syntax-rules ()
...     ((make-pair-mac a b) (cons a b))))

>>> (make-pair-mac 1 2)

==> (1 . 2)

; Even if cons is shadowed at call site, macro still uses the original.
>>> (let ((cons list))
...   (make-pair-mac 1 2))

==> (1 . 2)

; ==========================================================================
; syntax-rules — hygiene: pattern variables ARE substituted (not hygienic)
; ==========================================================================

; Pattern variables carry the use-site environment when substituted.

>>> (define-syntax use-caller-env
...   (syntax-rules ()
...     ((use-caller-env expr) expr)))

>>> (let ((x 42))
...   (use-caller-env x))

==> 42

; ==========================================================================
; syntax-rules — nested patterns
; ==========================================================================

>>> (define-syntax my-let
...   (syntax-rules ()
...     ((my-let ((var init) ...) body ...)
...      ((lambda (var ...) body ...) init ...))))

>>> (my-let ((x 1) (y 2)) (+ x y))

==> 3

>>> (my-let ((a 10) (b 20) (c 30)) (* a b c))

==> 6000

>>> (my-let () 'empty)

==> empty

; ==========================================================================
; syntax-rules — nested ellipsis (two levels deep)
; ==========================================================================

>>> (define-syntax my-let*-mac
...   (syntax-rules ()
...     ((my-let*-mac () body ...)
...      (begin body ...))
...     ((my-let*-mac ((var init) rest ...) body ...)
...      (let ((var init))
...        (my-let*-mac (rest ...) body ...)))))

>>> (my-let*-mac ((x 1) (y (+ x 1)) (z (+ x y))) (list x y z))

==> (1 2 3)

>>> (my-let*-mac () 'base-case)

==> base-case

; ==========================================================================
; syntax-rules — vector patterns
; ==========================================================================

>>> (define-syntax vec-first
...   (syntax-rules ()
...     ((vec-first #(a b ...)) a)))

>>> (vec-first #(10 20 30))

==> 10

>>> (define-syntax vec-to-list
...   (syntax-rules ()
...     ((vec-to-list #(x ...)) (list x ...))))

>>> (vec-to-list #(1 2 3))

==> (1 2 3)

>>> (vec-to-list #())

==> ()

; ==========================================================================
; syntax-rules — datum literals in pattern
; ==========================================================================

; Literal datums (numbers, booleans, chars) match themselves.

>>> (define-syntax match-zero
...   (syntax-rules ()
...     ((match-zero 0) 'zero)
...     ((match-zero n) 'nonzero)))

>>> (match-zero 0)

==> zero

>>> (match-zero 1)

==> nonzero

>>> (match-zero -1)

==> nonzero

>>> (define-syntax match-true
...   (syntax-rules ()
...     ((match-true #t) 'true)
...     ((match-true #f) 'false)
...     ((match-true _)  'other)))

>>> (match-true #t)

==> true

>>> (match-true #f)

==> false

>>> (match-true 0)

==> other

; ==========================================================================
; syntax-rules — template builds a vector
; ==========================================================================

>>> (define-syntax make-vec
...   (syntax-rules ()
...     ((make-vec x ...) (vector x ...))))

>>> (make-vec 1 2 3)

==> #(1 2 3)

>>> (make-vec)

==> #()

; ==========================================================================
; syntax-rules — pattern matching list structure
; ==========================================================================

>>> (define-syntax car-mac
...   (syntax-rules ()
...     ((car-mac (h . t)) h)))

>>> (car-mac (1 2 3))

==> 1

>>> (car-mac (a b c))

==> a

>>> (define-syntax cdr-mac
...   (syntax-rules ()
...     ((cdr-mac (h . t)) t)))

>>> (cdr-mac (1 2 3))

==> (2 3)

; ==========================================================================
; syntax-rules — define-syntax at top level
; ==========================================================================

>>> (define-syntax incr
...   (syntax-rules ()
...     ((incr x) (+ x 1))
...     ((incr x n) (+ x n))))

>>> (incr 5)

==> 6

>>> (incr 5 10)

==> 15

; ==========================================================================
; syntax-rules — while loop macro
; ==========================================================================

>>> (define-syntax while
...   (syntax-rules ()
...     ((while test body ...)
...      (let loop ()
...        (when test
...          body ...
...          (loop))))))

>>> (define w-i 0)

>>> (while (< w-i 5)
...   (set! w-i (+ w-i 1)))

>>> w-i

==> 5

; ==========================================================================
; syntax-rules — swap! macro
; ==========================================================================

>>> (define-syntax swap!
...   (syntax-rules ()
...     ((swap! a b)
...      (let ((t a))
...        (set! a b)
...        (set! b t)))))

>>> (define sa 'left)
>>> (define sb 'right)
>>> (swap! sa sb)
>>> (list sa sb)

==> (right left)

; ==========================================================================
; syntax-rules — no matching pattern is an error
; ==========================================================================

>>> (define-syntax exact-one
...   (syntax-rules ()
...     ((exact-one x) x)))

>>> (exact-one 1 2)

%%% %any-error%

>>> (exact-one)

%%% %any-error%

