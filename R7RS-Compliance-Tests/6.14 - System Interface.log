; Section 6.14 - System Interface
;
; (load filename)                [from (scheme load)]
;   Reads and evaluates expressions from a file.
;
; (file-exists? filename)        [from (scheme file)]
;   Returns #t if the file exists.
;
; (delete-file filename)         [from (scheme file)]
;   Deletes the named file.
;
; (command-line)                 [from (scheme process-context)]
;   Returns the command-line arguments as a list of strings.
;
; (exit)                         [from (scheme process-context)]
; (exit obj)
;   Exits the program. Integer obj is the exit code; #t means success,
;   #f means failure.
;
; (emergency-exit)               [from (scheme process-context)]
; (emergency-exit obj)
;   Exits without running dynamic-wind after thunks or finalizers.
;
; (get-environment-variable name)  [from (scheme process-context)]
;   Returns the value of the named environment variable as a string,
;   or #f if not defined.
;
; (get-environment-variables)    [from (scheme process-context)]
;   Returns an alist of all environment variables as (name . value) pairs.
;
; (current-second)               [from (scheme time)]
;   Returns current time as an inexact real (seconds since a fixed epoch).
;
; (current-jiffy)                [from (scheme time)]
;   Returns current time in jiffies (implementation-defined unit).
;
; (jiffies-per-second)           [from (scheme time)]
;   Returns number of jiffies per second (exact integer).
;
; Note: These procedures are in separate libraries and must be imported.

; ==========================================================================
; Import required libraries
; ==========================================================================

>>> (import (scheme file))

>>> (import (scheme process-context))

>>> (import (scheme time))
... 
... ; ==========================================================================
... ; file-exists? — check file presence
... ; ==========================================================================

>>> (procedure? file-exists?)

==> #t

; Create a file, check existence, delete, check again

>>> (call-with-output-file "6.14-existence-test.tmp"
...   (lambda (p) (display "test" p)))

>>> (file-exists? "6.14-existence-test.tmp")

==> #t

>>> (file-exists? "this-file-surely-does-not-exist-xyz987.txt")

==> #f

; file-exists? returns a boolean

>>> (boolean? (file-exists? "6.14-existence-test.tmp"))

==> #t

; ==========================================================================
; delete-file — remove a file
; ==========================================================================

>>> (procedure? delete-file)

==> #t

; delete-file removes the file

>>> (delete-file "6.14-existence-test.tmp")

>>> (file-exists? "6.14-existence-test.tmp")

==> #f

; delete-file on nonexistent file signals an error

>>> (delete-file "nonexistent-file-xyz.txt")

%%% %any-error%

; ==========================================================================
; command-line — list of strings
; ==========================================================================

>>> (procedure? command-line)

==> #t

; command-line returns a list

>>> (list? (command-line))

==> #t

; Each element is a string

>>> (for-each (lambda (s) (if (not (string? s)) (error "not a string" s) #f))
...           (command-line))
... 
... ; The first element is typically the program name (implementation-defined)

>>> (string? (car (command-line)))

==> #t

; ==========================================================================
; get-environment-variable — look up a single variable
; ==========================================================================

>>> (procedure? get-environment-variable)

==> #t

; Result is either a string or #f

>>> (let ((v (get-environment-variable "PATH")))
...   (or (string? v) (eq? v #f)))

==> #t

; Non-existent variable returns #f

>>> (get-environment-variable "THIS_VARIABLE_DOES_NOT_EXIST_XYZ_12345")

==> #f

; Result type is string when variable exists

>>> (let ((v (get-environment-variable "PATH")))
...   (if v (string? v) #t))

==> #t

; ==========================================================================
; get-environment-variables — alist of all variables
; ==========================================================================

>>> (procedure? get-environment-variables)

==> #t

; Result is a list

>>> (list? (get-environment-variables))

==> #t

; Each element is a pair

>>> (let ((env (get-environment-variables)))
...   (if (null? env)
...       #t
...       (pair? (car env))))

==> #t

; Keys and values are strings

>>> (let ((env (get-environment-variables)))
...   (if (null? env)
...       #t
...       (and (string? (caar env))
...            (string? (cdar env)))))

==> #t

; get-environment-variable is consistent with get-environment-variables

>>> (let* ((env (get-environment-variables))
...        (path-pair (assoc "PATH" env)))
...   (if path-pair
...       (equal? (cdr path-pair) (get-environment-variable "PATH"))
...       (eq? #f (get-environment-variable "PATH"))))

==> #t

; ==========================================================================
; current-second — current time in seconds
; ==========================================================================

>>> (procedure? current-second)

==> #t

; Returns an inexact real

>>> (inexact? (current-second))

==> #t

>>> (real? (current-second))

==> #t

; current-second is non-decreasing (monotone) over successive calls

>>> (let ((t1 (current-second))
...       (t2 (current-second)))
...   (<= t1 t2))

==> #t

; Value is a reasonable Unix-era timestamp (> 1e9 seconds since epoch)

>>> (> (current-second) 1.0e9)

==> #t

; ==========================================================================
; current-jiffy — current time in jiffies
; ==========================================================================

>>> (procedure? current-jiffy)

==> #t

; Returns an exact integer

>>> (exact? (current-jiffy))

==> #t

>>> (integer? (current-jiffy))

==> #t

; current-jiffy is non-decreasing

>>> (let ((j1 (current-jiffy))
...       (j2 (current-jiffy)))
...   (<= j1 j2))

==> #t

; ==========================================================================
; jiffies-per-second — conversion factor
; ==========================================================================

>>> (procedure? jiffies-per-second)

==> #t

; Returns an exact positive integer

>>> (exact? (jiffies-per-second))

==> #t

>>> (integer? (jiffies-per-second))

==> #t

>>> (positive? (jiffies-per-second))

==> #t

; jiffies-per-second is constant across calls

>>> (= (jiffies-per-second) (jiffies-per-second))

==> #t

; jiffies and current-second are consistent:
; elapsed jiffies / jiffies-per-second ≈ elapsed seconds

>>> (let* ((j1 (current-jiffy))
...        (s1 (current-second))
...        (j2 (current-jiffy))
...        (s2 (current-second))
...        (jps (jiffies-per-second)))
...   ; Both intervals must be non-negative and in rough agreement
...   (and (>= (- j2 j1) 0)
...        (>= (- s2 s1) 0)))

==> #t

; ==========================================================================
; exit — terminate program
; ==========================================================================

; exit is a procedure

>>> (procedure? exit)

==> #t

; We cannot call (exit) or (exit 0) in a compliance test without terminating
; the process. We verify it is a procedure and accepts arguments.

; exit can be passed as a value (it is first-class)

>>> (let ((e exit)) (procedure? e))

==> #t

; ==========================================================================
; emergency-exit — terminate without cleanup
; ==========================================================================

; emergency-exit is a procedure

>>> (procedure? emergency-exit)

==> #t

; emergency-exit is distinct from exit (implementation may share, but it is
; at minimum a valid procedure)

; We cannot call it without terminating. Verify it is callable.

>>> (let ((ee emergency-exit)) (procedure? ee))

==> #t

; ==========================================================================
; load — reads and evaluates a file
; ==========================================================================

>>> (import (scheme load))

>>> (procedure? load)

==> #t

; Create a file with Scheme expressions, load it

>>> (call-with-output-file "6.14-load-test.tmp"
...   (lambda (p)
...     (write '(define loaded-value 123) p)
...     (newline p)
...     (write '(define (loaded-double x) (* x 2)) p)
...     (newline p)))

>>> (load "6.14-load-test.tmp")

>>> loaded-value

==> 123

>>> (loaded-double 21)

==> 42

; load with multiple expressions — all are evaluated

>>> (call-with-output-file "6.14-load-multi.tmp"
...   (lambda (p)
...     (write '(define a 10) p) (newline p)
...     (write '(define b 20) p) (newline p)
...     (write '(define c (+ a b)) p) (newline p)))

>>> (load "6.14-load-multi.tmp")

>>> c

==> 30

>>> (call-with-output-file "6.14-load-env.tmp"
...   (lambda (p) (write '(define loaded-in-env 99) p) (newline p)))
... ; load with an explicit environment-specifier (R7RS 6.14): the file's forms
... ; are evaluated in the given environment; (interaction-environment) is the
... ; mutable global, so the new definition is visible afterwards.

>>> (load "6.14-load-env.tmp" (interaction-environment))

>>> loaded-in-env

==> 99

>>> (delete-file "6.14-load-env.tmp")
... ; load's optional second argument must be an environment specifier (the
... ; check happens before the file is opened, so the filename is irrelevant)

>>> (load "6.14-no-such-file.tmp" 42)

%%% %any-error%

; Cleanup test files

>>> (delete-file "6.14-load-test.tmp")

>>> (delete-file "6.14-load-multi.tmp")

>>> (file-exists? "6.14-load-test.tmp")

==> #f

; load on nonexistent file signals an error

>>> (load "nonexistent-load-file-xyz.scm")

%%% %any-error%

; ==========================================================================
; Integration — timing a computation
; ==========================================================================

>>> (let* ((start (current-jiffy))
...        (result (apply + (make-list 1000 1)))
...        (elapsed (- (current-jiffy) start))
...        (jps (jiffies-per-second)))
...   (and (= result 1000)
...        (>= elapsed 0)
...        (exact? elapsed)))

==> #t

; Elapsed time in seconds is non-negative

>>> (let* ((s1 (current-second))
...        (_ (apply + (make-list 10000 1)))
...        (s2 (current-second)))
...   (>= (- s2 s1) 0))

==> #t

; ==========================================================================
; ADDITIONAL R7RS COMPLIANCE TESTS
; ==========================================================================

; ===
; features — list of feature identifiers (§6.14, scheme base)
; ===

>>> (procedure? features)

==> #t

; features returns a list

>>> (list? (features))

==> #t

; Every element of the features list is a symbol

>>> (let loop ((fs (features)))
...   (cond ((null? fs) #t)
...         ((symbol? (car fs)) (loop (cdr fs)))
...         (else #f)))

==> #t

; The features list includes r7rs (this is an R7RS implementation)

>>> (and (memq 'r7rs (features)) #t)

==> #t

; A feature known to cond-expand as true must appear in (features);
; r7rs is true under cond-expand and so is listed.

>>> (cond-expand (r7rs (and (memq 'r7rs (features)) #t)) (else #f))

==> #t

; ===
; get-environment-variable — returns #f (not error) for a missing variable
; ===

>>> (eq? #f (get-environment-variable "DEFINITELY_MISSING_VAR_ABC_98765"))

==> #t

; ===
; current-jiffy / jiffies-per-second — exact integers, jps positive
; ===

>>> (and (exact? (current-jiffy)) (integer? (current-jiffy)))

==> #t

>>> (and (exact? (jiffies-per-second)) (positive? (jiffies-per-second)))

==> #t

; ===
; exit / emergency-exit — accept an exit-status argument without being called
; (cannot invoke without terminating; verify first-class + arity-tolerant)
; ===

>>> (procedure? (if #t exit emergency-exit))

==> #t

; Both are bindable and remain procedures

>>> (let ((quit exit) (boom emergency-exit))
...   (and (procedure? quit) (procedure? boom)))

==> #t

