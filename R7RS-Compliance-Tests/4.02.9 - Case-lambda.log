; Section 4.2.9 - Case-lambda
;
; (case-lambda (<formals> <body>) ...)
;
; Returns a procedure that dispatches on the number of arguments supplied.
; Each clause has a <formals> list (same syntax as lambda formals) and a body.
; The first clause whose formals match the argument count is used.
; If no clause matches, it is an error.
;
; <formals> forms:
;   (<x> ...)     — exact arity match
;   (<x> ... . r) — minimum arity, rest args collected into r
;   r             — variadic: all args collected into r (matches any count)

; ==========================================================================
; case-lambda — produces a procedure
; ==========================================================================

>>> (procedure? (case-lambda))

==> #t

>>> (procedure? (case-lambda ((x) x)))

==> #t

>>> (procedure? (case-lambda (() 0) ((x) x) ((x y) (+ x y))))

==> #t

; ==========================================================================
; case-lambda — single clause, exact arity
; ==========================================================================

>>> (define f (case-lambda ((x) (* x x))))

>>> (f 5)

==> 25

>>> (define g (case-lambda ((x y) (+ x y))))

>>> (g 3 4)

==> 7

>>> (define h (case-lambda (() 42)))

>>> (h)

==> 42

; ==========================================================================
; case-lambda — dispatch on argument count
; ==========================================================================

>>> (define multi
...   (case-lambda
...     (()        'zero)
...     ((x)       (list 'one x))
...     ((x y)     (list 'two x y))
...     ((x y z)   (list 'three x y z))))

>>> (multi)

==> zero

>>> (multi 1)

==> (one 1)

>>> (multi 1 2)

==> (two 1 2)

>>> (multi 1 2 3)

==> (three 1 2 3)

; ==========================================================================
; case-lambda — first matching clause wins
; ==========================================================================

>>> (define first-match
...   (case-lambda
...     ((x) (list 'first x))
...     ((x) (list 'second x))))

>>> (first-match 99)

==> (first 99)

; ==========================================================================
; case-lambda — rest parameter clause (minimum arity)
; ==========================================================================

>>> (define at-least-one
...   (case-lambda
...     ((x . rest) (list x rest))))

>>> (at-least-one 1)

==> (1 ())

>>> (at-least-one 1 2 3)

==> (1 (2 3))

>>> (define at-least-two
...   (case-lambda
...     ((x y . rest) (list x y rest))))

>>> (at-least-two 1 2)

==> (1 2 ())

>>> (at-least-two 1 2 3 4)

==> (1 2 (3 4))

; ==========================================================================
; case-lambda — variadic clause (sole rest parameter)
; ==========================================================================

>>> (define any-args
...   (case-lambda
...     (args (list 'all args))))

>>> (any-args)

==> (all ())

>>> (any-args 1 2 3)

==> (all (1 2 3))

; ==========================================================================
; case-lambda — mixing exact and variadic clauses
; ==========================================================================

>>> (define mixed
...   (case-lambda
...     (()       'none)
...     ((x)      (list 'one x))
...     ((x . r)  (list 'many x r))))

>>> (mixed)

==> none

>>> (mixed 1)

==> (one 1)

>>> (mixed 1 2)

==> (many 1 (2))

>>> (mixed 1 2 3 4)

==> (many 1 (2 3 4))

; ==========================================================================
; case-lambda — optional argument idiom
; ==========================================================================

>>> (define (make-greeting)
...   (case-lambda
...     (()        "Hello, world!")
...     ((name)    (string-append "Hello, " name "!"))
...     ((greeting name) (string-append greeting ", " name "!"))))

>>> (define greet (make-greeting))

>>> (greet)

==> "Hello, world!"

>>> (greet "Alice")

==> "Hello, Alice!"

>>> (greet "Hi" "Bob")

==> "Hi, Bob!"

; ==========================================================================
; case-lambda — default argument idiom
; ==========================================================================

>>> (define add
...   (case-lambda
...     ((x)   (+ x 1))
...     ((x y) (+ x y))))

>>> (add 5)

==> 6

>>> (add 5 10)

==> 15

; ==========================================================================
; case-lambda — body is a sequence; last value returned
; ==========================================================================

>>> (define seq-cl
...   (case-lambda
...     ((x) (define doubled (* x 2))
...           (+ doubled 1))))

>>> (seq-cl 5)

==> 11

>>> (define multi-body
...   (case-lambda
...     ((x y)
...      (define sum (+ x y))
...      (define product (* x y))
...      (list sum product))))

>>> (multi-body 3 4)

==> (7 12)

; ==========================================================================
; case-lambda — closures
; ==========================================================================

>>> (define (make-adder-or-multiplier)
...   (define factor 10)
...   (case-lambda
...     ((x)   (+ x factor))
...     ((x y) (* x y factor))))

>>> (define op (make-adder-or-multiplier))

>>> (op 5)

==> 15

>>> (op 2 3)

==> 60

; ==========================================================================
; case-lambda — recursive use
; ==========================================================================

>>> (define my-length
...   (case-lambda
...     ((lst)        (my-length lst 0))
...     ((lst acc)    (if (null? lst)
...                       acc
...                       (my-length (cdr lst) (+ acc 1))))))

>>> (my-length '(a b c d e))

==> 5

>>> (my-length '())

==> 0

>>> (my-length '(1 2 3) 10)

==> 13

; ==========================================================================
; case-lambda — used as argument (higher-order)
; ==========================================================================

>>> (define (apply-with-one-or-two f)
...   (list (f 1) (f 1 2)))

>>> (apply-with-one-or-two
...   (case-lambda
...     ((x)   (* x 10))
...     ((x y) (+ x y))))

==> (10 3)

; ==========================================================================
; case-lambda — tail position in body
; ==========================================================================

>>> (define (cl-tail n)
...   (define counter
...     (case-lambda
...       ((i) (if (= i 0) 'done (counter (- i 1))))))
...   (counter n))

>>> (cl-tail 1000000)

==> done

; ==========================================================================
; case-lambda — zero clauses (no valid arity, any call is an error)
; ==========================================================================

>>> (define no-clauses (case-lambda))

>>> (no-clauses)

%%% %any-error%

>>> (no-clauses 1)

%%% %any-error%

; ==========================================================================
; Error: no matching clause
; ==========================================================================

>>> (define exact-two
...   (case-lambda
...     ((x y) (+ x y))))

>>> (exact-two 1)

%%% %any-error%

>>> (exact-two 1 2 3)

%%% %any-error%

>>> (exact-two)

%%% %any-error%

>>> (define exact-zero
...   (case-lambda
...     (() 'nothing)))

>>> (exact-zero 1)

%%% %any-error%

; ==========================================================================
; case-lambda — formals shadow outer bindings (same as lambda)
; ==========================================================================

>>> (define shadow-val 100)

>>> (define shadow-cl
...   (case-lambda
...     ((shadow-val) shadow-val)))

>>> (shadow-cl 7)

==> 7

>>> shadow-val

==> 100

; ==========================================================================
; case-lambda — each clause has independent bindings
; ==========================================================================

>>> (define independent
...   (case-lambda
...     ((a)      (list 'one-arg a))
...     ((a b)    (list 'two-args a b))
...     ((a b c)  (list 'three-args a b c))))

>>> (independent 'x)

==> (one-arg x)

>>> (independent 'x 'y)

==> (two-args x y)

>>> (independent 'x 'y 'z)

==> (three-args x y z)

; ==========================================================================
; case-lambda — rest clause as final catch-all
; ==========================================================================

>>> (define with-catch-all
...   (case-lambda
...     ((x)     (list 'one x))
...     ((x y)   (list 'two x y))
...     (rest    (list 'many (length rest) rest))))

>>> (with-catch-all 1)

==> (one 1)

>>> (with-catch-all 1 2)

==> (two 1 2)

>>> (with-catch-all 1 2 3)

==> (many 3 (1 2 3))

>>> (with-catch-all)

==> (many 0 ())

>>> (with-catch-all 1 2 3 4 5)

==> (many 5 (1 2 3 4 5))

