; Section 4.2.2 - Binding Constructs
;
; (let ((<var> <init>) ...) <body>)
;   All <init>s evaluated in current env (left-to-right unspecified order),
;   then bound simultaneously.  Body evaluated with new bindings.
;
; (let* ((<var> <init>) ...) <body>)
;   Bindings created sequentially; each <init> may reference prior vars.
;
; (letrec ((<var> <init>) ...) <body>)
;   All <var>s bound first (to unspecified values), then <init>s evaluated;
;   each init may reference any var but the values are unspecified until
;   the inits complete.  Intended for mutually recursive procedures.
;
; (letrec* ((<var> <init>) ...) <body>)
;   Like letrec but inits evaluated left-to-right; each init may reference
;   variables bound by earlier bindings in the same letrec*.
;
; (let <name> ((<var> <init>) ...) <body>)
;   Named let: binds <name> to a procedure for recursion.
;
; (let-values (((<formals>) <init>) ...) <body>)
;   Like let but each <init> produces multiple values matched by <formals>.
;
; (let*-values (((<formals>) <init>) ...) <body>)
;   Like let* but each <init> produces multiple values.

; ==========================================================================
; let — basic
; ==========================================================================

>>> (let ((x 1)) x)

==> 1

>>> (let ((x 1) (y 2)) (+ x y))

==> 3

>>> (let ((x 10) (y 20) (z 30)) (+ x y z))

==> 60

; ==========================================================================
; let — body is a sequence; last expression returned
; ==========================================================================

>>> (let ((x 5))
...   (* x 2)
...   (+ x 1)
...   x)

==> 5

>>> (let ((x 3))
...   (define y (* x 2))
...   (+ x y))

==> 9

; ==========================================================================
; let — init expressions evaluated in current (outer) environment
; ==========================================================================

; x in outer scope should not be visible to the inits of the let

>>> (define x 100)

>>> (let ((x 1) (y x))
...   (list x y))

==> (1 100)

; Both inits see the outer x=100, not the let's x=1

>>> (let ((a 1) (b (+ 1 1)))
...   (list a b))

==> (1 2)

; ==========================================================================
; let — bindings shadow outer variables
; ==========================================================================

>>> (define outer 42)

>>> (let ((outer 0))
...   outer)

==> 0

>>> outer

==> 42

; ==========================================================================
; let — zero bindings
; ==========================================================================

>>> (let () 42)

==> 42

>>> (let () (+ 1 2))

==> 3

; ==========================================================================
; let — closures over let bindings
; ==========================================================================

>>> (define get-x
...   (let ((x 7))
...     (lambda () x)))

>>> (get-x)

==> 7

; ==========================================================================
; let — body may have internal definitions
; ==========================================================================

>>> (let ((x 5))
...   (define doubled (* x 2))
...   doubled)

==> 10

; ==========================================================================
; let* — sequential binding
; ==========================================================================

>>> (let* ((x 1) (y (+ x 1))) (+ x y))

==> 3

>>> (let* ((a 2) (b (* a 3)) (c (+ a b))) c)

==> 8

>>> (let* ((x 10) (x (* x 2)) (x (+ x 1))) x)

==> 21

; ==========================================================================
; let* — each binding sees all prior bindings
; ==========================================================================

>>> (let* ((x 1)
...        (y (+ x 1))
...        (z (+ x y)))
...   (list x y z))

==> (1 2 3)

; ==========================================================================
; let* — zero bindings
; ==========================================================================

>>> (let* () 99)

==> 99

; ==========================================================================
; let* — shadowing
; ==========================================================================

>>> (define v 100)

>>> (let* ((v 1) (w v))
...   (list v w))

==> (1 1)

; ==========================================================================
; letrec — mutual recursion
; ==========================================================================

>>> (letrec ((even? (lambda (n)
...                   (if (= n 0) #t (odd? (- n 1)))))
...           (odd?  (lambda (n)
...                   (if (= n 0) #f (even? (- n 1))))))
...   (list (even? 4) (odd? 3) (even? 7)))

==> (#t #t #f)

; ==========================================================================
; letrec — self-recursion
; ==========================================================================

>>> (letrec ((fact (lambda (n)
...                  (if (= n 0) 1 (* n (fact (- n 1)))))))
...   (fact 6))

==> 720

; ==========================================================================
; letrec — all variables in scope for all inits (but values unspecified
; during init evaluation — safe only when inits are lambdas)
; ==========================================================================

>>> (letrec ((x 1)
...           (y 2))
...   (+ x y))

==> 3

; ==========================================================================
; letrec — zero bindings
; ==========================================================================

>>> (letrec () 55)

==> 55

; ==========================================================================
; letrec* — left-to-right, each init may use previous values
; ==========================================================================

>>> (letrec* ((x 1) (y (+ x 1))) (+ x y))

==> 3

>>> (letrec* ((a 2)
...            (b (* a 3))
...            (c (+ a b)))
...   (list a b c))

==> (2 6 8)

; ==========================================================================
; letrec* — can reference earlier binding values (unlike letrec)
; ==========================================================================

>>> (letrec* ((x 10)
...            (y (* x 2)))
...   y)

==> 20

; ==========================================================================
; letrec* — mutual recursion still works (via lambda deferral)
; ==========================================================================

>>> (letrec* ((even? (lambda (n)
...                    (if (= n 0) #t (odd? (- n 1)))))
...            (odd?  (lambda (n)
...                    (if (= n 0) #f (even? (- n 1))))))
...   (even? 10))

==> #t

; ==========================================================================
; Named let — basic iteration pattern
; ==========================================================================

>>> (let loop ((i 0) (acc 0))
...   (if (= i 5)
...       acc
...       (loop (+ i 1) (+ acc i))))

==> 10

; ==========================================================================
; Named let — factorial
; ==========================================================================

>>> (let fact ((n 6) (acc 1))
...   (if (= n 0)
...       acc
...       (fact (- n 1) (* acc n))))

==> 720

; ==========================================================================
; Named let — list reversal
; ==========================================================================

>>> (let rev ((lst '(1 2 3 4 5)) (acc '()))
...   (if (null? lst)
...       acc
...       (rev (cdr lst) (cons (car lst) acc))))

==> (5 4 3 2 1)

; ==========================================================================
; Named let — name bound only in body (not in inits)
; ==========================================================================

>>> (define loop-count 0)

>>> (let go ((n 3))
...   (if (= n 0)
...       loop-count
...       (begin
...         (set! loop-count (+ loop-count 1))
...         (go (- n 1)))))

==> 3

; ==========================================================================
; Named let — tail recursive (TCO required)
; ==========================================================================

>>> (let loop ((i 0))
...   (if (= i 1000000)
...       i
...       (loop (+ i 1))))

==> 1000000

; ==========================================================================
; Named let — zero initial bindings
; ==========================================================================

>>> (let go ()
...   42)

==> 42

; ==========================================================================
; let-values — basic single binding
; ==========================================================================

>>> (let-values (((a b) (values 1 2)))
...   (+ a b))

==> 3

>>> (let-values (((x y z) (values 10 20 30)))
...   (list x y z))

==> (10 20 30)

; ==========================================================================
; let-values — rest argument in formals
; ==========================================================================

>>> (let-values (((a . rest) (values 1 2 3)))
...   (list a rest))

==> (1 (2 3))

; ==========================================================================
; let-values — sole rest (all values collected)
; ==========================================================================

>>> (let-values ((all (values 1 2 3)))
...   all)

==> (1 2 3)

; ==========================================================================
; let-values — multiple clauses (inits evaluated in current env)
; ==========================================================================

>>> (let-values (((a b) (values 1 2))
...              ((c d) (values 3 4)))
...   (list a b c d))

==> (1 2 3 4)

; ==========================================================================
; let-values — zero values matched by empty formals
; ==========================================================================

>>> (let-values ((() (values)))
...   'ok)

==> ok

; ==========================================================================
; let-values — single value
; ==========================================================================

>>> (let-values (((x) (values 42)))
...   x)

==> 42

; ==========================================================================
; let-values — inits see outer env, not each other's bindings
; ==========================================================================

>>> (define outer-a 99)

>>> (let-values (((a) (values 1))
...              ((b) (values outer-a)))
...   (list a b))

==> (1 99)

; ==========================================================================
; let*-values — sequential binding, each init sees prior bindings
; ==========================================================================

>>> (let*-values (((a b) (values 1 2))
...               ((c)   (values (+ a b))))
...   c)

==> 3

>>> (let*-values (((x y) (values 3 4))
...               ((z)   (values (* x y)))
...               ((w)   (values (+ x y z))))
...   (list x y z w))

==> (3 4 12 19)

; ==========================================================================
; let*-values — rest in later binding uses prior values
; ==========================================================================

>>> (let*-values (((a) (values 10))
...               ((b . rest) (values a (+ a 1) (+ a 2))))
...   (list a b rest))

==> (10 10 (11 12))

; ==========================================================================
; let*-values — zero clauses
; ==========================================================================

>>> (let*-values () 'done)

==> done

; ==========================================================================
; Nesting: let inside let*
; ==========================================================================

>>> (let* ((x 1)
...         (y (let ((z (+ x 1))) (* z 2))))
...   (list x y))

==> (1 4)

; ==========================================================================
; Nesting: letrec inside let
; ==========================================================================

>>> (let ((n 5))
...   (letrec ((fact (lambda (k)
...                    (if (= k 0) 1 (* k (fact (- k 1)))))))
...     (fact n)))

==> 120

; ==========================================================================
; Nesting: named let inside letrec*
; ==========================================================================

>>> (letrec* ((sum-to (lambda (n)
...                     (let loop ((i 0) (acc 0))
...                       (if (> i n)
...                           acc
...                           (loop (+ i 1) (+ acc i)))))))
...   (sum-to 10))

==> 55

; ==========================================================================
; let — tail position in body
; ==========================================================================

>>> (define (let-tail n)
...   (let ((i n))
...     (if (= i 0) 'done (let-tail (- i 1)))))

>>> (let-tail 1000000)

==> done

; ==========================================================================
; let* — tail position
; ==========================================================================

>>> (define (let*-tail n)
...   (let* ((i n) (j i))
...     (if (= j 0) 'done (let*-tail (- j 1)))))

>>> (let*-tail 1000000)

==> done

; ==========================================================================
; letrec — tail position
; ==========================================================================

>>> (letrec ((count (lambda (n)
...                   (if (= n 0) 'done (count (- n 1))))))
...   (count 1000000))

==> done

; ==========================================================================
; letrec* — tail position
; ==========================================================================

>>> (letrec* ((count (lambda (n)
...                    (if (= n 0) 'done (count (- n 1))))))
...   (count 1000000))

==> done


; ==========================================================================
; ADDITIONAL R7RS COMPLIANCE TESTS
; ==========================================================================

; === let: R7RS spec example — inner z init sees outer x,y (not inner x) ===
; (R7RS 4.2.2: "(let ((x 2) (y 3)) (let ((x 7) (z (+ x y))) (* z x))) => 35")

>>> (let ((x 2) (y 3))
...   (let ((x 7) (z (+ x y)))
...     (* z x)))

==> 35

; === let*: R7RS spec example — z init sees the let*-rebound x=7 ===
; (R7RS 4.2.2: "(let ((x 2) (y 3)) (let* ((x 7) (z (+ x y))) (* z x))) => 70")

>>> (let ((x 2) (y 3))
...   (let* ((x 7) (z (+ x y)))
...     (* z x)))

==> 70

; === letrec*: R7RS spec example — non-lambda inits referencing earlier procs ===
; (R7RS 4.2.2: p,q mutually recursive, x=(p 5), y=x => 5)

>>> (letrec* ((p (lambda (x) (+ 1 (q (- x 1)))))
...           (q (lambda (y) (if (zero? y) 0 (+ 1 (p (- y 1))))))
...           (x (p 5))
...           (y x))
...   y)

==> 5

; === let-values: R7RS spec example with exact-integer-sqrt ===
; (R7RS 4.2.2: "(let-values (((root rem) (exact-integer-sqrt 32))) (* root rem)) => 35")

>>> (let-values (((root rem) (exact-integer-sqrt 32)))
...   (* root rem))

==> 35

; === let*-values: R7RS spec example — second init sees first set's bindings ===
; (R7RS 4.2.2: swap idiom yields (x y x y))

>>> (let ((a 'a) (b 'b) (x 'x) (y 'y))
...   (let*-values (((a b) (values x y))
...                 ((x y) (values a b)))
...     (list a b x y)))

==> (x y x y)

; === let: it is an error for a variable to appear more than once ===
; (R7RS 4.2.2: "It is an error for a variable to appear more than once
; in the list of variables being bound.")

>>> (let ((x 1) (x 2)) x)

%%% %any-error%

; === letrec: duplicate bound variable is an error ===

>>> (letrec ((x 1) (x 2)) x)

%%% %any-error%

; === letrec*: duplicate bound variable is an error ===

>>> (letrec* ((x 1) (x 2)) x)

%%% %any-error%

; === let-values: it is an error for a variable to appear more than once
; in the set of formals ===

>>> (let-values (((a a) (values 1 2))) a)

%%% %any-error%

>>> (let-values (((a b) (values 1 2 3))) (list a b))
... ; R7RS 4.2.2: "it is an error if the formals do not match the number of
... ; values" -- undefined behavior, so a conforming implementation MAY signal
... ; or MAY proceed; %optional-error% accepts either outcome.

%%% %optional-error%

