; Section 5.6 - Libraries
;
; (define-library <library-name> <library-declaration> ...)
;
; <library-name> is a list of identifiers and/or exact non-negative integers:
;   (scheme base), (my utils v2), (srfi 1), etc.
;
; Library declarations:
;   (export <export-spec> ...)
;     <export-spec> is <identifier> or (rename <internal> <external>)
;   (import <import-set> ...)
;     Same import-set forms as top-level import.
;   (begin <command-or-definition> ...)
;     Code for the library body.
;   (include <filename> ...)
;     Include source files into the library body.
;   (include-ci <filename> ...)
;     Like include but with case folding.
;   (include-library-declarations <filename> ...)
;     Include library declaration forms (export/import/begin) from a file.
;   (cond-expand <ce-clause> ...)
;     Conditional inclusion of declarations based on features.
;
; Note: The test runner must add the test directory to the library search
; path so that (test math), (test strings), etc. resolve to the .sld files
; alongside this test log.
;
; Auxiliary library files used by these tests.  They follow the standard
; R7RS library-name -> path convention, so (test math) resolves to
; test/math.sld on the search path (the test directory), etc.:
;   test/math.sld    — (test math):    square, cube, sum-of-squares
;   test/strings.sld — (test strings): string-join, string-repeat
;   test/user.sld    — (test user):    hypotenuse, labeled-square
;   test/rename.sld  — (test rename):  public-add, public-mul, version
;   test/syntax.sld  — (test syntax):  my-when, my-swap!

; ==========================================================================
; import from a user-defined library
; ==========================================================================

>>> (import (test math))

>>> (square 5)

==> 25

>>> (cube 3)

==> 27

>>> (sum-of-squares 3 4)

==> 25

; ==========================================================================
; Exported names are procedures
; ==========================================================================

>>> (procedure? square)

==> #t

>>> (procedure? cube)

==> #t

>>> (procedure? sum-of-squares)

==> #t

; ==========================================================================
; Non-exported names from library are not accessible
; ==========================================================================

; (test math) does not export any name beginning with 'internal-'.
; The library's internal bindings are not visible outside.

; ==========================================================================
; Library importing another library — (test user) uses (test math)
; ==========================================================================

>>> (import (test user))

>>> (< (abs (- (hypotenuse 3.0 4.0) 5.0)) 1e-10)

==> #t

>>> (labeled-square 7)

==> (square-of 7 = 49)

; hypotenuse uses sum-of-squares from (test math), which was imported
; by (test user) — but sum-of-squares is not re-exported by (test user).

>>> (procedure? hypotenuse)

==> #t

>>> (procedure? labeled-square)

==> #t

; ==========================================================================
; Library with string utilities
; ==========================================================================

>>> (import (test strings))

>>> (string-join '("hello" "world") " ")

==> "hello world"

>>> (string-join '("a" "b" "c") ", ")

==> "a, b, c"

>>> (string-join '() "-")

==> ""

>>> (string-join '("only") "-")

==> "only"

>>> (string-repeat "ab" 3)

==> "ababab"

>>> (string-repeat "x" 0)

==> ""

>>> (string-repeat "!" 5)

==> "!!!!!"

; ==========================================================================
; Export rename — internal name differs from exported name
; ==========================================================================

>>> (import (test rename))
... 
... ; The library exports internal-add as public-add, internal-mul as public-mul.

>>> (public-add 3 4)

==> 7

>>> (public-mul 6 7)

==> 42

>>> version

==> "1.0"

; The internal names are not accessible

>>> (procedure? public-add)

==> #t

>>> (procedure? public-mul)

==> #t

; ==========================================================================
; Library exporting syntax (macros)
; ==========================================================================

>>> (import (test syntax))

>>> (my-when #t 'fired)

==> fired

>>> (my-when #f 'not-fired)
... 
... ; unspecified — no error

>>> (define sw-x 1)

>>> (define sw-y 2)

>>> (my-swap! sw-x sw-y)

>>> (list sw-x sw-y)

==> (2 1)

; ==========================================================================
; Import modifiers applied to user libraries
; ==========================================================================

; prefix on user library
>>> (import (prefix (test math) math:))

>>> (math:square 4)

==> 16

>>> (math:cube 2)

==> 8

; only from user library
>>> (import (only (test math) square))

>>> (square 9)

==> 81

; rename from user library
>>> (import (rename (test math) (square sq) (cube cb)))

>>> (sq 5)

==> 25

>>> (cb 3)

==> 27

; ==========================================================================
; Multiple imports in one import declaration (user and standard)
; ==========================================================================

>>> (import (test math) (scheme write))

>>> (square 6)

==> 36

>>> (procedure? write)

==> #t

; ==========================================================================
; define-library at the top level (inline)
; ==========================================================================

; Some R7RS implementations allow define-library at the REPL.
; We test the form when supported.

>>> (define-library (test inline)
...   (export double triple)
...   (import (scheme base))
...   (begin
...     (define (double x) (* x 2))
...     (define (triple x) (* x 3))))

>>> (import (test inline))

>>> (double 5)

==> 10

>>> (triple 4)

==> 12

; ==========================================================================
; define-library — begin declaration
; ==========================================================================

; The begin declaration splices definitions into the library body.
; Multiple begin declarations are allowed and concatenated.

>>> (define-library (test multi-begin)
...   (export val1 val2 combined)
...   (import (scheme base))
...   (begin
...     (define val1 10))
...   (begin
...     (define val2 20))
...   (begin
...     (define combined (+ val1 val2))))

>>> (import (test multi-begin))

>>> val1

==> 10

>>> val2

==> 20

>>> combined

==> 30

; ==========================================================================
; define-library — export list controls visibility
; ==========================================================================

>>> (define-library (test private)
...   (export public-val)
...   (import (scheme base))
...   (begin
...     (define private-val 99)
...     (define public-val (* private-val 2))))

>>> (import (test private))

>>> public-val

==> 198

; private-val is not exported — accessing it is an error

>>> private-val

%%% %any-error%

; ==========================================================================
; define-library — library importing standard libraries
; ==========================================================================

>>> (define-library (test uses-std)
...   (export even-count odd-count)
...   (import (scheme base))
...   (begin
...     (define (even-count lst)
...       (length (filter even? lst)))
...     (define (odd-count lst)
...       (length (filter odd? lst)))))

>>> (import (test uses-std))

>>> (even-count '(1 2 3 4 5 6))

==> 3

>>> (odd-count '(1 2 3 4 5 6))

==> 3

; ==========================================================================
; define-library — cond-expand in library declarations
; ==========================================================================

; cond-expand selects declarations based on implementation features.
; We test that cond-expand with (else ...) always applies.

>>> (define-library (test cond-lib)
...   (export feature-name)
...   (import (scheme base))
...   (cond-expand
...     (r7rs
...      (begin (define feature-name 'r7rs)))
...     (else
...      (begin (define feature-name 'other)))))

>>> (import (test cond-lib))

>>> (symbol? feature-name)

==> #t

; ==========================================================================
; define-library — library name with integers
; ==========================================================================

>>> (define-library (test utils 2)
...   (export double2)
...   (import (scheme base))
...   (begin
...     (define (double2 x) (* x 2))))

>>> (import (test utils 2))

>>> (double2 21)

==> 42

; ==========================================================================
; define-library — re-importing a library is harmless
; ==========================================================================

>>> (import (test math))

>>> (square 7)

==> 49

>>> (import (test math))

>>> (square 7)

==> 49

; ==========================================================================
; Error: importing non-existent library
; ==========================================================================

>>> (import (test nonexistent-xyz))

%%% %any-error%

; ==========================================================================
; Error: importing identifier not exported by library
; ==========================================================================

>>> (import (only (test math) nonexistent-proc))

%%% %any-error%

; ==========================================================================
; Library name structure — identifiers and non-negative integers
; ==========================================================================

; Library names are lists; each element is a symbol or exact non-negative integer.

>>> (define-library (my lib 1 0)
...   (export lib-version)
...   (import (scheme base))
...   (begin (define lib-version '(1 0))))

>>> (import (my lib 1 0))

>>> lib-version

==> (1 0)

; ==========================================================================
; ADDITIONAL R7RS COMPLIANCE TESTS
; ==========================================================================

; === define-library — export with rename (internal name differs from exported)
; (export (rename <internal> <external>) ...) exposes internal-foo as foo.

>>> (define-library (test exp-rename)
...   (export (rename internal-area area)
...           (rename internal-perimeter perimeter))
...   (import (scheme base))
...   (begin
...     (define (internal-area w h) (* w h))
...     (define (internal-perimeter w h) (* 2 (+ w h)))))

>>> (import (test exp-rename))

>>> (area 3 4)

==> 12

>>> (perimeter 3 4)

==> 14

; The internal names are not exported.
>>> internal-area

%%% %any-error%

; === define-library — a library may export some names plainly and others renamed

>>> (define-library (test mixed-export)
...   (export plain-val (rename hidden-val shown-val))
...   (import (scheme base))
...   (begin
...     (define plain-val 1)
...     (define hidden-val 2)))

>>> (import (test mixed-export))

>>> plain-val

==> 1

>>> shown-val

==> 2

>>> hidden-val

%%% %any-error%

; === define-library — re-export: a library re-exports a name it imported
; (test reexporter) imports (test math) and re-exports square.

>>> (define-library (test reexporter)
...   (export square triple-square)
...   (import (scheme base) (test math))
...   (begin
...     (define (triple-square x) (* 3 (square x)))))

>>> (import (test reexporter))

>>> (square 4)

==> 16

>>> (triple-square 2)

==> 12

; === define-library — exporting a macro defined with define-syntax inline

>>> (define-library (test macro-lib)
...   (export swap-pair)
...   (import (scheme base))
...   (begin
...     (define-syntax swap-pair
...       (syntax-rules ()
...         ((swap-pair (a b)) (list b a))))))

>>> (import (test macro-lib))

>>> (swap-pair (1 2))

==> (2 1)

; === define-library — multiple import declarations in one library

>>> (define-library (test multi-import)
...   (export upper-first)
...   (import (scheme base))
...   (import (scheme char))
...   (begin
...     (define (upper-first ch) (char-upcase ch))))

>>> (import (test multi-import))

>>> (upper-first #\a)

==> #\A

; === define-library — cond-expand selecting on a library being available
; (cond-expand ((library (scheme base)) ...) (else ...)): the base library is
; always present, so the first clause applies.

>>> (define-library (test ce-lib-avail)
...   (export ce-result)
...   (import (scheme base))
...   (cond-expand
...     ((library (scheme base))
...      (begin (define ce-result 'has-base)))
...     (else
...      (begin (define ce-result 'no-base)))))

>>> (import (test ce-lib-avail))

>>> ce-result

==> has-base

; === define-library — cond-expand with 'and'/'or' feature combinations
; (and r7rs) is true on an R7RS implementation; (or ...) with else fallback.

>>> (define-library (test ce-combo)
...   (export combo-val)
...   (import (scheme base))
...   (cond-expand
...     ((or some-unlikely-feature r7rs)
...      (begin (define combo-val 'ok)))
...     (else
...      (begin (define combo-val 'fallback)))))

>>> (import (test ce-combo))

>>> (symbol? combo-val)

==> #t

; === define-library — empty export list is allowed (library with no exports)
; Importing it adds no names but is not an error.

>>> (define-library (test no-exports)
...   (export)
...   (import (scheme base))
...   (begin
...     (define internal-only 123)))

>>> (import (test no-exports))
...
... ; No error; internal-only is still not visible.

>>> internal-only

%%% %any-error%

; === Error: define-library export of a name that is not defined in the body

>>> (define-library (test bad-export)
...   (export not-defined-anywhere)
...   (import (scheme base))
...   (begin
...     (define something-else 1)))

%%% %any-error%

