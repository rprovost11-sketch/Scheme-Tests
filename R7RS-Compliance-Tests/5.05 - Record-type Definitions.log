; Section 5.5 - Record-type Definitions
;
; (define-record-type <name>
;   (<constructor> <field-name> ...)
;   <predicate>
;   (<field-name> <accessor> [<modifier>]) ...)
;
; Creates a new disjoint type with:
;   <name>        — the type name (for documentation/printing)
;   <constructor> — a procedure that takes one value per field and
;                   returns a new instance
;   <predicate>   — returns #t for instances of this type, #f otherwise
;   <accessor>    — retrieves the value of a field
;   <modifier>    — (optional) sets the value of a mutable field
;
; Fields listed in the constructor clause without a modifier are immutable.
; The order of fields in the constructor matches the order in the
; constructor clause, not the field clause order.

; ==========================================================================
; Basic record type — single field, immutable
; ==========================================================================

>>> (define-record-type <point1d>
...   (make-point1d x)
...   point1d?
...   (x point1d-x))

>>> (define p (make-point1d 42))

>>> (point1d? p)

==> #t

>>> (point1d-x p)

==> 42

; ==========================================================================
; Predicate — returns #f for non-instances
; ==========================================================================

>>> (point1d? 42)

==> #f

>>> (point1d? '())

==> #f

>>> (point1d? #t)

==> #f

>>> (point1d? "hello")

==> #f

>>> (point1d? '(make-point1d 1))

==> #f

; ==========================================================================
; Multiple fields — immutable
; ==========================================================================

>>> (define-record-type <point>
...   (make-point x y)
...   point?
...   (x point-x)
...   (y point-y))

>>> (define origin (make-point 0 0))

>>> (define p1 (make-point 3 4))

>>> (point? origin)

==> #t

>>> (point? p1)

==> #t

>>> (point-x origin)

==> 0

>>> (point-y origin)

==> 0

>>> (point-x p1)

==> 3

>>> (point-y p1)

==> 4

; ==========================================================================
; Multiple fields — mutable (with modifier)
; ==========================================================================

>>> (define-record-type <mpoint>
...   (make-mpoint x y)
...   mpoint?
...   (x mpoint-x set-mpoint-x!)
...   (y mpoint-y set-mpoint-y!))

>>> (define mp (make-mpoint 1 2))

>>> (mpoint-x mp)

==> 1

>>> (mpoint-y mp)

==> 2

>>> (set-mpoint-x! mp 10)

>>> (mpoint-x mp)

==> 10

>>> (set-mpoint-y! mp 20)

>>> (mpoint-y mp)

==> 20

>>> (list (mpoint-x mp) (mpoint-y mp))

==> (10 20)

; ==========================================================================
; Mutable field — mutation affects the same object
; ==========================================================================

>>> (define shared-mp (make-mpoint 0 0))

>>> (define alias shared-mp)

>>> (set-mpoint-x! shared-mp 99)

>>> (mpoint-x alias)

==> 99

; ==========================================================================
; Mix of mutable and immutable fields
; ==========================================================================

>>> (define-record-type <person>
...   (make-person name age)
...   person?
...   (name person-name)
...   (age  person-age set-person-age!))

>>> (define alice (make-person "Alice" 30))

>>> (person-name alice)

==> "Alice"

>>> (person-age alice)

==> 30

; name is immutable — no setter

>>> (person-age alice)

==> 30

>>> (set-person-age! alice 31)

>>> (person-age alice)

==> 31

; name remains unchanged

>>> (person-name alice)

==> "Alice"

; ==========================================================================
; Record type is a new disjoint type
; ==========================================================================

>>> (define-record-type <foo>
...   (make-foo v)
...   foo?
...   (v foo-v))

>>> (define-record-type <bar>
...   (make-bar v)
...   bar?
...   (v bar-v))

>>> (define f (make-foo 1))

>>> (define b (make-bar 1))
... 
... ; Disjoint: foo? and bar? are mutually exclusive

>>> (foo? f)

==> #t

>>> (bar? f)

==> #f

>>> (foo? b)

==> #f

>>> (bar? b)

==> #t

; Records are not pairs, vectors, strings, etc.

>>> (pair? f)

==> #f

>>> (vector? f)

==> #f

>>> (string? f)

==> #f

>>> (procedure? f)

==> #f

>>> (boolean? f)

==> #f

; ==========================================================================
; Record equality
; ==========================================================================

; Two separately constructed records are not eq? even if fields are equal

>>> (define r1 (make-foo 42))

>>> (define r2 (make-foo 42))

>>> (eq? r1 r2)

==> #f

; A record is eq? to itself

>>> (eq? r1 r1)

==> #t

; equal? behavior on records is implementation-defined by R7RS —
; some treat records as eq? only, others do structural comparison.
; We do not require a specific result for (equal? r1 r2) here.

>>> (eq? r1 r1)

==> #t

; ==========================================================================
; Multiple instances are independent
; ==========================================================================

>>> (define pt-a (make-mpoint 1 2))

>>> (define pt-b (make-mpoint 3 4))

>>> (set-mpoint-x! pt-a 99)

>>> (mpoint-x pt-a)

==> 99

>>> (mpoint-x pt-b)

==> 3

; ==========================================================================
; Record with many fields
; ==========================================================================

>>> (define-record-type <rgb>
...   (make-rgb r g b)
...   rgb?
...   (r rgb-r)
...   (g rgb-g)
...   (b rgb-b))

>>> (define red   (make-rgb 255 0 0))

>>> (define green (make-rgb 0 255 0))

>>> (define blue  (make-rgb 0 0 255))

>>> (list (rgb-r red) (rgb-g red) (rgb-b red))

==> (255 0 0)

>>> (list (rgb-r green) (rgb-g green) (rgb-b green))

==> (0 255 0)

>>> (list (rgb-r blue) (rgb-g blue) (rgb-b blue))

==> (0 0 255)

; ==========================================================================
; Record with zero fields
; ==========================================================================

>>> (define-record-type <unit>
...   (make-unit)
...   unit?)

>>> (define u (make-unit))

>>> (unit? u)

==> #t

>>> (unit? '())

==> #f

>>> (eq? u u)

==> #t

; ==========================================================================
; Constructor argument order matches constructor clause, not field clause
; ==========================================================================

>>> (define-record-type <reversed>
...   (make-reversed first second)
...   reversed?
...   (second reversed-second)
...   (first  reversed-first))

>>> (define rv (make-reversed 'uno 'dos))

>>> (reversed-first rv)

==> uno

>>> (reversed-second rv)

==> dos

; ==========================================================================
; Nested records — record containing another record
; ==========================================================================

>>> (define-record-type <segment>
...   (make-segment start end)
...   segment?
...   (start segment-start)
...   (end   segment-end))

>>> (define seg (make-segment (make-point 0 0) (make-point 3 4)))

>>> (point-x (segment-start seg))

==> 0

>>> (point-y (segment-end seg))

==> 4

>>> (point? (segment-start seg))

==> #t

>>> (segment? seg)

==> #t

; ==========================================================================
; Records stored in lists and vectors
; ==========================================================================

>>> (define points (list (make-point 1 2) (make-point 3 4) (make-point 5 6)))

>>> (point-x (car points))

==> 1

>>> (point-y (cadr points))

==> 4

>>> (map point-x points)

==> (1 3 5)

>>> (map point-y points)

==> (2 4 6)

>>> (define point-vec (vector (make-point 0 0) (make-point 1 1)))

>>> (point-x (vector-ref point-vec 1))

==> 1

; ==========================================================================
; Records as procedure arguments and return values
; ==========================================================================

>>> (define (distance pt)
...   (let ((x (point-x pt))
...         (y (point-y pt)))
...     (sqrt (+ (* x x) (* y y)))))

>>> (< (abs (- (distance (make-point 3.0 4.0)) 5.0)) 1e-10)

==> #t

>>> (define (midpoint p1 p2)
...   (make-point (/ (+ (point-x p1) (point-x p2)) 2)
...               (/ (+ (point-y p1) (point-y p2)) 2)))

>>> (define mid (midpoint (make-point 0 0) (make-point 4 6)))

>>> (point-x mid)

==> 2

>>> (point-y mid)

==> 3

; ==========================================================================
; Record predicate used in cond/case dispatch
; ==========================================================================

>>> (define (describe x)
...   (cond ((point? x)   (list 'point (point-x x) (point-y x)))
...         ((person? x)  (list 'person (person-name x)))
...         ((rgb? x)     (list 'color (rgb-r x) (rgb-g x) (rgb-b x)))
...         (else         'unknown)))

>>> (describe (make-point 1 2))

==> (point 1 2)

>>> (describe (make-person "Bob" 25))

==> (person "Bob")

>>> (describe (make-rgb 128 64 32))

==> (color 128 64 32)

>>> (describe 42)

==> unknown

; ==========================================================================
; Error: wrong number of arguments to constructor
; ==========================================================================

>>> (make-point 1)

%%% %any-error%

>>> (make-point 1 2 3)

%%% %any-error%

>>> (make-person "Alice")

%%% %any-error%

>>> (make-unit 1)

%%% %any-error%

; ==========================================================================
; Error: accessor applied to wrong type
; ==========================================================================

>>> (point-x 42)

%%% %any-error%

>>> (point-x (make-foo 1))

%%% %any-error%

>>> (person-name (make-point 0 0))

%%% %any-error%

; ==========================================================================
; Error: modifier applied to wrong type
; ==========================================================================

>>> (set-mpoint-x! 42 1)

%%% %any-error%

>>> (set-mpoint-x! (make-point 1 2) 99)

%%% %any-error%

; ==========================================================================
; Record type — constructor, predicate, accessors are procedures
; ==========================================================================

>>> (procedure? make-point)

==> #t

>>> (procedure? point?)

==> #t

>>> (procedure? point-x)

==> #t

>>> (procedure? point-y)

==> #t

>>> (procedure? make-mpoint)

==> #t

>>> (procedure? set-mpoint-x!)

==> #t

