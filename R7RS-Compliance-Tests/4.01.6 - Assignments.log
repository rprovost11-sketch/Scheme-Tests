; Section 4.1.6 - Assignments
;
; (set! <variable> <expression>)
;
; Evaluates <expression> and stores the result into the location
; denoted by <variable>, which must already be bound.
; Returns an unspecified value.
; It is an error to set! an unbound variable.

; ==========================================================================
; Basic assignment
; ==========================================================================

>>> (define x 1)

>>> (set! x 2)

>>> x

==> 2

; set! can change the type of value stored

>>> (set! x "hello")

>>> x

==> "hello"

>>> (set! x '(1 2 3))

>>> x

==> (1 2 3)

>>> (set! x #t)

>>> x

==> #t

>>> (set! x (lambda (n) (* n n)))

>>> (x 5)

==> 25

; ==========================================================================
; set! returns an unspecified value
; We verify: no error, and the return value is not relied upon
; ==========================================================================

>>> (define y 0)

>>> (define result (set! y 42))

>>> y

==> 42

; result holds an unspecified value — it should not be an error to bind it

>>> (if #t 'ok)

==> ok

; ==========================================================================
; The expression is evaluated before assignment
; ==========================================================================

; Incrementing a variable by its own value

>>> (define n 10)

>>> (set! n (+ n 1))

>>> n

==> 11

>>> (set! n (* n 2))

>>> n

==> 22

; Self-referential: the old value is read before the new value is written

>>> (define a 1)

>>> (define b 2)

>>> (set! a (+ a b))

>>> a

==> 3

>>> b

==> 2

; Swap via temporary

>>> (define p 'left)

>>> (define q 'right)

>>> (define tmp p)

>>> (set! p q)

>>> (set! q tmp)

>>> p

==> right

>>> q

==> left

; ==========================================================================
; set! on a lambda parameter (local binding)
; ==========================================================================

>>> (define (f x)
...   (set! x (* x 2))
...   x)

>>> (f 5)

==> 10

>>> (f 7)

==> 14

; Mutating the parameter does not affect the caller's variable

>>> (define val 100)

>>> (define (mutate-param x) (set! x 999))

>>> (mutate-param val)

>>> val

==> 100

; ==========================================================================
; set! on a variable from an enclosing scope (closure mutation)
; ==========================================================================

>>> (define (make-counter)
...   (define n 0)
...   (lambda ()
...     (set! n (+ n 1))
...     n))

>>> (define counter (make-counter))

>>> (counter)

==> 1

>>> (counter)

==> 2

>>> (counter)

==> 3

; set! in a closure affects the shared binding

>>> (define (make-account balance)
...   (lambda (amount)
...     (set! balance (+ balance amount))
...     balance))

>>> (define acc (make-account 100))

>>> (acc 50)

==> 150

>>> (acc -30)

==> 120

>>> (acc 200)

==> 320

; Multiple closures sharing one set!-able binding

>>> (define shared 0)

>>> (define (inc!) (set! shared (+ shared 1)))

>>> (define (dec!) (set! shared (- shared 1)))

>>> (define (get) shared)

>>> (inc!)

>>> (inc!)

>>> (inc!)

>>> (get)

==> 3

>>> (dec!)

>>> (get)

==> 2

; ==========================================================================
; set! in tail position
; ==========================================================================

>>> (define (count-to n)
...   (define i 0)
...   (define (loop)
...     (if (= i n)
...         i
...         (begin
...           (set! i (+ i 1))
...           (loop))))
...   (loop))

>>> (count-to 1000000)

==> 1000000

; ==========================================================================
; set! on a variable bound by various forms
; ==========================================================================

; Variable bound by let

>>> (let ((z 1))
...   (set! z 99)
...   z)

==> 99

; Variable bound by let*

>>> (let* ((a 1) (b (+ a 1)))
...   (set! a 10)
...   (list a b))

==> (10 2)

; Variable bound by letrec

>>> (letrec ((count 0)
...           (inc! (lambda () (set! count (+ count 1)) count)))
...   (inc!)
...   (inc!)
...   (inc!))

==> 3

; Variable bound by do

>>> (do ((i 0 (+ i 1))
...      (acc 0))
...     ((= i 5) acc)
...   (set! acc (+ acc i)))

==> 10

; ==========================================================================
; Error: set! on an unbound variable
; ==========================================================================

>>> (set! unbound-variable 42)

%%% %any-error%

; R7RS requires set! to error only if the variable is unbound at the point
; of evaluation. Since not-yet-defined is bound before bad-set! is called,
; the set! succeeds. Early-binding compilers may error; interpreters need not.

>>> (define (bad-set!)
...   (set! not-yet-defined 1))

>>> (define not-yet-defined 0)

>>> (bad-set!)

