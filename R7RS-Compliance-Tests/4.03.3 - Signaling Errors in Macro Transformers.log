; Section 4.3.3 - Signaling Errors in Macro Transformers
;
; A macro transformer may signal an error during expansion.
; R7RS specifies that if a syntax-rules pattern has no matching rule,
; it is an error.  Macro transformers implemented via syntax-rules
; may also call (error ...) or use other means to signal errors at
; expand time (implementation-defined mechanism).
;
; The key testable fact is: a macro use with no matching pattern signals
; an error.  The error may be reported at expand time or run time
; (both are conformant), but it must be an error.

; ==========================================================================
; No matching pattern — is an error
; ==========================================================================

; Zero-arg macro called with one arg
>>> (define-syntax zero-arg
...   (syntax-rules ()
...     ((zero-arg) 'ok)))

>>> (zero-arg 1)

%%% %any-error%

; One-arg macro called with zero args
>>> (define-syntax one-arg
...   (syntax-rules ()
...     ((one-arg x) x)))

>>> (one-arg)

%%% %any-error%

>>> (one-arg 1 2)

%%% %any-error%

; Two-arg macro called with one arg
>>> (define-syntax two-arg
...   (syntax-rules ()
...     ((two-arg x y) (+ x y))))

>>> (two-arg 1)

%%% %any-error%

>>> (two-arg 1 2 3)

%%% %any-error%

; ==========================================================================
; No matching pattern — literal mismatch
; ==========================================================================

; Macro with literal 'else' — non-else input that matches no other rule
>>> (define-syntax requires-else
...   (syntax-rules (else)
...     ((requires-else else) 'matched)))

>>> (requires-else else)

==> matched

>>> (requires-else other)

%%% %any-error%

; ==========================================================================
; Error raised explicitly inside a macro transformer
; ==========================================================================

; A transformer may call (error ...) to report a meaningful message.
; R7RS does not mandate the mechanism but permits it.

>>> (define-syntax must-be-positive
...   (syntax-rules ()
...     ((must-be-positive n)
...      (if (> n 0)
...          n
...          (error "must-be-positive: argument must be positive" n)))))
... 
... ; When argument is positive, no error
>>> (must-be-positive 5)

==> 5

; When argument is non-positive, error is raised at run time
>>> (must-be-positive -1)

%%% %any-error%

>>> (must-be-positive 0)

%%% %any-error%

; ==========================================================================
; Macro that checks form structure and signals error
; ==========================================================================

; A macro requiring exactly a list of two-element pairs

>>> (define-syntax check-pairs
...   (syntax-rules ()
...     ((check-pairs ((k v) ...) body)
...      (let ((k v) ...) body))))

>>> (check-pairs ((x 1) (y 2)) (+ x y))

==> 3

; Wrong structure — single element instead of pair
>>> (check-pairs (x) 'body)

%%% %any-error%

; ==========================================================================
; Error in nested macro expansion
; ==========================================================================

>>> (define-syntax outer-err
...   (syntax-rules ()
...     ((outer-err x)
...      (one-arg))))
... 
... ; one-arg defined above requires exactly one argument
... ; Expanding (outer-err 1) expands to (one-arg) which has no match
>>> (outer-err 1)

%%% %any-error%

; ==========================================================================
; guard can catch macro expansion errors that occur at run time
; ==========================================================================

; Some implementations report expansion errors at run time; guard can
; catch those.  This test is implementation-defined but must not hang.

>>> (guard (exn (#t 'caught))
...   (one-arg))

%%% %any-error%

; This test is implementation-defined: an implementation that reports the
; macro mismatch at expand time lets the error propagate past guard (the
; case checked here), while one that defers it to run time would instead
; have guard return 'caught.  Both are conformant; the essential fact is
; that (one-arg) is an error and the evaluator must not hang.

