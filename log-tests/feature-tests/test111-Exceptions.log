;;; ============================================================
;;; test111-Exceptions
;;; The Scheme Programming Language, 4th ed. - Chapter 11
;;; R. Kent Dybvig  (examples used for educational testing)
;;; ============================================================
;;; pyscheme supports R7RS exception handling: raise, raise-continuable,
;;; with-exception-handler, guard, error (R7RS form only).
;;; R6RS condition system (condition?, make-error, make-violation,
;;; make-message-condition, simple-conditions, define-condition-type,
;;; condition-predicate, condition-accessor, etc.) is unsupported.
;;; R6RS error form (error who message ...) is not supported: pyscheme
;;; uses R7RS form (error message obj ...).
;;; ============================================================

;;; ============================================================
;;; 11.1  Raising and Handling Exceptions
;;; ============================================================

;;; condition constructor is R6RS -- unbound in pyscheme

>>> (raise (condition (make-error) (make-message-condition "no go")))
%%% line 1, col 9: unbound variable: condition
%%% (raise (condition (make-error) (make-message-condition "no go")))
%%%         ^

>>> (raise-continuable (condition (make-violation) (make-message-condition "oops")))
%%% line 1, col 21: unbound variable: condition
%%% (raise-continuable (condition (make-violation) (make-message-condition "oops")))
%%%                     ^

;;; call/cc escape from handler: raise aborts (+ (raise 17) 8), k captures result

>>> (list (call/cc (lambda (k) (vector (with-exception-handler (lambda (x) (k (+ x 5))) (lambda () (+ (raise 17) 8)))))))
==> (22)

;;; raise-continuable allows handler to return: 17+5=22, (+ 22 8)=30

>>> (list (vector (with-exception-handler (lambda (x) (+ x 5)) (lambda () (+ (raise-continuable 17) 8)))))
==> (#(30))

;;; R7RS §6.11: handler return from non-continuable raise is an error.
;;; book: violation: non-continuable; pyscheme (strict): uncaught SchemeRaised.

>>> (list (vector (with-exception-handler (lambda (x) (+ x 5)) (lambda () (+ (raise 17) 8)))))
%%% SchemeRaised: #<error-object "exception handler returned" (17)>

;;; R6RS error form (who message ...): pyscheme requires string as first argument

>>> (error 'who "message" 'irritant)
%%% SchemeTypeError: line 1, col 1: error: first argument must be a string
%%% (error 'who "message" 'irritant)
%%% ^

;;; R7RS error form works: (error message obj ...)

>>> (error "message" 'irritant)
%%% SchemeUserError: line 1, col 1: message irritant
%%% (error "message" 'irritant)
%%% ^

;;; assertion-violation, assert, syntax-violation: R6RS -- unbound in pyscheme

>>> (assertion-violation 'who "message" 'irritant)
%%% line 1, col 2: unbound variable: assertion-violation
%%% (assertion-violation 'who "message" 'irritant)
%%%  ^

>>> (assert #t)
%%% line 1, col 2: unbound variable: assert
%%% (assert #t)
%%%  ^

>>> (syntax-violation 'who "message" '(bad form))
%%% line 1, col 2: unbound variable: syntax-violation
%%% (syntax-violation 'who "message" '(bad form))
%%%  ^

;;; try using call/cc: define succeeds; (try thunk) works if thunk doesn't raise

>>> (define (try thunk)
...   (call/cc
...     (lambda (k)
...       (with-exception-handler
...         (lambda (x) (if (error? x) (k #f) (raise x)))
...         thunk))))
==>

>>> (try (lambda () 17))
==> 17

;;; try branches use error? which is R6RS -- unbound; handler itself fails

>>> (try (lambda () (raise (make-error))))
%%% line 5, col 26: unbound variable: error?
%%%         (lambda (x) (if (error? x) (k #f) (raise x)))
%%%                          ^

>>> (try (lambda () (raise (make-violation))))
%%% line 5, col 26: unbound variable: error?
%%%         (lambda (x) (if (error? x) (k #f) (raise x)))
%%%                          ^

;;; complex with-exception-handler using condition, simple-conditions: all R6RS unbound

>>> (with-exception-handler
...   (lambda (x)
...     (raise
...       (apply condition
...         (make-message-condition "oops")
...         (simple-conditions x))))
...   (lambda ()
...     (with-exception-handler
...       (lambda (x) (if (error? x) 'ok (raise x)))
...       (lambda () (raise (make-violation))))))
%%% line 4, col 14: unbound variable: condition
%%%       (apply condition
%%%              ^

;;; guard: basic else clause catches any raised value

>>> (guard (x [else x]) (raise "oops"))
==> "oops"

;;; guard with no matching clause reraises the exception

>>> (guard (x [#f #f]) (raise "oops"))
%%% SchemeRaised: line 1, col 1: "oops"
%%% (guard (x [#f #f]) (raise "oops"))
%%% ^

;;; guard reraises error-object when make-error is unbound

>>> (guard (x [#f #f]) (raise (make-error)))
%%% SchemeRaised: line 1, col 1: #<error-object "unbound variable: make-error">
%%% (guard (x [#f #f]) (raise (make-error)))
%%% ^

;;; try as syntax-rules macro: define succeeds

>>> (define-syntax try
...   (syntax-rules ()
...     [(_ e1 e2 ...) (guard (x [(error? x) #f]) e1 e2 ...)]))
==>

>>> (try 17)
==> 17

;;; try catches error but (error? x) is unbound -- guard clause fails

>>> (try (error "test"))
%%% line 3, col 32: unbound variable: error?
%%%     [(_ e1 e2 ...) (guard (x [(error? x) #f]) e1 e2 ...)]))
%%%                                ^

;;; ============================================================
;;; 11.2  Defining Condition Types
;;; ============================================================

;;; condition?: R6RS -- unbound in pyscheme

>>> (condition? 'stable)
%%% line 1, col 2: unbound variable: condition?
%%% (condition? 'stable)
%%%  ^

>>> (condition? (make-message-condition "oops"))
%%% line 1, col 2: unbound variable: condition?
%%% (condition? (make-message-condition "oops"))
%%%  ^

;;; condition constructor: R6RS -- unbound in pyscheme

>>> (condition)
%%% line 1, col 2: unbound variable: condition
%%% (condition)
%%%  ^

>>> (condition (make-error) (make-message-condition "oops"))
%%% line 1, col 2: unbound variable: condition
%%% (condition (make-error) (make-message-condition "oops"))
%%%  ^

;;; simple-conditions: R6RS -- unbound in pyscheme

>>> (simple-conditions (condition))
%%% line 1, col 2: unbound variable: simple-conditions
%%% (simple-conditions (condition))
%%%  ^

>>> (simple-conditions (make-error))
%%% line 1, col 2: unbound variable: simple-conditions
%%% (simple-conditions (make-error))
%%%  ^

;;; define-condition-type: R6RS -- unbound in pyscheme

>>> (define-condition-type &mistake &condition make-mistake mistake?
...   (type mistake-type))
%%% line 1, col 2: unbound variable: define-condition-type
%%% (define-condition-type &mistake &condition make-mistake mistake?
%%%  ^

;;; mistake?, make-mistake, mistake-type all unbound after failed define-condition-type

>>> (mistake? 'booboo)
%%% line 1, col 2: unbound variable: mistake?
%%% (mistake? 'booboo)
%%%  ^

>>> (define c1 (make-mistake 'spelling))
%%% line 1, col 13: unbound variable: make-mistake
%%% (define c1 (make-mistake 'spelling))
%%%             ^

>>> (define c2 (condition c1 (make-irritants-condition '(eggregius))))
%%% line 1, col 13: unbound variable: condition
%%% (define c2 (condition c1 (make-irritants-condition '(eggregius))))
%%%             ^

>>> (irritants-condition? c2)
%%% line 1, col 2: unbound variable: irritants-condition?
%%% (irritants-condition? c2)
%%%  ^

>>> (condition-irritants c2)
%%% line 1, col 2: unbound variable: condition-irritants
%%% (condition-irritants c2)
%%%  ^

;;; condition-predicate, condition-accessor: R6RS -- unbound in pyscheme

>>> (condition-predicate 'foo)
%%% line 1, col 2: unbound variable: condition-predicate
%%% (condition-predicate 'foo)
%%%  ^

>>> (condition-accessor 'foo car)
%%% line 1, col 2: unbound variable: condition-accessor
%%% (condition-accessor 'foo car)
%%%  ^

