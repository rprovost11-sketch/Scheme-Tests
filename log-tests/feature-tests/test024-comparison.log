>>> (= 1 1)
==> #t

>>> (= 1 1 1 1)
==> #t

>>> (= 1 2)
==> #f

>>> (< 1 2 3 4)
==> #t

>>> (< 1 3 2)
==> #f

>>> (> 4 3 2 1)
==> #t

>>> (<= 1 1 2 3)
==> #t

>>> (>= 3 3 2 1)
==> #t

>>> (= +inf.0 +inf.0)
==> #t

>>> (< -inf.0 0 +inf.0)
==> #t

>>> (> +inf.0 1000000)
==> #t

>>> (< +nan.0 0)
... ;;; -------- type predicates on special reals --------
==> #f

>>> (< 1/3 1/2)
==> #t

>>> (= 2/4 1/2)
==> #t

>>> (> 3/4 1/2)
==> #t

>>> (<= 1/3 1/3)
==> #t

>>> (= 1/2 0.5)
... ;;; -------- numerator / denominator --------
==> #t

>>> (= 3+4i 3+4i)
==> #t

>>> (= 3+4i 3+5i)
... ;;; Complex with zero imaginary part equals the real.
==> #f

>>> (= 2+0i 2)
... ;;; -------- abs on complex (magnitude) --------
==> #t

>>> (= 1@0 (make-polar 1 0))
... ;;; Polar and rectangular agree for r=5, theta=0.
==> #t

>>> (= 5@0 5+0i)
... ;;; -------- string->number with #e on non-integer reals --------
... ;;; #e1.5 -> exact rational 3/2.
==> #t

>>> (= 3+4i 3.0+4.0i)
... ;;; eqv? and equal? on exact complex.
==> #t

>>> (= 1/2 1/2)
==> #t

>>> (= 1/2 2/4)
==> #t

>>> (<= 1/4 1/4)
==> #t

>>> (>= 3/4 1/2)
... ; eqv? exact/inexact distinction
==> #t

