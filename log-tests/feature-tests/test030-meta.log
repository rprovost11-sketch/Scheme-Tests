... ; runtime
... ; ==========================================================
>>> (inexact? (runtime))
==> #t

>>> (>= (runtime) 0)
==> #t

>>> (number? (runtime))
==> #t

>>> (runtime 1)
%%% SchemeArityError: line 1, col 1: runtime: 1 argument provided; 0 expected
%%% (runtime 1)
%%% ^

;;; ==========================================================
;;; trace / untrace
;;; ==========================================================

;;; (trace) with no args returns the set of traced names (empty at start)
>>> (trace)
==> ()

>>> (define (double x) (* x 2))
==>

;;; (trace f) registers f and returns the updated set
>>> (trace double)
==> (double)

;;; calling a traced function prints enter and exit lines
>>> (double 5)
 0: (double 5)
 0: double returned 10
==> 10

;;; (untrace f) removes f and returns the updated set
>>> (untrace double)
==> ()

;;; after untracing, no output
>>> (double 7)
==> 14

;;; recursive function: trace shows nested calls
>>> (define (fact n) (if (= n 0) 1 (* n (fact (- n 1)))))
==>

>>> (trace fact)
==> (fact)

>>> (fact 3)
 0: (fact 3)
 1:   (fact 2)
 2:     (fact 1)
 3:       (fact 0)
 3:       fact returned 1
 2:     fact returned 1
 1:   fact returned 2
 0: fact returned 6
==> 6

;;; (untrace) with no args clears all
>>> (untrace)
==> ()

>>> (trace)
==> ()

;;; type errors
>>> (trace 42)
%%% SchemeTypeError: line 1, col 1: trace: arguments must be symbols
%%% (trace 42)
%%% ^

>>> (untrace 42)
%%% SchemeTypeError: line 1, col 1: untrace: arguments must be symbols
%%% (untrace 42)
%%% ^

;;; ==========================================================
;;; record-system internal primitives (%-prefixed; emitted by
;;; define-record-type but directly callable) — error paths
;;; ==========================================================

>>> (%make-record-type 5 '())
... ; %make-record-type with a non-symbol name is an error
%%% SchemeTypeError: line 1, col 1: %make-record-type: first argument must be a symbol
%%% (%make-record-type 5 '())
%%% ^

>>> (%make-record-type 'p '(a 5 c))
... ; %make-record-type with a non-symbol field name is an error
%%% SchemeTypeError: line 1, col 1: %make-record-type: field names must be symbols
%%% (%make-record-type 'p '(a 5 c))
%%% ^

>>> (%make-record-type 'p '(a . b))
... ; %make-record-type field names must be a proper list
%%% SchemeTypeError: line 1, col 1: %make-record-type: field names must be a proper list
%%% (%make-record-type 'p '(a . b))
%%% ^

>>> (%make-record 5 '())
... ; %make-record first argument must be a record type
%%% SchemeTypeError: line 1, col 1: %make-record: first argument must be a record type
%%% (%make-record 5 '())
%%% ^

>>> (%make-record (%make-record-type 'p '(a)) '(1 . 2))
... ; %make-record field values must be a proper list
%%% SchemeTypeError: line 1, col 1: %make-record: field values must be a proper list
%%% (%make-record (%make-record-type 'p '(a)) '(1 . 2))
%%% ^

>>> (%record-of-type? 5 5)
... ; %record-of-type? second argument must be a record type
%%% SchemeTypeError: line 1, col 1: %record-of-type?: second argument must be a record type
%%% (%record-of-type? 5 5)
%%% ^

>>> (%record-ref 5 5 0)
... ; %record-ref second argument must be a record type
%%% SchemeTypeError: line 1, col 1: %record-ref: second argument must be a record type
%%% (%record-ref 5 5 0)
%%% ^

>>> (%record-ref 5 (%make-record-type 'p '(a)) 0)
... ; %record-ref record is not of the expected type
%%% SchemeTypeError: line 1, col 1: %record-ref: record is not of the expected type p
%%% (%record-ref 5 (%make-record-type 'p '(a)) 0)
%%% ^

>>> (let ((t (%make-record-type 'p '(a)))) (%record-ref (%make-record t '(1)) t 'x))
... ; %record-ref index must be an integer
%%% SchemeTypeError: line 1, col 40: %record-ref: index must be an integer
%%% (let ((t (%make-record-type 'p '(a)))) (%record-ref (%make-record t '(1)) t 'x))
%%%                                        ^

>>> (%make-record-accessor 5 0 'a)
... ; %make-record-accessor first argument must be a record type
%%% SchemeTypeError: line 1, col 1: %make-record-accessor: first argument must be a record type
%%% (%make-record-accessor 5 0 'a)
%%% ^

>>> (%make-record-accessor (%make-record-type 'p '(a)) 'x 'a)
... ; %make-record-accessor index must be an integer
%%% SchemeTypeError: line 1, col 1: %make-record-accessor: index must be an integer
%%% (%make-record-accessor (%make-record-type 'p '(a)) 'x 'a)
%%% ^

>>> (%make-record-accessor (%make-record-type 'p '(a)) 0 5)
... ; %make-record-accessor name must be a symbol
%%% SchemeTypeError: line 1, col 1: %make-record-accessor: name must be a symbol
