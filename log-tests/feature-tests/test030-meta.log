;;; ==========================================================
;;; null-environment / scheme-report-environment / load
;;; ==========================================================

>>> (null-environment 'x)
... ; null-environment version must be an integer
%%% SchemeTypeError: line 1, col 1: null-environment: version must be an integer
%%% (null-environment 'x)
%%% ^

>>> (null-environment 99)
... ; null-environment only supports version 5
%%% SchemeTypeError: line 1, col 1: null-environment: unsupported version (only 5 is supported)
%%% (null-environment 99)
%%% ^

>>> (scheme-report-environment 'x)
... ; scheme-report-environment version must be an integer
%%% SchemeTypeError: line 1, col 1: scheme-report-environment: version must be an integer
%%% (scheme-report-environment 'x)
%%% ^

>>> (scheme-report-environment 99)
... ; scheme-report-environment only supports version 5
%%% SchemeTypeError: line 1, col 1: scheme-report-environment: unsupported version (only 5 is supported)
%%% (scheme-report-environment 99)
%%% ^

>>> (load 5)
... ; load filename must be a string
%%% SchemeTypeError: line 1, col 1: load: filename must be a string
%%% (load 5)
%%% ^

>>> (load "x" 5)
... ; load second argument must be an environment specifier
%%% SchemeTypeError: line 1, col 1: load: second argument must be an environment specifier
%%% (load "x" 5)
%%% ^
