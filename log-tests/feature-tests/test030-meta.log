%%% SchemeUserError: line 1, col 1: wrong 1 two "three"
%%% (error "wrong" 1 'two "three")
%%% ^
>>> (error 42)
%%% SchemeTypeError: line 1, col 1: error: first argument must be a string
%%% (error 42)
%%% ^
