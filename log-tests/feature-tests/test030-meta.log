%%% ^

>>> (%make-record-mutator 5 0 'a)
... ; %make-record-mutator first argument must be a record type
%%% SchemeTypeError: line 1, col 1: %make-record-mutator: first argument must be a record type
%%% (%make-record-mutator 5 0 'a)
%%% ^

>>> (%make-record-mutator (%make-record-type 'p '(a)) 'x 'a)
... ; %make-record-mutator index must be an integer
%%% SchemeTypeError: line 1, col 1: %make-record-mutator: index must be an integer
%%% (%make-record-mutator (%make-record-type 'p '(a)) 'x 'a)
%%% ^

>>> (%make-record-mutator (%make-record-type 'p '(a)) 0 5)
... ; %make-record-mutator name must be a symbol
%%% SchemeTypeError: line 1, col 1: %make-record-mutator: name must be a symbol
%%% (%make-record-mutator (%make-record-type 'p '(a)) 0 5)
%%% ^

>>> (%record-set! 5 5 0 9)
... ; %record-set! second argument must be a record type
%%% SchemeTypeError: line 1, col 1: %record-set!: second argument must be a record type
%%% (%record-set! 5 5 0 9)
%%% ^

>>> (%record-set! 5 (%make-record-type 'p '(a)) 0 9)
... ; %record-set! record is not of the expected type
%%% SchemeTypeError: line 1, col 1: %record-set!: record is not of the expected type p
%%% (%record-set! 5 (%make-record-type 'p '(a)) 0 9)
%%% ^

>>> (let ((t (%make-record-type 'p '(a)))) (%record-set! (%make-record t '(1)) t 'x 9))
... ; %record-set! index must be an integer
%%% SchemeTypeError: line 1, col 40: %record-set!: index must be an integer
