%%%                                        ^

>>> (apply (%make-record-mutator (%make-record-type 'p '(a)) 0 'set-a!) '(5 9))
... ; applying a record mutator to a non-record of its type is an error
%%% SchemeTypeError: line 1, col 1: set-a!: first argument is not a p
%%% (apply (%make-record-mutator (%make-record-type 'p '(a)) 0 'set-a!) '(5 9))
%%% ^

>>> (call-with-values (lambda () (values 1 2)) 5)
... ; a consumer that is not a procedure is an error
%%% SchemeTypeError: line 1, col 1: expected a procedure
%%% (call-with-values (lambda () (values 1 2)) 5)
%%% ^

