;;; ============================================================
;;; test110-Libraries
;;; The Scheme Programming Language, 4th ed. - Chapter 10
;;; R. Kent Dybvig  (examples used for educational testing)
;;; ============================================================
;;; pyscheme supports R7RS define-library and import (R7RS names only).
;;; The R6RS (library ...) form and all (rnrs ...) library names are
;;; unsupported.  Sections 10.1 and 10.2 have no standalone executable
;;; examples; section 10.4 library definitions all fail as unbound.
;;; ============================================================

;;; ============================================================
;;; 10.1  Standard Libraries
;;; ============================================================

;;; §10.1 lists R6RS standard library names only -- no executable examples.
;;; R6RS names like (rnrs base), (rnrs lists), (rnrs io simple), etc.
;;; are not found by pyscheme's import.

;;; ============================================================
;;; 10.2  Defining New Libraries
;;; ============================================================

;;; (library ...) is R6RS syntax -- unbound in pyscheme

>>> (library (list-tools setops (1))
...   (export set empty-set)
...   (import (rnrs base))
...   (define empty-set '()))
%%% line 1, col 2: unbound variable: library
%%% (library (list-tools setops (1))
%%%  ^

;;; R7RS (import (scheme base)) works; R6RS (rnrs ...) names are not found

>>> (import (scheme base))
==>

>>> (import (scheme write))
==>

>>> (import (rnrs base))
%%% line 1, col 9: import: library not found: (rnrs base)
%%% (import (rnrs base))
%%%         ^

>>> (import (rnrs lists))
%%% line 1, col 9: import: library not found: (rnrs lists)
%%% (import (rnrs lists))
%%%         ^

>>> (import (rnrs syntax-case))
%%% line 1, col 9: import: library not found: (rnrs syntax-case)
%%% (import (rnrs syntax-case))
%%%         ^

;;; versioned library name: library name parts must be symbols or integers

>>> (import (list-tools setops (1)))
%%% line 1, col 9: import: library name parts must be symbols or integers
%%% (import (list-tools setops (1)))
%%%         ^

;;; (only ...) sub-form: only parses outer library name, reports it not found

>>> (import (only (rnrs lists) member))
%%% line 1, col 9: import: library not found: (rnrs lists)
%%% (import (only (rnrs lists) member))
%%%         ^

;;; ============================================================
;;; 10.3  Top-Level Programs
;;; ============================================================

;;; command-line: returns a list of strings (content is system-dependent)

>>> (list? (command-line))
==> #t

;;; (exit) and (exit obj) terminate the process -- not testable in log format

;;; ============================================================
;;; 10.4  Examples
;;; ============================================================

;;; list-tools setops library: (library ...) unbound in pyscheme

>>> (library (list-tools setops (1))
...   (export set empty-set empty-set? list->set set->list
...           union intersection difference member?)
...   (import (rnrs base) (only (rnrs lists) member))
...   (define-syntax set
...     (syntax-rules ()
...       [(_ x ...)
...        (list->set (list x ...))]))
...   (define empty-set '())
...   (define empty-set? null?)
...   (define list->set
...     (lambda (ls)
...       (cond
...         [(null? ls) '()]
...         [(member (car ls) (cdr ls)) (list->set (cdr ls))]
...         [else (cons (car ls) (list->set (cdr ls)))]))))
%%% line 1, col 2: unbound variable: library
%%% (library (list-tools setops (1))
%%%  ^

;;; more-setops library: also unbound

>>> (library (more-setops)
...   (export quoted-set set-cons set-remove)
...   (import (list-tools setops) (rnrs base) (rnrs syntax-case))
...   (define set-cons
...     (lambda (opt optset)
...       (union (set opt) optset))))
%%% line 1, col 2: unbound variable: library
%%% (library (more-setops)
%%%  ^

;;; top-level program import: first library not found

>>> (import (list-tools setops) (more-setops) (rnrs))
%%% line 1, col 9: import: library not found: (list-tools setops)
%%% (import (list-tools setops) (more-setops) (rnrs))
%%%         ^
