;;; cond => with a continuation as the arrow procedure: k is applied with
;;; the test value #t, escaping the enclosing call/cc entirely.
>>> (call/cc (lambda (k) (cond (#t => k)) 'unreached))
==> #t

;;; cond => with a truthy non-boolean test value.
>>> (call/cc (lambda (k) (cond (42 => k)) 'unreached))
==> 42

;;; cond => with assv: continuation receives the matching pair.
>>> (call/cc
...   (lambda (k)
...     (cond ((assv 2 '((1 . a) (2 . b) (3 . c))) => (lambda (p) (k (cdr p))))
...           (else 'miss))))
==> b

;;; case => with a continuation as the arrow procedure: k receives the datum.
>>> (call/cc (lambda (k) (case 5 ((5) => k) (else 'no)) 'unreached))
==> 5



;;; ==========================================================================
;;; Regression: outer with-exception-handler must remain visible when an
;;; inner with-exception-handler is installed in tail position of the outer
;;; thunk.  The previous optimisation popped the outer handler from
;;; handler_stack, so exceptions raised inside the inner handler body could
;;; not propagate outward.
;;; ==========================================================================

;;; raise-continuable inside inner handler reaches outer handler.
>>> (with-exception-handler
...   (lambda (e) (+ e 100))
...   (lambda ()
...     (with-exception-handler
...       (lambda (e) (raise-continuable (+ e 1)))
...       (lambda () (raise-continuable 5)))))
==> 106

;;; raise inside inner handler reaches outer handler via call/cc escape.
>>> (call/cc
...   (lambda (k)
...     (with-exception-handler
...       (lambda (e) (k (+ e 100)))
...       (lambda ()
...         (with-exception-handler
...           (lambda (e) (raise (+ e 10)))
...           (lambda () (raise 1)))))))
==> 111

;;; Three levels: innermost raise propagates through two handlers to outermost.
>>> (call/cc
...   (lambda (k)
...     (with-exception-handler
...       (lambda (e) (k (* e 2)))
...       (lambda ()
...         (with-exception-handler
...           (lambda (e) (raise (+ e 1)))
...           (lambda ()
...             (with-exception-handler
...               (lambda (e) (raise (+ e 10)))
...               (lambda () (raise 1)))))))))
==> 24

>>> (define (late-setter!) (set! late-target 99))
... ;;; ============================================================
... ;;; set! late-binding semantics (R7RS 4.1.6)
... ;;; set! resolves its target at call time, not closure-creation time.
... ;;; If the variable is bound when set! is evaluated, no error occurs.
... ;;; ============================================================
... ;;; Closure is defined before late-target exists in the environment.
==>

>>> (define late-target 0)
==>

>>> (late-setter!)
... ;;; Call succeeds: late-target is bound by the time set! is evaluated.
==>

>>> late-target
... ;;; Verify the mutation took effect.
==> 99

>>> (define (always-unbound!) (set! truly-unbound-var 1))
... ;;; Contrast: set! on a variable that remains unbound at call time still errors.
==>

>>> (always-unbound!)
%%% %any-error%

; ==========================================================================
; Proper tail recursion via bounded continuation space (R7RS 3.5)
; %continuation-depth is an internal probe returning the live continuation-
; stack (K) length.  A properly tail-recursive implementation runs a tail
; loop in CONSTANT continuation space, so the depth measured at the base
; case is independent of the iteration count.  A non-tail loop accumulates
; frames, so its depth grows with the count.  This catches a TCO regression
; at small N -- without relying on a multi-million-iteration overflow (which,
; on a CEK machine, is heap/memory exhaustion rather than a clean signal).
; The tests assert the INVARIANTS (constant vs. growing), not absolute
; depths, which differ by framing across implementations.
; ==========================================================================

>>> (define (kdepth-tail n)
...   (if (= n 0) (%continuation-depth) (kdepth-tail (- n 1))))
==>

>>> (define (kdepth-nontail n)
...   (if (= n 0) (%continuation-depth) (+ 0 (kdepth-nontail (- n 1)))))
==>

>>> (integer? (%continuation-depth))
... ; the probe returns an integer K-stack length
==> #t

>>> (= (kdepth-tail 1) (kdepth-tail 10000))
... ; tail recursion is constant-space: base-case depth is independent of N
==> #t

>>> (= (kdepth-tail 1) (kdepth-tail 1000) (kdepth-tail 10000))
... ; ... and stable across several iteration counts
==> #t

>>> (> (kdepth-nontail 1000) (kdepth-nontail 1))
... ; sensitivity: a non-tail loop's depth grows with N, so a real TCO
...   ; regression would be detected here rather than silently passing
==> #t
