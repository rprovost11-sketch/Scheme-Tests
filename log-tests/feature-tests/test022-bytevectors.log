;;; ============================================================
;;; test22-bytevectors
;;; bytevectors.py: all bytevector operations
;;; ============================================================

>>> (bytevector? #u8(1 2 3))
==> #t

>>> (bytevector? #u8())
==> #t

>>> (bytevector? "hello")
==> #f

>>> (bytevector? '(1 2 3))
... ; --- literal syntax ---
==> #f

>>> (make-bytevector 3)
==> #u8(0 0 0)

>>> (make-bytevector 4 7)
==> #u8(7 7 7 7)

>>> (make-bytevector 0)
... ; --- bytevector constructor ---
==> #u8()

>>> (make-bytevector 1.5)
... ; make-bytevector length must be an integer
%%% SchemeTypeError: line 1, col 1: make-bytevector: length must be an integer
%%% (make-bytevector 1.5)
%%% ^

>>> (make-bytevector -1)
... ; make-bytevector length must be non-negative
%%% SchemeTypeError: line 1, col 1: make-bytevector: length must be non-negative
%%% (make-bytevector -1)
%%% ^

>>> (bytevector 1 2 3)
==> #u8(1 2 3)

>>> (bytevector)
==> #u8()

>>> (bytevector 0 127 255)
... ; === 9. bytevector-length, bytevector-u8-ref, bytevector-u8-set! ===
... ; --- bytevector-length ---
==> #u8(0 127 255)

>>> (bytevector-length #u8(1 2 3))
==> 3

>>> (bytevector-length #u8())
... ; --- bytevector-u8-ref ---
==> 0

>>> (bytevector-u8-ref #u8(10 20 30) 0)
==> 10

>>> (bytevector-u8-ref (make-bytevector 2) 1.5)
... ; bytevector-u8-ref index must be an integer
%%% SchemeTypeError: line 1, col 1: bytevector-u8-ref: index must be an integer
%%% (bytevector-u8-ref (make-bytevector 2) 1.5)
%%% ^

>>> (bytevector-u8-ref #u8(10 20 30) 2)
... ; out of range
==> 30

>>> (bytevector-u8-ref #u8(1 2 3) 5)
%%% SchemeTypeError: line 1, col 1: bytevector-u8-ref: index 5 out of range
%%% (bytevector-u8-ref #u8(1 2 3) 5)
%%% ^

>>> (bytevector-copy #u8(1 2 3 4 5))
==> #u8(1 2 3 4 5)

>>> (bytevector-copy #u8(1 2 3 4 5) 1 3)
==> #u8(2 3)

>>> (bytevector-copy #u8(1 2 3 4 5) 2)
... ; --- bytevector-copy! ---
==> #u8(3 4 5)

>>> (bytevector-append #u8(1 2) #u8(3 4))
==> #u8(1 2 3 4)

>>> (bytevector-append #u8() #u8(5 6))
==> #u8(5 6)

>>> (bytevector-append)
... ; === 11. bytevector->u8-list, u8-list->bytevector ===
... ; --- bytevector->u8-list ---
==> #u8()

>>> (bytevector->u8-list #u8(1 2 3 4 5))
%%% line 1, col 2: unbound variable: bytevector->u8-list
%%% (bytevector->u8-list #u8(1 2 3 4 5))
%%%  ^

>>> (bytevector->u8-list #u8())
%%% line 1, col 2: unbound variable: bytevector->u8-list
%%% (bytevector->u8-list #u8())
%%%  ^

>>> (bytevector-u8-set! (make-bytevector 3) 5 0)
%%% SchemeTypeError: line 1, col 1: bytevector-u8-set!: index 5 out of range
%%% (bytevector-u8-set! (make-bytevector 3) 5 0)
%%% ^

>>> (bytevector-u8-set! (make-bytevector 3) 0 256)
%%% SchemeTypeError: line 1, col 1: bytevector-u8-set!: byte 256 out of u8 range (0..255)
%%% (bytevector-u8-set! (make-bytevector 3) 0 256)
%%% ^

>>> (bytevector-u8-set! (make-bytevector 2) 0 1.5)
... ; bytevector-u8-set! byte must be an integer
%%% SchemeTypeError: line 1, col 1: bytevector-u8-set!: byte must be an integer
%%% (bytevector-u8-set! (make-bytevector 2) 0 1.5)
%%% ^

>>> (bytevector-u8-set! '#u8(1 2) 0 9)
... ; bytevector-u8-set! on an immutable literal is an error
%%% SchemeTypeError: line 1, col 1: bytevector-u8-set!: argument is an immutable literal
%%% (bytevector-u8-set! '#u8(1 2) 0 9)
%%% ^

>>> (bytevector-copy #u8(1 2 3) 2 1)
%%% SchemeTypeError: line 1, col 1: bytevector-copy: range out of bounds
%%% (bytevector-copy #u8(1 2 3) 2 1)
%%% ^

>>> (bytevector-copy '#u8(1 2 3) 1.5)
... ; bytevector-copy start must be an integer
%%% SchemeTypeError: line 1, col 1: bytevector-copy: start must be an integer
%%% (bytevector-copy '#u8(1 2 3) 1.5)
%%% ^

>>> (bytevector-copy '#u8(1 2 3) 0 1.5)
... ; bytevector-copy end must be an integer
%%% SchemeTypeError: line 1, col 1: bytevector-copy: end must be an integer
%%% (bytevector-copy '#u8(1 2 3) 0 1.5)
%%% ^

>>> (bytevector-copy! (make-bytevector 3) 2 #u8(9 9) 0 2)
%%% SchemeTypeError: line 1, col 1: bytevector-copy!: range out of bounds
%%% (bytevector-copy! (make-bytevector 3) 2 #u8(9 9) 0 2)
%%% ^

>>> (bytevector-copy! '#u8(1 2) 0 '#u8(3 4))
... ; bytevector-copy! destination is an immutable literal
%%% SchemeTypeError: line 1, col 1: bytevector-copy!: destination is an immutable literal
%%% (bytevector-copy! '#u8(1 2) 0 '#u8(3 4))
%%% ^

>>> (bytevector-copy! (make-bytevector 2) 1.5 '#u8(3 4))
... ; bytevector-copy! at must be an integer
%%% SchemeTypeError: line 1, col 1: bytevector-copy!: at must be an integer
%%% (bytevector-copy! (make-bytevector 2) 1.5 '#u8(3 4))
%%% ^

>>> (bytevector-copy! (make-bytevector 2) 0 '#u8(3 4) 1.5)
... ; bytevector-copy! start must be an integer
%%% SchemeTypeError: line 1, col 1: bytevector-copy!: start must be an integer
%%% (bytevector-copy! (make-bytevector 2) 0 '#u8(3 4) 1.5)
%%% ^

>>> (bytevector-copy! (make-bytevector 2) 0 '#u8(3 4) 0 1.5)
... ; bytevector-copy! end must be an integer
%%% SchemeTypeError: line 1, col 1: bytevector-copy!: end must be an integer
%%% (bytevector-copy! (make-bytevector 2) 0 '#u8(3 4) 0 1.5)
%%% ^

>>> (bytevector-length "oops")
%%% SchemeTypeError: line 1, col 1: bytevector-length: argument 1 must be a bytevector
%%% (bytevector-length "oops")
%%% ^

>>> (bytevector-u8-ref '() 0)
%%% SchemeTypeError: line 1, col 1: bytevector-u8-ref: argument 1 must be a bytevector
%%% (bytevector-u8-ref '() 0)
%%% ^

>>> (utf8->string #u8(104 101 108 108 111))
==> "hello"

>>> (string->utf8 "hello")
==> #u8(104 101 108 108 111)

>>> (utf8->string (string->utf8 "abc"))
==> "abc"

>>> (string->utf8 "abc" 1 2)
... ; --- error paths ---
... ; utf8->string invalid range
==> #u8(98)

>>> (utf8->string #u8(1 2 3) 3 1)
%%% SchemeTypeError: line 1, col 1: utf8->string: range out of bounds
%%% (utf8->string #u8(1 2 3) 3 1)
%%% ^

>>> (utf8->string '#u8(104 105) 1.5)
... ; utf8->string start must be an integer
%%% SchemeTypeError: line 1, col 1: utf8->string: start must be an integer
%%% (utf8->string '#u8(104 105) 1.5)
%%% ^

>>> (utf8->string '#u8(104 105) 0 1.5)
... ; utf8->string end must be an integer
%%% SchemeTypeError: line 1, col 1: utf8->string: end must be an integer
%%% (utf8->string '#u8(104 105) 0 1.5)
%%% ^

>>> (utf8->string '#u8(255))
... ; utf8->string invalid UTF-8 (system message text varies)
%%% %any-error%

>>> (string->utf8 "abc" 2 1)
%%% SchemeTypeError: line 1, col 1: string->utf8: range out of bounds
%%% (string->utf8 "abc" 2 1)
%%% ^

>>> (string->utf8 42)
... ; string->utf8 argument must be a string
%%% SchemeTypeError: line 1, col 1: string->utf8: argument must be a string
%%% (string->utf8 42)
%%% ^

>>> (string->utf8 "ab" 1.5)
... ; string->utf8 start must be an integer
%%% SchemeTypeError: line 1, col 1: string->utf8: start must be an integer
%%% (string->utf8 "ab" 1.5)
%%% ^

>>> (string->utf8 "ab" 0 1.5)
... ; string->utf8 end must be an integer
%%% SchemeTypeError: line 1, col 1: string->utf8: end must be an integer
%%% (string->utf8 "ab" 0 1.5)
%%% ^
