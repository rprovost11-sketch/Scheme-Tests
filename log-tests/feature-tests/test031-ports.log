... ; --- non-shared structure: output same as write ---
#\space
==>

>>> (write-shared '(1 2 3))
(1 2 3)
==>

>>> (write-shared "hello")
"hello"
==>

>>> (write-shared #t)
... ; simple list, no sharing
#t
==>

>>> (write-shared '(a b c))
... ; nested list, no sharing
(a b c)
==>

>>> (write-shared '(1 (2 3) 4))
... ; --- shared structure: same object in two positions ---
(1 (2 3) 4)
==>

>>> (let ((x '(1 2)))
...   (write-shared (list x x)))
... ; --- cyclic list ---
(#0=(1 2) #0#)
==>

>>> (let ((x (list 1 2 3)))
...   (set-cdr! (cddr x) x)
...   (write-shared x))
... ; --- shared vector ---
#0=(1 2 3 . #0#)
==>

>>> (let ((v (vector 1 2)))
...   (write-shared (list v v)))
... ; optional port argument
(#0=#(1 2) #0#)
==>

>>> (write-shared '(a b) (current-output-port))
... ; --- write vs write-shared distinction ---
... ; write does not detect sharing
(a b)
==>

>>> (let ((x '(a b)))
...   (write (list x x)))
... ; write-shared does detect sharing
