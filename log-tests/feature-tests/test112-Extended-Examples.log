;;; ============================================================
;;; 12.5  Scheme Printer
;;; ============================================================

;;; §12.5 implements put-datum dispatching on all Scheme types, then
;;; wraps it as write and display.  pyscheme already provides write and
;;; display.  The section's examples are equivalent to pyscheme's
;;; built-in output behavior:

>>> (let ([p (open-output-string)])
...   (write '(a b c) p)
...   (get-output-string p))
==> "(a b c)"

>>> (let ([p (open-output-string)])
...   (display "hello" p)
...   (get-output-string p))
==> "hello"

>>> (let ([p (open-output-string)])
...   (write "hello" p)
...   (get-output-string p))
==> "\"hello\""

>>> (let ([p (open-output-string)])
...   (display #\a p)
...   (get-output-string p))
==> "a"

>>> (let ([p (open-output-string)])
...   (write #\a p)
...   (get-output-string p))
==> "#\\a"

;;; ============================================================
;;; 12.6  Formatted Output
;;; ============================================================

;;; dofmt processes ~s (write), ~a (display), ~% (newline), ~~ (tilde)

>>> (define dofmt
...   (lambda (control args port)
...     (let ([n (string-length control)])
...       (let loop ([i 0] [args args])
...         (if (< i n)
...             (let ([c (string-ref control i)])
...               (if (char=? c #\~)
...                   (if (= (+ i 1) n)
...                       (error "printf: incomplete format" control)
...                       (case (string-ref control (+ i 1))
...                         [(#\a #\A) (display (car args) port) (loop (+ i 2) (cdr args))]
...                         [(#\s #\S) (write (car args) port) (loop (+ i 2) (cdr args))]
...                         [(#\%) (newline port) (loop (+ i 2) args)]
...                         [(#\~) (write-char #\~ port) (loop (+ i 2) args)]
...                         [else (error "printf: bad format character"
...                                      (string-ref control (+ i 1)))]))
...                   (begin (write-char c port) (loop (+ i 1) args)))))))))
==>

>>> (define printf
...   (lambda (control . args)
...     (dofmt control args (current-output-port))))
==>

>>> (define fprintf
...   (lambda (port control . args)
...     (dofmt control args port)))
==>

;;; ~s uses write (with quotes), ~~ becomes literal ~, ~% is newline

>>> (printf "The string ~s displays as ~~.~%" "~")
The string "~" displays as ~.
==>

;;; fprintf to string port; ~s writes integer, ~a displays string

>>> (let ([p (open-output-string)])
...   (fprintf p "~s ~a" 42 "hello")
...   (get-output-string p))
==> "42 hello"

;;; ============================================================
;;; 12.7  Meta-Circular Interpreter
;;; ============================================================

;;; exec: handles symbol lookup, quote, lambda, if, set!, application
;;; lambda form creates a real Scheme closure capturing env
;;; primitive-environment: seeds interpreter with essential Scheme procs

>>> (define primitive-environment
...   (list (cons 'cons cons) (cons 'car car) (cons 'cdr cdr)
...         (cons 'list list) (cons 'null? null?) (cons 'eq? eq?)
...         (cons 'call/cc call-with-current-continuation)))
==>

>>> (define new-env
...   (lambda (formals actuals env)
...     (cond
...       [(null? formals) env]
...       [(symbol? formals) (cons (cons formals actuals) env)]
...       [else (cons (cons (car formals) (car actuals))
...                   (new-env (cdr formals) (cdr actuals) env))])))
==>

>>> (define lookup (lambda (var env) (cdr (assq var env))))
==>

>>> (define assign (lambda (var val env) (set-cdr! (assq var env) val)))
==>

>>> (define exec
...   (lambda (expr env)
...     (cond
...       [(symbol? expr) (lookup expr env)]
...       [(pair? expr)
...        (case (car expr)
...          [(quote) (cadr expr)]
...          [(lambda)
...           (lambda vals
...             (let ([env (new-env (cadr expr) vals env)])
...               (let loop ([exprs (cddr expr)])
...                 (if (null? (cdr exprs))
...                     (exec (car exprs) env)
...                     (begin (exec (car exprs) env) (loop (cdr exprs)))))))]
...          [(if)
...           (if (exec (cadr expr) env)
...               (exec (caddr expr) env)
...               (exec (cadddr expr) env))]
...          [(set!) (assign (cadr expr) (exec (caddr expr) env) env)]
...          [else
...           (apply (exec (car expr) env)
...                  (map (lambda (x) (exec x env)) (cdr expr)))])]
...      [else expr])))
==>

>>> (define interpret (lambda (expr) (exec expr primitive-environment)))
==>

>>> (interpret 3)
==> 3

>>> (interpret '(cons 3 4))
==> (3 . 4)

>>> (interpret '((lambda (x . y) (list x y)) 'a 'b 'c 'd))
==> (a (b c d))

;;; call/cc cannot be applied through pyscheme's apply primitive

>>> (interpret '(((call/cc (lambda (k) k)) (lambda (x) x)) "HEY!"))
%%% SchemeTypeError: line 21, col 11: call/cc: cannot be applied through a re-entering primitive (apply / call-with-values / force) in this implementation
%%%           (apply (exec (car expr) env)
%%%           ^
%%%   at line 1, col 34: exec
%%% (define interpret (lambda (expr) (exec expr primitive-environment)))
%%%                                  ^

>>> (interpret '((lambda (memq) (memq memq 'a '(b c a d e)))
...              (lambda (memq x ls)
...                (if (null? ls) #f
...                    (if (eq? (car ls) x) ls
...                        (memq memq x (cdr ls)))))))
==> (a d e)

>>> (interpret '((lambda (reverse)
...               (set! reverse
...                     (lambda (ls new)
...                       (if (null? ls) new
...                           (reverse (cdr ls) (cons (car ls) new)))))
...               (reverse '(a b c d e) '()))
...             #f))
==> (e d c b a)

;;; ============================================================
;;; 12.8  Abstract Objects
;;; ============================================================

;;; define-object: creates a constructor that returns a message-dispatch closure
;;; send-message: syntax that invokes the object with a quoted message name

>>> (define-syntax define-object
...   (syntax-rules ()
...     [(_ (name ivar ...) ((mname mval) ...))
...      (define name
...        (lambda (ivar ...)
...          (letrec ([mname mval] ...)
...            (lambda (msg . args)
...              (case msg
...                [(mname) (apply mname args)] ...
...                [else (error "undefined message" msg)])))))]
...     [(_ (name ivar ...) ((svar sinit) ...) ((mname mval) ...))
...      (define name
...        (lambda (ivar ...)
...          (let* ([svar sinit] ...)
...            (letrec ([mname mval] ...)
...              (lambda (msg . args)
...                (case msg
...                  [(mname) (apply mname args)] ...
...                  [else (error "undefined message" msg)]))))))]))
==>

>>> (define-syntax send-message
...   (syntax-rules ()
...     [(_ obj msg arg ...)
...      (obj 'msg arg ...)]))
==>

;;; kons: pair-like object with mutable car/cdr slots

>>> (define-object (kons kar kdr)
...   ((get-car (lambda () kar))
...    (get-cdr (lambda () kdr))
...    (set-car! (lambda (x) (set! kar x)))
...    (set-cdr! (lambda (x) (set! kdr x)))))
==>

>>> (define p (kons 'a 'b))
==>

>>> (send-message p get-car)
==> a

>>> (send-message p get-cdr)
==> b

>>> (send-message p set-cdr! 'c)
==>

>>> (send-message p get-cdr)
==> c

;;; kons with access count: state variable initialized before methods

>>> (define-object (kons kar kdr)
...   ((count 0))
...   ((get-car (lambda () (set! count (+ count 1)) kar))
...    (get-cdr (lambda () (set! count (+ count 1)) kdr))
...    (accesses (lambda () count))))
==>

>>> (define p (kons 'a 'b))
==>

>>> (send-message p get-car)
==> a

>>> (send-message p get-cdr)
==> b

>>> (send-message p accesses)
==> 2

>>> (send-message p get-cdr)
==> b

>>> (send-message p accesses)
==> 3

