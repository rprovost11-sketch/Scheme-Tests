;;; ============================================================
;;; 12.1  Matrix and Vector Multiplication
;;; ============================================================

;;; matrix represented as vector of row-vectors; helpers use do loops

>>> (define make-matrix
...   (lambda (rows columns)
...     (do ([m (make-vector rows)] [i 0 (+ i 1)])
...         ((= i rows) m)
...       (vector-set! m i (make-vector columns)))))
==>

>>> (define matrix?
...   (lambda (x)
...     (and (vector? x)
...          (> (vector-length x) 0)
...          (vector? (vector-ref x 0)))))
==>

>>> (define matrix-rows (lambda (x) (vector-length x)))
==>

>>> (define matrix-columns (lambda (x) (vector-length (vector-ref x 0))))
==>

>>> (define matrix-ref (lambda (m i j) (vector-ref (vector-ref m i) j)))
==>

>>> (define matrix-set! (lambda (m i j x) (vector-set! (vector-ref m i) j x)))
==>

>>> (define mat-sca-mul
...   (lambda (m x)
...     (let* ([nr (matrix-rows m)] [nc (matrix-columns m)] [r (make-matrix nr nc)])
...       (do ([i 0 (+ i 1)]) ((= i nr) r)
...         (do ([j 0 (+ j 1)]) ((= j nc))
...           (matrix-set! r i j (* x (matrix-ref m i j))))))))
==>

>>> (define mat-mat-mul
...   (lambda (m1 m2)
...     (let* ([nr1 (matrix-rows m1)] [nr2 (matrix-rows m2)]
...            [nc2 (matrix-columns m2)] [r (make-matrix nr1 nc2)])
...       (do ([i 0 (+ i 1)]) ((= i nr1) r)
...         (do ([j 0 (+ j 1)]) ((= j nc2))
...           (do ([k 0 (+ k 1)] [a 0 (+ a (* (matrix-ref m1 i k) (matrix-ref m2 k j)))])
...               ((= k nr2) (matrix-set! r i j a))))))))
==>

>>> (define mul
...   (lambda (x y)
...     (cond
...       [(number? x)
...        (cond [(number? y) (* x y)]
...              [(matrix? y) (mat-sca-mul y x)]
...              [else (error "mul: not a number or matrix" y)])]
...       [(matrix? x)
...        (cond [(number? y) (mat-sca-mul x y)]
...              [(matrix? y) (mat-mat-mul x y)]
...              [else (error "mul: not a number or matrix" y)])]
...       [else (error "mul: not a number or matrix" x)])))
==>

>>> (mul 3 4)
==> 12

>>> (mul 1/2 '#(#(1 2 3)))
==> #(#(1/2 1 3/2))

>>> (mul -2 '#(#(3 -2 -1) #(-3 0 -5) #(7 -1 -1)))
==> #(#(-6 4 2) #(6 0 10) #(-14 2 2))

>>> (mul '#(#(1 2 3)) '#(#(2 3) #(3 4) #(4 5)))
==> #(#(20 26))

>>> (mul '#(#(2 3 4) #(3 4 5)) '#(#(1) #(2) #(3)))
==> #(#(20) #(26))

>>> (mul '#(#(1 2 3) #(4 5 6)) '#(#(1 2 3 4) #(2 3 4 5) #(3 4 5 6)))
==> #(#(14 20 26 32) #(32 47 62 77))

;;; ============================================================
;;; 12.2  Sorting
;;; ============================================================

;;; merge-sort: uses quotient (book uses div, R6RS); list-tail is R7RS

>>> (define domerge
...   (lambda (pred? l1 l2)
...     (cond
...       [(null? l1) l2]
...       [(null? l2) l1]
...       [(pred? (car l2) (car l1))
...        (cons (car l2) (domerge pred? l1 (cdr l2)))]
...       [else (cons (car l1) (domerge pred? (cdr l1) l2))])))
==>

>>> (define dosort
...   (lambda (pred? ls n)
...     (if (= n 1)
...         (list (car ls))
...         (let ([i (quotient n 2)])
...           (domerge pred?
...             (dosort pred? ls i)
...             (dosort pred? (list-tail ls i) (- n i)))))))
==>

>>> (define sort
...   (lambda (pred? l)
...     (if (null? l) l (dosort pred? l (length l)))))
==>

>>> (define merge
...   (lambda (pred? l1 l2)
...     (domerge pred? l1 l2)))
==>

>>> (sort < '(3 4 2 1 2 5))
==> (1 2 2 3 4 5)

;;; stable sort: 0.5 = 1/2 so equal elements preserve original order

>>> (sort > '(0.5 1/2))
==> (0.5 1/2)

>>> (sort > '(1/2 0.5))
==> (1/2 0.5)

>>> (list->string (sort char>? (string->list "coins")))
==> "sonic"

>>> (merge char<? '(#\a #\c) '(#\b #\c #\d))
==> (#\a #\b #\c #\c #\d)

>>> (merge < '(1/2 2/3 3/4) '(0.5 0.6 0.7))
==> (1/2 0.5 0.6 2/3 0.7 3/4)

>>> (list->string (merge char>? (string->list "old") (string->list "toe")))
==> "tooled"

;;; ============================================================
;;; 12.3  A Set Constructor
;;; ============================================================

;;; set-of: list comprehension via syntax-rules
;;; clauses: (x in l) -- iterate, (x is v) -- bind, pred -- filter
;;; fresh loop variable 'ls' avoids pattern-variable substitution issue

>>> (define-syntax set-of
...   (syntax-rules (in is)
...     [(_ e) (list e)]
...     [(_ e (x in l) rest ...)
...      (let loop ([ls l])
...        (if (null? ls)
...            '()
...            (let ([x (car ls)])
...              (append (set-of e rest ...) (loop (cdr ls))))))]
...     [(_ e (x is v) rest ...)
...      (let ([x v]) (set-of e rest ...))]
...     [(_ e pred rest ...)
...      (if pred (set-of e rest ...) '())]))
==>

>>> (set-of x (x in '(a b c)))
==> (a b c)

>>> (set-of x (x in '(1 2 3 4)) (even? x))
==> (2 4)

>>> (set-of (cons x y) (x in '(1 2 3)) (y is (* x x)))
==> ((1 . 1) (2 . 4) (3 . 9))

>>> (set-of (cons x y) (x in '(a b)) (y in '(1 2)))
==> ((a . 1) (a . 2) (b . 1) (b . 2))

