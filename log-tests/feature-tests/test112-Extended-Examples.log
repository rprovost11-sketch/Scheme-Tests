;;; ============================================================
;;; 12.10  Unification Algorithm
;;; ============================================================

;;; unify: finds most-general unifier; returns unified term or "clash"/"cycle"
;;; uni: CPS unification; s is substitution procedure (starts as identity)
;;; try-subst: substitutes a logic variable, checks for cycle via occurs?
;;; sigma: extends substitution: returns new procedure replacing u with v

>>> (define uni
...   (lambda (u v s ks kf)
...     (cond
...       [(symbol? u) (try-subst u v s ks kf)]
...       [(symbol? v) (try-subst v u s ks kf)]
...       [(and (pair? u) (pair? v)
...             (eq? (car u) (car v))
...             (= (length u) (length v)))
...        (let f ([u (cdr u)] [v (cdr v)] [s s])
...          (if (null? u)
...              (ks s)
...              (uni (car u) (car v) s
...                   (lambda (s) (f (cdr u) (cdr v) s))
...                   kf)))]
...       [else (kf "clash")])))
==>

>>> (define try-subst
...   (lambda (u v s ks kf)
...     (let ([u (s u)])
...       (if (not (symbol? u))
...           (uni u v s ks kf)
...           (let ([v (s v)])
...             (cond
...               [(eq? u v) (ks s)]
...               [(occurs? u v) (kf "cycle")]
...               [else (ks (sigma u v s))]))))))
==>

>>> (define occurs?
...   (lambda (u v)
...     (and (pair? v)
...          (let f ([l (cdr v)])
...            (and (pair? l)
...                 (or (eq? u (car l))
...                     (occurs? u (car l))
...                     (f (cdr l))))))))
==>

>>> (define sigma
...   (lambda (u v s)
...     (lambda (x)
...       (let f ([x (s x)])
...         (if (symbol? x)
...             (if (eq? x u) v x)
...             (cons (car x) (map f (cdr x))))))))
==>

>>> (define unify
...   (lambda (u v)
...     (uni u v
...          (lambda (x) x)
...          (lambda (s) (s u))
...          (lambda (msg) msg))))
==>

>>> (unify 'x 'y)
==> y

>>> (unify '(f x y) '(g x y))
==> "clash"

>>> (unify '(f x (h)) '(f (h) y))
==> (f (h) (h))

>>> (unify '(f (g x) y) '(f y x))
==> "cycle"

>>> (unify '(f (g x) y) '(f y (g x)))
==> (f (g x) (g x))

>>> (unify '(f (g x) y) '(f y z))
==> (f (g x) (g x))

