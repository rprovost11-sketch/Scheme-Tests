;;; ============================================================
;;; test011-hygiene
;;; R7RS sets-of-scopes hygiene: regression tests for the cases
;;; that motivated the 0.3.3 / 0.3.4 hygiene refactor and that are
;;; not already covered in test008-macros.log.
;;; ============================================================

;;; ------------------------------------------------------------
;;; R7RS 4.3.2 normative example 1: `when' built from `if' and
;;; `begin'.  A use site that locally rebinds `if' must not break
;;; the macro -- the template's `if' refers to the def-time `if'.
;;; ------------------------------------------------------------

>>> (define-syntax h11-when
...   (syntax-rules ()
...     ((_ test stmt1 stmt2 ...) (if test (begin stmt1 stmt2 ...)))))
==>

>>> (let ((if 'redefined))
...   (h11-when #t 'ran))
==> ran

;;; ------------------------------------------------------------
;;; R7RS 4.3.2 normative example 2: a use-site `if' whose binding
;;; would shadow a template free `if' must not capture it.
;;; ------------------------------------------------------------

>>> (let ((if (lambda args 'use-site-if)))
...   (h11-when (= 1 1) 'a))
==> a

;;; ------------------------------------------------------------
;;; Macros That Work (Clinger 1991) `or' style: the introduced
;;; temporary must not be captured by a use-site binding of the
;;; same name.
;;; ------------------------------------------------------------

>>> (define-syntax h11-or
...   (syntax-rules ()
...     ((_) #f)
...     ((_ e) e)
...     ((_ e1 e2 ...) (let ((t e1)) (if t t (h11-or e2 ...))))))
==>

>>> (let ((t 'user)) (h11-or #f t))
==> user

;;; ------------------------------------------------------------
;;; Identifier in binding position introduced by a macro must not
;;; collide with a use-site reference of the same name.  The body
;;; of `make-x' creates its own `x'; the surrounding `x' is the
;;; outer one and is unaffected.
;;; ------------------------------------------------------------

>>> (define-syntax h11-make-x
...   (syntax-rules ()
...     ((_ body) (let ((x 'inner)) body))))
==>

>>> (define h11-x 'outer)
==>

>>> (h11-make-x h11-x)
==> outer

;;; ------------------------------------------------------------
;;; Auxiliary keyword `else' is hygienic: a user binding named
;;; `else' shadows the literal in `cond'; the else clause must
;;; not fire when `else' is bound to a true (non-#f) value, and
;;; the symbol is treated as a regular test instead.
;;; ------------------------------------------------------------

>>> (let ((else #f))
...   (cond (else 'fired)
...         (#t 'fallback)))
==> fallback

>>> (let ((else 'truthy))
...   (cond (else 'fired)))
==> fired

;;; ------------------------------------------------------------
;;; Auxiliary keyword `=>' is hygienic: shadowing it removes the
;;; arrow-clause interpretation.  Here `=>' is bound to a value,
;;; so `(test => proc)' is read as a 3-element clause body, not
;;; an arrow clause.
;;; ------------------------------------------------------------

>>> (let ((=> 'shadowed))
...   (cond (#t => 'val)))
==> val

;;; ------------------------------------------------------------
;;; Auxiliary keyword `else' inside `case' is hygienic too: when
;;; shadowed, it is no longer recognized as the case clause-tag,
;;; and the clause becomes malformed (its head is a bare symbol,
;;; not a list of datums).
;;; ------------------------------------------------------------

>>> (let ((else 'shadowed))
...   (case 1
...     ((2) 'two)
...     (else 'last)))
%%% line 4, col 6: case clause head must be a list of datums, got else
%%%     (else 'last)))
%%%      ^

;;; ------------------------------------------------------------
;;; let-syntax vs letrec-syntax (R7RS 4.3.1).  Sibling bindings
;;; in let-syntax are NOT visible to each other; in letrec-syntax
;;; they are.
;;; ------------------------------------------------------------

>>> (letrec-syntax ((h11-a (syntax-rules () ((_) (h11-b))))
...                 (h11-b (syntax-rules () ((_) 42))))
...   (h11-a))
==> 42

>>> (let-syntax ((h11-c (syntax-rules () ((_) 1)))
...              (h11-d (syntax-rules () ((_) (h11-c)))))
...   (h11-d))
%%% line 2, col 44: unbound variable: h11-c
%%%              (h11-d (syntax-rules () ((_) (h11-c)))))
%%%                                            ^

;;; ------------------------------------------------------------
;;; Duplicate binding detection (R7RS 4.2.2): let, letrec, and
;;; letrec* must reject duplicate names; let* explicitly allows
;;; them.
;;; ------------------------------------------------------------

>>> (let ((a 1) (a 2)) a)
%%% line 1, col 1: duplicate variable name in let bindings: a
%%% (let ((a 1) (a 2)) a)
%%% ^

>>> (letrec ((a 1) (a 2)) a)
%%% line 1, col 1: duplicate variable name in letrec bindings: a
%%% (letrec ((a 1) (a 2)) a)
%%% ^

>>> (letrec* ((a 1) (a 2)) a)
%%% line 1, col 1: duplicate variable name in letrec* bindings: a
%%% (letrec* ((a 1) (a 2)) a)
%%% ^

>>> (let* ((a 1) (a 2)) a)
==> 2

;;; ------------------------------------------------------------
;;; R7RS 4.3.2 (syntax-error <message> <args>...): a template form
;;; that raises a syntax error at expansion time.  The message is
;;; a literal string; remaining args are appended to the message
;;; in their datum form.
;;; ------------------------------------------------------------

>>> (define-syntax h11-must-be-zero
...   (syntax-rules ()
...     ((_ 0) 'ok)
...     ((_ x) (syntax-error "argument must be 0" x))))
==>

>>> (h11-must-be-zero 0)
==> ok

>>> (h11-must-be-zero 5)
%%% line 1, col 1: argument must be 0: 5
%%% (h11-must-be-zero 5)
%%% ^

>>> (define-syntax h11-no-args
...   (syntax-rules ()
...     ((_) (syntax-error "no args allowed"))))
==>

>>> (h11-no-args)
%%% line 1, col 1: no args allowed
%%% (h11-no-args)
%%% ^

;;; ------------------------------------------------------------
;;; Per-application introduction scope (R7RS 4.3 / Flatt 2016
;;; two-scope-per-use): two applications of the same macro that
;;; each introduce a binding with the same name must produce
;;; DISTINCT hygienic identifiers, not a duplicate-name error.
;;; The resulting bindings are invisible to use-site references
;;; (correct hygiene), so a use-site reference to that name is
;;; unbound.
;;; ------------------------------------------------------------

>>> (define-syntax h11-bind-hidden
...   (syntax-rules ()
...     ((_ v) (define h11-hidden v))))
==>

>>> (let ()
...   (h11-bind-hidden 1)
...   (h11-bind-hidden 2)
...   h11-hidden)
%%% line 4, col 3: unbound variable: h11-hidden
%%%   h11-hidden)
%%%   ^

;;; ------------------------------------------------------------
;;; Counterpart: when the binding name is supplied by the user
;;; via a pattern variable, the binding IS visible at the use
;;; site (because the captured fragment carries the user's
;;; scope set, not the macro's introduction scope).
;;; ------------------------------------------------------------

>>> (define-syntax h11-bind-visible
...   (syntax-rules ()
...     ((_ name v) (define name v))))
==>

>>> (let ()
...   (h11-bind-visible h11-vis 7)
...   h11-vis)
==> 7
