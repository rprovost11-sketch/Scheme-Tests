;;; ============================================================
;;; 01-reader
;;; lexer / datum syntax: read, #-syntax, datum labels, escapes
;;; ============================================================
;;;
;;; Regression tripwires for the reader/parser.  Each entry is pinned to a specific
;;; bug that was fixed -- this is NOT feature coverage.  Only Scheme-
;;; observable, non-spec regressions belong here; spec deviations go in
;;; R7RS-Compliance-Tests/, internal-only bugs in undercarriage gc_test.cpp.
;;; See 00-conventions.md for the full routing rule.
;;;
;;; HOW TO ADD A REGRESSION
;;;   - Append to the END of this file.  Tests run top-to-bottom; keep them
;;;     in chronological order (oldest bug first) so the file reads as a
;;;     timeline for this subsystem.
;;;   - Precede each case with a provenance comment so it stays meaningful:
;;;        ; REG <yyyy-mm-dd> -- <commit-or-issue> -- <one line: what broke>
;;;        ; Symptom: <what the user saw before the fix>
;;;   - Keep the reproducer MINIMAL, then give the expected result:
;;;        >>> (expression)
;;;        ==> expected             ; or:  %%% %any-error%
;;;

>>> #!bogus
... ; REG 2026-06-08 -- short #!-directive crashed the reader; _substring read past
... ; end of string.  Symptom: "internal error: string index out of range" instead
... ; of "unknown #!-directive".  (cppscheme2 unaffected; guards length before substr.)
%%% line 1, col 1: unknown #!-directive
%%% #!bogus
%%% ^

; REG 2026-06-09 -- reader nesting is unbounded (iterative reader, v0.5.13).
;   The recursive-descent reader used to overflow the host stack on deeply-nested
;   input (hard C-stack crash in cppscheme2, RecursionError in pyScheme); v0.5.12
;   capped nesting at 500 with a graceful "expression nesting too deep" error.
;   v0.5.13 rewrote the reader with an explicit frame stack, so nesting of any
;   depth now reads (memory-bound, not depth-capped) -- matching equal? and the
;   pretty-printer.  Flat lists of any length always read.  The deep input is
;   built as a runtime string and fed through read, so it is not literally here.

>>> (pair? (read (open-input-string (string-append (make-string 100 #\() "1" (make-string 100 #\))))))
... ; 100-deep nesting reads fine
==> #t

>>> (let loop ((x (read (open-input-string (string-append (make-string 30000 #\() "1" (make-string 30000 #\)))))) (n 0)) (if (pair? x) (loop (car x) (+ n 1)) n))
... ; 30000-deep nesting reads with no cap and fully descends (was a graceful "too deep" error at 500)
==> 30000
