;;; ============================================================
;;; 03-evaluator
;;; core evaluation: special forms, tail calls, continuations, dynamic-wind
;;; ============================================================
;;;
;;; Regression tripwires for the evaluator.  Each entry is pinned to a specific
;;; bug that was fixed -- this is NOT feature coverage.  Only Scheme-
;;; observable, non-spec regressions belong here; spec deviations go in
;;; R7RS-Compliance-Tests/, internal-only bugs in undercarriage gc_test.cpp.
;;; See 00-conventions.md for the full routing rule.
;;;
;;; HOW TO ADD A REGRESSION
;;;   - Append to the END of this file.  Tests run top-to-bottom; keep them
;;;     in chronological order (oldest bug first) so the file reads as a
;;;     timeline for this subsystem.
;;;   - Precede each case with a provenance comment so it stays meaningful:
;;;        ; REG <yyyy-mm-dd> -- <commit-or-issue> -- <one line: what broke>
;;;        ; Symptom: <what the user saw before the fix>
;;;   - Keep the reproducer MINIMAL, then give the expected result:
;;;        >>> (expression)
;;;        ==> expected             ; or:  %%% %any-error%
;;;
; REG 2026-06-07 -- map/for-each/filter CEK-frame conversion -- nested
;   higher-order calls overflowed the host stack.
; Symptom: a recursive map / for-each / filter whose callback re-enters
;   map / for-each / filter (a for-each tree walk, a singleton-map driven
;   recursion, a predicate that recurses) raised "recursion depth exceeded"
;   at ~600 levels, because each primitive re-entered the evaluator (cek_eval)
;   once per element.  These are now driven on the CEK K-stack via
;   FRAME_HOF_STEP, so nesting depth is heap-bounded like ordinary recursion.

>>> (define (map-depth n)
...   (if (= n 0) 'done (car (map (lambda (ignore) (map-depth (- n 1))) '(x)))))
==>

>>> (map-depth 5000)
... ; pre-fix: aborted ~600 deep with "recursion depth exceeded"
==> done

>>> (define fe-acc 0)
==>

>>> (define (fe-depth n)
...   (if (= n 0) #t
...       (for-each (lambda (ignore) (set! fe-acc (+ fe-acc 1)) (fe-depth (- n 1))) '(x))))
==>

>>> (begin (fe-depth 5000) fe-acc)
... ; deep for-each nesting through the callback; runs once per level, no overflow.
...   ; (Uses a 1-element list each level rather than one deep structure, so this
...   ; exercises for-each's own recursion without depending on GC traversal of
...   ; deeply car-nested data.)
==> 5000

>>> (define (filter-depth n)
...   (if (= n 0) #t (filter (lambda (ignore) (filter-depth (- n 1))) '(x))))
==>

>>> (length (filter-depth 5000))
... ; the predicate recurses, nesting filter through its callback each level
==> 1

; REG 2026-06-07 -- HOF stack-safety, part 2 -- vector/string variants.
; Symptom: same as above (host-stack overflow ~600 deep on nested callbacks),
;   for vector-map / vector-for-each / string-map / string-for-each.  Now driven
;   on the K stack via FRAME_HOF_STEP_IDX (index-based cursors).

>>> (define (vmap-depth n)
...   (if (= n 0) 'done
...       (vector-ref (vector-map (lambda (ignore) (vmap-depth (- n 1))) #(x)) 0)))
==>

>>> (vmap-depth 5000)
... ; deep vector-map nesting through the callback, no overflow
==> done

>>> (define vfe-acc 0)
==>

>>> (define (vfe-depth n)
...   (if (= n 0) #t
...       (vector-for-each
...         (lambda (ignore) (set! vfe-acc (+ vfe-acc 1)) (vfe-depth (- n 1)))
...         #(x))))
==>

>>> (begin (vfe-depth 5000) vfe-acc)
... ; deep vector-for-each: callback runs once per level
==> 5000

>>> (define (smap-depth n)
...   (if (= n 0) #\z
...       (string-ref (string-map (lambda (ignore) (smap-depth (- n 1))) "x") 0)))
==>

>>> (char=? (smap-depth 5000) #\z)
... ; deep string-map nesting through the callback
==> #t

>>> (define sfe-acc 0)
==>

>>> (define (sfe-depth n)
...   (if (= n 0) #t
...       (string-for-each
...         (lambda (ignore) (set! sfe-acc (+ sfe-acc 1)) (sfe-depth (- n 1)))
...         "x")))
==>

>>> (begin (sfe-depth 5000) sfe-acc)
... ; deep string-for-each: callback runs once per level
==> 5000

; REG 2026-06-09 -- member/assoc custom-comparator CEK-frame conversion.
; Symptom: the 3-arg member/assoc forms re-entered the evaluator once per
;   element via the comparator, so a comparator that itself recursed through
;   member/assoc overflowed the host stack at ~600 levels ("recursion depth
;   exceeded").  Now driven on the CEK K-stack via FRAME_SEARCH_STEP, so depth
;   is heap-bounded like ordinary recursion.  The 2-arg forms (and memv/memq/
;   assv/assq) use built-in equality, never re-enter the evaluator -- unaffected.

>>> (member 5 (list 1 2 5 7) (lambda (a b) (= a b)))
... ; 3-arg member returns the matching sublist
==> (5 7)

>>> (assoc 2 (list (cons 1 'a) (cons 2 'b)) (lambda (a b) (= a b)))
... ; 3-arg assoc returns the matching pair
==> (2 . b)

>>> (define mem-deep #f)
==>

>>> (define (mem-depth n)
...   (if (= n 0) (set! mem-deep 'done)
...       (member 'x (list 'x) (lambda (t e) (mem-depth (- n 1)) #t))))
==>

>>> (begin (mem-depth 5000) mem-deep)
... ; the comparator recurses through member each level; pre-fix overflowed ~600 deep
==> done

>>> (define assoc-deep #f)
==>

>>> (define (assoc-depth n)
...   (if (= n 0) (set! assoc-deep 'done)
...       (assoc 'x (list (cons 'x 1)) (lambda (t e) (assoc-depth (- n 1)) #t))))
==>

>>> (begin (assoc-depth 5000) assoc-deep)
... ; same for assoc's comparator, driven through FRAME_SEARCH_STEP
==> done

; REG 2026-06-09 -- equal? iterative (explicit heap worklist).
; Symptom: equal? recursed on BOTH car and cdr, so it overflowed the host stack
;   on a long FLAT list (the cdr-spine) or a deeply NESTED structure (the car
;   chain) -- ~1000 deep in pyScheme (RecursionError), a hard C-stack crash in
;   cppscheme2.  Now driven by an explicit worklist: the cdr-spine is iterated
;   in a loop and cars / vector items / exact-complex parts are pushed, so depth
;   is heap-bounded.  The 'seen' set still bounds cyclic structure.

>>> (define (eq-build n acc) (if (= n 0) acc (eq-build (- n 1) (cons n acc))))
==>

>>> (equal? (eq-build 100000 '()) (eq-build 100000 '()))
... ; long flat list: pre-fix overflowed the cdr-spine recursion
==> #t

>>> (define (eq-nest n) (if (= n 0) 'x (list (eq-nest (- n 1)))))
==>

>>> (equal? (eq-nest 50000) (eq-nest 50000))
... ; deeply nested: pre-fix overflowed the car recursion
==> #t

>>> (equal? (vector 1 (vector 2 3) "s") (vector 1 (vector 2 3) "s"))
... ; nested-vector structural equality still correct after the rewrite
==> #t

>>> (equal? (eq-build 100 '()) (eq-build 101 '()))
... ; differing lengths -> not equal (short-circuits)
==> #f

>>> (define cyc (list 1 2 3))
==>

>>> (begin (set-cdr! (cddr cyc) cyc) (equal? cyc cyc))
... ; cyclic structure: the seen-set bounds the walk; terminates as #t
==> #t

; REG 2026-06-09 -- mark_literal_immutable iterative.  Evaluating (quote <datum>)
;   marks the literal immutable by walking it; that walk recursed on car AND cdr
;   and overflowed on deeply-nested or long literal data (hard C-stack crash in
;   cppscheme2 ~50k, RecursionError in pyScheme ~1k).  Now an explicit worklist
;   (the immutable flag doubles as the visited marker), so depth is heap-bounded.
;   The datum is built at runtime and eval'd, so the deep nesting is not in this
;   file literally (the reader itself caps source nesting at 500 -- see 01-reader).

>>> (define (mil-nest k) (let loop ((i k) (a 1)) (if (= i 0) a (loop (- i 1) (list (quote +) 1 a)))))
==>

>>> (pair? (eval (list (quote quote) (mil-nest 20000)) (interaction-environment)))
... ; eval marks the 20000-deep literal immutable; pre-fix overflowed the host stack
==> #t
