;;; ============================================================
;;; 04-gc
;;; garbage-collector bugs observable from Scheme
;;; ============================================================
;;;
;;; Regression tripwires for the garbage collector (Scheme-observable only).  Each entry is pinned to a specific
;;; bug that was fixed -- this is NOT feature coverage.  Only Scheme-
;;; observable, non-spec regressions belong here; spec deviations go in
;;; R7RS-Compliance-Tests/, internal-only bugs in undercarriage gc_test.cpp.
;;; See 00-conventions.md for the full routing rule.
;;;
;;; HOW TO ADD A REGRESSION
;;;   - Append to the END of this file.  Tests run top-to-bottom; keep them
;;;     in chronological order (oldest bug first) so the file reads as a
;;;     timeline for this subsystem.
;;;   - Precede each case with a provenance comment so it stays meaningful:
;;;        ; REG <yyyy-mm-dd> -- <commit-or-issue> -- <one line: what broke>
;;;        ; Symptom: <what the user saw before the fix>
;;;   - Keep the reproducer MINIMAL, then give the expected result:
;;;        >>> (expression)
;;;        ==> expected             ; or:  %%% %any-error%
;;;
; REG 2026-06-07 -- iterative GC mark -- deep car-nested structures overflowed
;   the C stack during collection (cppscheme2 only).
; Symptom: traversing a deeply car-nested structure (e.g. a chain of one-element
;   lists) crashed with a C stack overflow at ~8k-16k depth, non-deterministically
;   (it depended on when a GC happened to fire), because the mark phase recursed
;   on each cons's car.  mark is now driven by an explicit worklist, so mark depth
;   lives on the heap.  pyScheme never had this (no moving GC tracing the data).

>>> (define (build n) (if (= n 0) '() (list (build (- n 1)))))
==>

>>> (define leaves 0)
==>

>>> (define (walk n)
...   (if (pair? n) (for-each walk n) (set! leaves (+ leaves 1))))
==>

>>> (begin (walk (build 30000)) leaves)
... ; a 30000-deep car-nested walk completes; pre-fix this overflowed the C stack
==> 1

; REG 2026-06-15 -- 338fcdc -- record-mutator field store skipped the write barrier
; Symptom: mutating a record that had been promoted to old gen so it points to a
;   freshly-allocated (young) record created an old->young edge the minor GC never
;   recorded; the young child was swept as unreachable and the next access read
;   freed memory -- SIGSEGV, or "<setter>: first argument is not a <type>" once the
;   slot was reused (cppscheme2 only; surfaced by the gcbench benchmark).  The
;   evaluator's record-mutator apply now calls gc_write_barrier like %record-set!.
;   Below: build a tree by churning allocation (forcing GC, promoting gc-root to
;   old gen) and mutating old nodes to point at new ones; every node must survive.

>>> (define-record-type gcnode (mk l r) gcnode? (l gl sl!) (r gr sr!))
==>

>>> (define (pop d n)
...   (if (<= d 0)
...       #f
...       (let ((d (- d 1)))
...         (sl! n (mk #f #f))
...         (sr! n (mk #f #f))
...         (pop d (gl n))
...         (pop d (gr n)))))
==>

>>> (define (cnt n) (if (gcnode? n) (+ 1 (cnt (gl n)) (cnt (gr n))) 0))
==>

>>> (define gc-root (mk #f #f))
==>

>>> (begin (do ((i 0 (+ i 1))) ((>= i 8)) (let ((t (mk #f #f))) (pop 12 t)))
...        (pop 12 gc-root)
...        (cnt gc-root))
... ; all 8191 nodes of the long-lived tree survive; pre-fix this crashed / under-counted
==> 8191
