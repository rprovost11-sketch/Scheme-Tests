;;; ============================================================
;;; SRFI 48 -- Intermediate Format Strings
;;; Loaded from the SRFI repo via -L; byte-identical on both ports,
;;; so ONE golden serves both.  Run through the differ
;;; (]suites differ-srfi) or any -L-aware .log runner.
;;; ============================================================
>>> (import (srfi 48))
==>
>>> (format "~a + ~a = ~a" 1 2 3)
==> "1 + 2 = 3"
>>> (format "~d / ~x / ~b / ~o" 255 255 5 8)
==> "255 / ff / 101 / 10"
>>> (format "~5d" 42)
==> "   42"
>>> (format "~8,2f" 3.14159)
==> "    3.14"
>>> (format "~,2f" 3.1)
==> "3.10"
>>> (format "~,3f" 1/3)
==> "0.333"
>>> (format "~,2f" -3.14159)
==> "-3.14"
>>> (format "~6f" "hi")
==> "    hi"
>>> (format "~c" #\A)
==> "A"
>>> (format "~w" (list 1 2 3))
==> "(1 2 3)"
>>> (format "~?" "~a-~a" (list 1 2))
==> "1-2"
>>> (format "fresh:~&a~&b")
==> "fresh:\na\nb"
>>> (format #f "~a" 42)
==> "42"
