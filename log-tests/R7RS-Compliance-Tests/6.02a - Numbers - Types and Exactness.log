; Section 6.2 - Numbers (Part a: Types, Exactness, Special Values, Comparison)
;
; R7RS numerical tower (each set is a subset of the next):
;   integer ⊆ rational ⊆ real ⊆ complex ⊆ number
;
; Exactness is orthogonal to type: 1 and 1.0 are both integers
; (1 is exact, 1.0 is inexact).
;
; Special inexact values: +inf.0, -inf.0, +nan.0

; ==========================================================================
; number? — true for all numbers
; ==========================================================================

>>> (number? 0)

==> #t

>>> (number? 1)

==> #t

>>> (number? -1)

==> #t

>>> (number? 1.0)

==> #t

>>> (number? 1/2)

==> #t

>>> (number? +inf.0)

==> #t

>>> (number? -inf.0)

==> #t

>>> (number? +nan.0)

==> #t

>>> (number? #t)

==> #f

>>> (number? "1")

==> #f

>>> (number? '())

==> #f

; ==========================================================================
; complex? — true for all numbers (R7RS: all numbers are complex)
; ==========================================================================

>>> (complex? 0)

==> #t

>>> (complex? 1)

==> #t

>>> (complex? 1.0)

==> #t

>>> (complex? 1/2)

==> #t

>>> (complex? +inf.0)

==> #t

>>> (complex? +nan.0)

==> #t

>>> (complex? #f)

==> #f

; ==========================================================================
; real? — true for all real numbers
; ==========================================================================

>>> (real? 1)

==> #t

>>> (real? 1.0)

==> #t

>>> (real? 1/2)

==> #t

>>> (real? +inf.0)

==> #t

>>> (real? -inf.0)

==> #t

>>> (real? +nan.0)

==> #t

>>> (real? #f)

==> #f

; ==========================================================================
; rational? — true for finite rationals (not inf or nan)
; ==========================================================================

>>> (rational? 1)

==> #t

>>> (rational? 1.0)

==> #t

>>> (rational? 1/2)

==> #t

>>> (rational? 0)

==> #t

>>> (rational? -3/4)

==> #t

>>> (rational? +inf.0)

==> #f

>>> (rational? -inf.0)

==> #f

>>> (rational? +nan.0)

==> #f

; ==========================================================================
; integer? — true for integers (exact or inexact whole numbers)
; ==========================================================================

>>> (integer? 0)

==> #t

>>> (integer? 1)

==> #t

>>> (integer? -1)

==> #t

>>> (integer? 1.0)

==> #t

>>> (integer? 1.5)

==> #f

>>> (integer? 1/2)

==> #f

>>> (integer? 2/2)

==> #t

>>> (integer? +inf.0)

==> #f

>>> (integer? +nan.0)

==> #f

>>> (integer? "1")

==> #f

; ==========================================================================
; R7RS 6.2.6 -- worked examples (numerical type predicates)
; An exact zero imaginary part is real (-2.5+0i => #t), but an inexact 0.0
; imaginary part is NOT (-2.5+0.0i => #f); likewise 3+0i is an integer.
; ==========================================================================

>>> (complex? 3+4i)

==> #t

>>> (complex? 3)

==> #t

>>> (real? 3)

==> #t

>>> (real? -2.5+0i)

==> #t

>>> (real? -2.5+0.0i)

==> #f

>>> (real? #e1e10)

==> #t

>>> (rational? 3.5)

==> #t

>>> (rational? 6/10)

==> #t

>>> (rational? 6/3)

==> #t

>>> (integer? 3+0i)

==> #t

>>> (integer? 3.0)

==> #t

>>> (integer? 8/4)

==> #t

; ==========================================================================
; Tower relationships: integer ⊆ rational ⊆ real ⊆ complex ⊆ number
; ==========================================================================

>>> (and (integer? 1) (rational? 1) (real? 1) (complex? 1) (number? 1))

==> #t

>>> (and (integer? 1.0) (rational? 1.0) (real? 1.0) (number? 1.0))

==> #t

>>> (and (rational? 1/3) (real? 1/3) (number? 1/3))

==> #t

>>> (not (integer? 1/3))

==> #t

; ==========================================================================
; exact? and inexact?
; ==========================================================================

>>> (exact? 1)

==> #t

>>> (exact? 0)

==> #t

>>> (exact? 1/2)

==> #t

>>> (exact? -3/4)

==> #t

>>> (exact? 1.0)

==> #f

>>> (exact? 0.0)

==> #f

>>> (exact? 1.5)

==> #f

>>> (inexact? 1.0)

==> #t

>>> (inexact? 0.0)

==> #t

>>> (inexact? 1.5)

==> #t

>>> (inexact? 1)

==> #f

>>> (inexact? 1/2)

==> #f

>>> (exact? +inf.0)

==> #f

>>> (inexact? +inf.0)

==> #t

>>> (exact? +nan.0)

==> #f

>>> (inexact? +nan.0)

==> #t

; ==========================================================================
; exact-integer?
; ==========================================================================

>>> (exact-integer? 1)

==> #t

>>> (exact-integer? 0)

==> #t

>>> (exact-integer? -5)

==> #t

>>> (exact-integer? 1.0)

==> #f

>>> (exact-integer? 1/2)

==> #f

>>> (exact-integer? 2/2)

==> #t

>>> (exact-integer? #t)

==> #f

; ==========================================================================
; exact — conversion from inexact to exact
; ==========================================================================

>>> (exact 1.0)

==> 1

>>> (exact 0.0)

==> 0

>>> (exact 1.5)

==> 3/2

>>> (exact 0.1)

==> 3602879701896397/36028797018963968 or ==> 1/10

>>> (exact 0.25)

==> 1/4

>>> (exact 0.5)

==> 1/2

>>> (exact 1/2)

==> 1/2

>>> (exact 42)

==> 42

>>> (exact? (exact 1.0))

==> #t

; ==========================================================================
; inexact — conversion from exact to inexact
; ==========================================================================

>>> (inexact 1)

==> 1.0

>>> (inexact 0)

==> 0.0

>>> (inexact 1/2)

==> 0.5

>>> (inexact 1/4)

==> 0.25

>>> (inexact 1/3)

==> 0.3333333333333333 or ==> 0.3333333333333334

>>> (inexact 1.5)

==> 1.5

>>> (inexact? (inexact 1))

==> #t

; ==========================================================================
; Special values: +inf.0, -inf.0, +nan.0
; ==========================================================================

>>> +inf.0

==> +inf.0

>>> -inf.0

==> -inf.0

>>> +nan.0

==> +nan.0

>>> (number? +inf.0)

==> #t

>>> (real? +inf.0)

==> #t

>>> (rational? +inf.0)

==> #f

>>> (integer? +inf.0)

==> #f

; ==========================================================================
; finite?, infinite?, nan?
; ==========================================================================

>>> (finite? 1)

==> #t

>>> (finite? 1.0)

==> #t

>>> (finite? +inf.0)

==> #f

>>> (finite? -inf.0)

==> #f

>>> (finite? +nan.0)

==> #f

>>> (infinite? +inf.0)

==> #t

>>> (infinite? -inf.0)

==> #t

>>> (infinite? 1)

==> #f

>>> (infinite? 1.0)

==> #f

>>> (infinite? +nan.0)

==> #f

>>> (nan? +nan.0)

==> #t

>>> (nan? +inf.0)

==> #f

>>> (nan? 1)

==> #f

>>> (nan? 1.0)

==> #f

; ==========================================================================
; Arithmetic with special values
; ==========================================================================

>>> (+ +inf.0 1)

==> +inf.0

>>> (+ -inf.0 1)

==> -inf.0

>>> (+ +inf.0 +inf.0)

==> +inf.0

>>> (+ +inf.0 -inf.0)

==> +nan.0

>>> (* +inf.0 2)

==> +inf.0

>>> (* +inf.0 -1)

==> -inf.0

>>> (* +inf.0 0)

==> +nan.0

>>> (/ 1.0 0.0)

==> +inf.0

>>> (/ -1.0 0.0)

==> -inf.0

>>> (< -inf.0 0 +inf.0)

==> #t

; ==========================================================================
; = — numeric equality
; ==========================================================================

>>> (= 1 1)

==> #t

>>> (= 1 2)

==> #f

>>> (= 1 1.0)

==> #t

>>> (= 1/2 0.5)

==> #t

>>> (= 0 0.0)

==> #t

; Multi-argument =

>>> (= 1 1 1)

==> #t

>>> (= 1 1 2)

==> #f

>>> (= 2 2 2 2)

==> #t

; = with special values

>>> (= +inf.0 +inf.0)

==> #t

>>> (= +nan.0 +nan.0)

==> #f

>>> (= +nan.0 1)

==> #f

; ==========================================================================
; < — strictly less than
; ==========================================================================

>>> (< 1 2)

==> #t

>>> (< 2 1)

==> #f

>>> (< 1 1)

==> #f

>>> (< 1 2 3)

==> #t

>>> (< 1 2 2)

==> #f

>>> (< 1.0 2.0)

==> #t

>>> (< 1/2 3/4)

==> #t

>>> (< -inf.0 0 +inf.0)

==> #t

>>> (< +nan.0 1)

==> #f

; ==========================================================================
; > — strictly greater than
; ==========================================================================

>>> (> 2 1)

==> #t

>>> (> 1 2)

==> #f

>>> (> 3 2 1)

==> #t

>>> (> 3 2 2)

==> #f

; ==========================================================================
; <= and >= — non-strict
; ==========================================================================

>>> (<= 1 1)

==> #t

>>> (<= 1 2)

==> #t

>>> (<= 2 1)

==> #f

>>> (<= 1 1 2)

==> #t

>>> (<= 1 2 2)

==> #t

>>> (<= 1 2 1)

==> #f

>>> (>= 2 2)

==> #t

>>> (>= 2 1)

==> #t

>>> (>= 1 2)

==> #f

>>> (>= 3 2 1)

==> #t

>>> (>= 3 3 1)

==> #t

; ==========================================================================
; zero?, positive?, negative?
; ==========================================================================

>>> (zero? 0)

==> #t

>>> (zero? 0.0)

==> #t

>>> (zero? 1)

==> #f

>>> (zero? -1)

==> #f

>>> (positive? 1)

==> #t

>>> (positive? 0)

==> #f

>>> (positive? -1)

==> #f

>>> (positive? 0.1)

==> #t

>>> (positive? +inf.0)

==> #t

>>> (negative? -1)

==> #t

>>> (negative? 0)

==> #f

>>> (negative? 1)

==> #f

>>> (negative? -0.1)

==> #t

>>> (negative? -inf.0)

==> #t

; ==========================================================================
; odd? and even?
; ==========================================================================

>>> (odd? 1)

==> #t

>>> (odd? 2)

==> #f

>>> (odd? 0)

==> #f

>>> (odd? -1)

==> #t

>>> (odd? -2)

==> #f

>>> (even? 0)

==> #t

>>> (even? 2)

==> #t

>>> (even? 1)

==> #f

>>> (even? -2)

==> #t

>>> (even? -1)

==> #f

; Inexact integers

>>> (odd? 1.0)

==> #t

>>> (even? 2.0)

==> #t

; ==========================================================================
; max and min
; ==========================================================================

>>> (max 1 2 3)

==> 3

>>> (max 3 2 1)

==> 3

>>> (max -1 0 1)

==> 1

>>> (min 1 2 3)

==> 1

>>> (min 3 1 2)

==> 1

>>> (min -1 0 1)

==> -1

; Single argument

>>> (max 5)

==> 5

>>> (min 5)

==> 5

; Bignum arguments stay exact (not collapsed to double); the original exact
; winner is returned.  Contagion still makes the result inexact (below).

>>> (max 5 1267650600228229401496703205376)

==> 1267650600228229401496703205376

>>> (min 5 1267650600228229401496703205376)

==> 5

>>> (max 1267650600228229401496703205376 1267650600228229401496703205377)

==> 1267650600228229401496703205377

>>> (exact? (max 5 1267650600228229401496703205376))

==> #t

>>> (max 5.0 1267650600228229401496703205376)

==> 1.2676506002282294e+30

; Mixed exact/inexact — result is inexact if any arg is inexact

>>> (max 1 2.0)

==> 2.0

>>> (min 1 2.0)

==> 1.0

>>> (max 3 2.5)

==> 3.0

; With +inf.0

>>> (max 1 +inf.0)

==> +inf.0

>>> (min 1 -inf.0)

==> -inf.0

; +nan.0 propagates

>>> (max 1 +nan.0)

==> +nan.0 or ==> 1

>>> (min 1 +nan.0)

==> +nan.0 or ==> 1


; ==========================================================================
; ADDITIONAL R7RS COMPLIANCE TESTS
; ==========================================================================

; === exact-integer? — negative and inexact-whole cases

>>> (exact-integer? -100)

==> #t

>>> (exact-integer? 0)

==> #t

>>> (exact-integer? 3.0)

==> #f

>>> (exact-integer? +inf.0)

==> #f

>>> (exact-integer? +nan.0)

==> #f

; === exact — negative inexact and exactness of result

>>> (exact -2.0)

==> -2

>>> (exact -1.5)

==> -3/2

>>> (exact -0.25)

==> -1/4

>>> (exact-integer? (exact 5.0))

==> #t

; === inexact — idempotent on inexact, exactness of result

>>> (inexact -2)

==> -2.0

>>> (inexact -1/2)

==> -0.5

>>> (inexact? (inexact 1/3))

==> #t

; === Comparison — single argument is always #t
; 6.2.6: these predicates accept any number of args; one arg is trivially true.

>>> (= 5)

==> #t

>>> (< 5)

==> #t

>>> (> 5)

==> #t

>>> (<= 5)

==> #t

>>> (>= 5)

==> #t

; === Comparison — mixed exact/inexact chains

>>> (< 1 1.5 2)

==> #t

>>> (<= 1 1.0 2)

==> #t

>>> (= 1 1.0 1)

==> #t

>>> (> 3 2.5 2)

==> #t

; === Comparison — bignum vs inexact compares exactly (no double collapse)
; A bignum and a nearby inexact that round to the same double must NOT
; compare equal: 2^100+1 differs from the double 2^100.0, even though both
; round to that double.  (Formerly both collapsed to 2^100.0 and = wrongly
; returned #t.)

>>> (= (+ 1 1267650600228229401496703205376) (exact->inexact 1267650600228229401496703205376))

==> #f

>>> (< (exact->inexact 1267650600228229401496703205376) (+ 1 1267650600228229401496703205376))

==> #t

>>> (> (+ 1 1267650600228229401496703205376) (exact->inexact 1267650600228229401496703205376))

==> #t

; An exact value equal to its own inexact image still compares = (2^100 is
; exactly representable as a double).

>>> (= 1267650600228229401496703205376 (exact->inexact 1267650600228229401496703205376))

==> #t

; === = with infinities

>>> (= +inf.0 +inf.0 +inf.0)

==> #t

>>> (= +inf.0 -inf.0)

==> #f

; === Ordering with NaN — all comparisons involving NaN are #f
; 6.2.6: comparisons involving +nan.0 return #f.

>>> (> +nan.0 1)

==> #f

>>> (<= +nan.0 1)

==> #f

>>> (>= +nan.0 1)

==> #f

>>> (< 1 +nan.0)

==> #f

>>> (= 1 +nan.0 1)

==> #f

; === zero? / positive? / negative? on inexact and special values

>>> (zero? -0.0)

==> #t

>>> (zero? +nan.0)

==> #f

>>> (positive? +nan.0)

==> #f

>>> (negative? +nan.0)

==> #f

>>> (negative? -inf.0)

==> #t

>>> (positive? +inf.0)

==> #t

; === odd? / even? — negative inexact integers

>>> (odd? -3.0)

==> #t

>>> (even? -4.0)

==> #t

>>> (odd? 0.0)

==> #f

; === max / min — single inexact argument keeps exactness

>>> (max 2.5)

==> 2.5

>>> (min 2.5)

==> 2.5

; === max / min — all-inexact arguments

>>> (max 1.0 2.0 3.0)

==> 3.0

>>> (min 1.0 2.0 3.0)

==> 1.0

; === max / min — contagion: any inexact arg makes whole result inexact

>>> (inexact? (max 1 2 3.0))

==> #t

>>> (inexact? (min 1.0 2 3))

==> #t

; === max / min with infinities and exact args (contagion to inexact)

>>> (max -5 +inf.0)

==> +inf.0

>>> (min 5 -inf.0)

==> -inf.0

; === rational? on inexact integer is #t (it is a finite rational)

>>> (rational? 5.0)

==> #t

>>> (rational? -2.5)

==> #t
