; Section 6.2 - Numbers (Part c: Rounding, sqrt/expt, Complex, Conversion)
;
; Covers: floor, ceiling, truncate, round, sqrt, expt, rationalize,
; make-rectangular, make-polar, real-part, imag-part, magnitude, angle,
; number->string, string->number

; ==========================================================================
; floor — largest integer not larger than x
; ==========================================================================

>>> (floor 3.5)

==> 3.0

>>> (floor 3.0)

==> 3.0

>>> (floor -3.5)

==> -4.0

>>> (floor -3.0)

==> -3.0

>>> (floor 0.0)

==> 0.0

>>> (floor 0.9)

==> 0.0

>>> (floor -0.9)

==> -1.0

; Exact input → exact output

>>> (floor 7/2)

==> 3

>>> (floor -7/2)

==> -4

>>> (floor 3)

==> 3

>>> (exact? (floor 7/2))

==> #t

>>> (inexact? (floor 3.5))

==> #t

; A bignum is already an integer, so floor/ceiling/truncate/round return it
; unchanged and exact (formerly degraded to double through the NumAny path)

>>> (floor 1267650600228229401496703205376)

==> 1267650600228229401496703205376

>>> (ceiling -1267650600228229401496703205376)

==> -1267650600228229401496703205376

>>> (truncate 1267650600228229401496703205376)

==> 1267650600228229401496703205376

>>> (round -1267650600228229401496703205376)

==> -1267650600228229401496703205376

>>> (exact? (round 1267650600228229401496703205376))

==> #t

; ==========================================================================
; ceiling — smallest integer not smaller than x
; ==========================================================================

>>> (ceiling 3.5)

==> 4.0

>>> (ceiling 3.0)

==> 3.0

>>> (ceiling -3.5)

==> -3.0

>>> (ceiling -3.0)

==> -3.0

>>> (ceiling 0.1)

==> 1.0

>>> (ceiling -0.1)

==> 0.0

>>> (ceiling 7/2)

==> 4

>>> (ceiling -7/2)

==> -3

>>> (exact? (ceiling 7/2))

==> #t

; ==========================================================================
; truncate — integer part (towards zero)
; ==========================================================================

>>> (truncate 3.7)

==> 3.0

>>> (truncate -3.7)

==> -3.0

>>> (truncate 3.0)

==> 3.0

>>> (truncate -3.0)

==> -3.0

>>> (truncate 0.9)

==> 0.0

>>> (truncate -0.9)

==> 0.0

>>> (truncate 7/2)

==> 3

>>> (truncate -7/2)

==> -3

>>> (exact? (truncate 7/2))

==> #t

; ==========================================================================
; round — nearest integer, ties to even (banker's rounding)
; ==========================================================================

>>> (round 3.5)

==> 4.0

>>> (round 4.5)

==> 4.0

>>> (round 2.5)

==> 2.0

>>> (round 1.5)

==> 2.0

>>> (round 0.5)

==> 0.0

>>> (round -0.5)

==> 0.0

>>> (round -1.5)

==> -2.0

>>> (round -2.5)

==> -2.0

>>> (round 3.4)

==> 3.0

>>> (round 3.6)

==> 4.0

>>> (round 0.0)

==> 0.0

; Exact input → exact output

>>> (round 7/2)

==> 4

>>> (round 5/2)

==> 2

>>> (round 3/2)

==> 2

>>> (round 1/2)

==> 0

>>> (round 3)

==> 3

>>> (exact? (round 7/2))

==> #t

; ==========================================================================
; Rounding comparison summary
; ==========================================================================

>>> (list (floor 2.3) (ceiling 2.3) (truncate 2.3) (round 2.3))

==> (2.0 3.0 2.0 2.0)

>>> (list (floor -2.3) (ceiling -2.3) (truncate -2.3) (round -2.3))

==> (-3.0 -2.0 -2.0 -2.0)

>>> (list (floor 2.7) (ceiling 2.7) (truncate 2.7) (round 2.7))

==> (2.0 3.0 2.0 3.0)

>>> (list (floor -2.7) (ceiling -2.7) (truncate -2.7) (round -2.7))

==> (-3.0 -2.0 -2.0 -3.0)

; ==========================================================================
; sqrt
; ==========================================================================

>>> (sqrt 4)

==> 2 or ==> 2.0

>>> (sqrt 2)

==> 1.4142135623730951 or ==> 1.4142135623730950

>>> (sqrt 9)

==> 3 or ==> 3.0

>>> (sqrt 0)

==> 0 or ==> 0.0

>>> (sqrt 1)

==> 1 or ==> 1.0

>>> (sqrt 2.0)

==> 1.4142135623730951 or ==> 1.4142135623730950

>>> (sqrt 4.0)

==> 2.0

; Exact perfect squares may return exact result

>>> (exact? (sqrt 4))

==> #t or ==> #f

>>> (inexact? (sqrt 2.0))

==> #t

; sqrt of negative number — result may be a complex number or an error

>>> (real? (sqrt -1))

==> #f or ==> #t

; ==========================================================================
; expt
; ==========================================================================

>>> (expt 2 0)

==> 1

>>> (expt 2 1)

==> 2

>>> (expt 2 10)

==> 1024

>>> (expt 2 32)

==> 4294967296

>>> (expt 3 3)

==> 27

>>> (expt 1/2 3)

==> 1/8

>>> (expt 2.0 3)

==> 8.0

>>> (expt 2 -1)

==> 1/2

>>> (expt 2 -2)

==> 1/4

>>> (expt 0 0)

==> 1

>>> (expt 0 1)

==> 0

>>> (expt -1 2)

==> 1

>>> (expt -1 3)

==> -1

; Large exact exponentiation

>>> (expt 2 64)

==> 18446744073709551616

>>> (exact? (expt 2 64))

==> #t

; Inexact base or exponent

>>> (inexact? (expt 2.0 3))

==> #t

>>> (expt 4.0 0.5)

==> 2.0

; ==========================================================================
; rationalize — best rational approximation within tolerance
; ==========================================================================

; simplest rational within 1/10 of (exact .1); Chez yields 1/5.
>>> (rationalize (exact .1) 1/10)

==> 1/5

; The result is the simplest rational within 1/10 of (exact 0.1).

>>> (rationalize 0 1/10)

==> 0

>>> (rationalize 1/4 1/100)

==> 1/4

; ==========================================================================
; Complex number procedures (from scheme inexact / scheme complex)
; ==========================================================================

; make-rectangular: creates a+bi

>>> (real-part (make-rectangular 3 4))

==> 3

>>> (imag-part (make-rectangular 3 4))

==> 4

>>> (real-part 5)

==> 5

>>> (imag-part 5)

==> 0

>>> (real-part 3.0)

==> 3.0

>>> (imag-part 3.0)

==> 0 or ==> 0.0

; magnitude: absolute value (for real numbers, same as abs)

>>> (magnitude 3)

==> 3 or ==> 3.0

>>> (magnitude -3)

==> 3 or ==> 3.0

>>> (magnitude 3.0)

==> 3.0

>>> (< (abs (- (magnitude (make-rectangular 3 4)) 5.0)) 1e-10)

==> #t

; angle: argument of complex number (for positive reals: 0)

>>> (angle 1)

==> 0 or ==> 0.0

>>> (angle -1)

==> 3.141592653589793 or ==> 3.14159265358979

; make-polar: r * e^(i*theta)

>>> (< (abs (- (real-part (make-polar 1.0 0.0)) 1.0)) 1e-10)

==> #t

>>> (< (abs (imag-part (make-polar 1.0 0.0))) 1e-10)

==> #t

; ==========================================================================
; number->string
; ==========================================================================

>>> (number->string 10)

==> "10"

>>> (number->string 0)

==> "0"

>>> (number->string -5)

==> "-5"

>>> (number->string 1/3)

==> "1/3"

>>> (number->string 1.5)

==> "1.5"

; With radix

>>> (number->string 10 2)

==> "1010"

>>> (number->string 10 8)

==> "12"

>>> (number->string 10 16)

==> "a"

>>> (number->string 255 16)

==> "ff"

>>> (number->string 8 2)

==> "1000"

>>> (number->string 0 2)

==> "0"

>>> (number->string 16 16)

==> "10"

; Special values

>>> (number->string +inf.0)

==> "+inf.0"

>>> (number->string -inf.0)

==> "-inf.0"

>>> (number->string +nan.0)

==> "+nan.0"

; ==========================================================================
; string->number
; ==========================================================================

>>> (string->number "10")

==> 10

>>> (string->number "0")

==> 0

>>> (string->number "-5")

==> -5

>>> (string->number "1/3")

==> 1/3

>>> (string->number "1.5")

==> 1.5

>>> (string->number "3.14")

==> 3.14

; With radix

>>> (string->number "1010" 2)

==> 10

>>> (string->number "12" 8)

==> 10

>>> (string->number "a" 16)

==> 10

>>> (string->number "ff" 16)

==> 255

>>> (string->number "FF" 16)

==> 255

>>> (string->number "1000" 2)

==> 8

; With prefix notation

>>> (string->number "#b1010")

==> 10

>>> (string->number "#o12")

==> 10

>>> (string->number "#xff")

==> 255

>>> (string->number "#d10")

==> 10

; Exactness prefix

>>> (string->number "#e1.5")

==> 3/2

>>> (string->number "#i3")

==> 3.0

; Returns #f for invalid input

>>> (string->number "hello")

==> #f

>>> (string->number "")

==> #f

>>> (string->number "1.2.3")

==> #f

; "10" parsed in base 2 is 2 (Chez agrees).
>>> (string->number "10" 2)

==> 2

>>> (string->number "xyz" 16)

==> #f

; Special values

>>> (string->number "+inf.0")

==> +inf.0

>>> (string->number "-inf.0")

==> -inf.0

>>> (string->number "+nan.0")

==> +nan.0

; ==========================================================================
; number->string / string->number roundtrip
; ==========================================================================

>>> (= 255 (string->number (number->string 255 16) 16))

==> #t

>>> (= 42 (string->number (number->string 42 2) 2))

==> #t

>>> (string=? "1/3" (number->string (string->number "1/3")))

==> #t

; ==========================================================================
; Exact large integer arithmetic
; ==========================================================================

>>> (expt 10 20)

==> 100000000000000000000

>>> (+ (expt 2 100) (expt 2 100))

==> 2535301200456458802993406410752

>>> (* (expt 10 10) (expt 10 10))

==> 100000000000000000000

>>> (exact? (expt 10 20))

==> #t

; ==========================================================================
; Exactness preservation
; ==========================================================================

; Operations on exact numbers produce exact results

>>> (exact? (+ 1/3 1/6))

==> #t

>>> (+ 1/3 1/6)

==> 1/2

>>> (exact? (* 7 1/7))

==> #t

>>> (* 7 1/7)

==> 1


; ==========================================================================
; ADDITIONAL R7RS COMPLIANCE TESTS
; ==========================================================================

; === exact-integer-sqrt — returns s and r with k = s*s + r, k < (s+1)^2
; R7RS 6.2.6.

>>> (call-with-values (lambda () (exact-integer-sqrt 4)) list)

==> (2 0)

>>> (call-with-values (lambda () (exact-integer-sqrt 5)) list)

==> (2 1)

>>> (call-with-values (lambda () (exact-integer-sqrt 0)) list)

==> (0 0)

>>> (call-with-values (lambda () (exact-integer-sqrt 1)) list)

==> (1 0)

>>> (call-with-values (lambda () (exact-integer-sqrt 8)) list)

==> (2 4)

>>> (call-with-values (lambda () (exact-integer-sqrt 9)) list)

==> (3 0)

>>> (call-with-values (lambda () (exact-integer-sqrt 15)) list)

==> (3 6)

>>> (call-with-values (lambda () (exact-integer-sqrt 16)) list)

==> (4 0)

; both results exact
>>> (call-with-values
...   (lambda () (exact-integer-sqrt 17))
...   (lambda (s r) (and (exact-integer? s) (exact-integer? r))))

==> #t

; reconstruction identity for a non-perfect-square
>>> (call-with-values
...   (lambda () (exact-integer-sqrt 32))
...   (lambda (s r) (= 32 (+ (* s s) r))))

==> #t

; === floor / ceiling / truncate / round — exact integer is identity (exact)

>>> (floor 5)

==> 5

>>> (ceiling 5)

==> 5

>>> (truncate 5)

==> 5

>>> (round 5)

==> 5

>>> (floor -5)

==> -5

>>> (round -5)

==> -5

>>> (exact? (round 5))

==> #t

; === round — exact rational ties to even

>>> (round -3/2)

==> -2

>>> (round -5/2)

==> -2

>>> (round 7/3)

==> 2

>>> (round 8/3)

==> 3

; === expt — identities

>>> (expt 5 0)

==> 1

>>> (expt 0 5)

==> 0

>>> (expt 1 100)

==> 1

>>> (expt 10 3)

==> 1000

>>> (expt -2 3)

==> -8

>>> (expt -2 4)

==> 16

; negative exact fractional base, integer exponent

>>> (expt 2/3 2)

==> 4/9

>>> (expt -1/2 3)

==> -1/8

>>> (expt 3 -2)

==> 1/9

; === sqrt — exact perfect square of larger value

>>> (sqrt 16)

==> 4 or ==> 4.0

>>> (sqrt 100)

==> 10 or ==> 10.0

>>> (sqrt 144)

==> 12 or ==> 12.0

; === square / sqrt round trip on inexact

>>> (< (abs (- (sqrt (square 7.0)) 7.0)) 1e-10)

==> #t

; === exp / log inverse relationship (tolerance-based; digits impl-dependent)

>>> (< (abs (- (log (exp 1.0)) 1.0)) 1e-10)

==> #t

>>> (< (abs (- (exp 0.0) 1.0)) 1e-10)

==> #t

>>> (< (abs (- (log 1.0) 0.0)) 1e-10)

==> #t

; two-argument log: (log z1 z2) is log base z2

>>> (< (abs (- (log 8 2) 3.0)) 1e-10)

==> #t

>>> (< (abs (- (log 100 10) 2.0)) 1e-10)

==> #t

; === trig identities (tolerance-based)

>>> (< (abs (- (sin 0.0) 0.0)) 1e-10)

==> #t

>>> (< (abs (- (cos 0.0) 1.0)) 1e-10)

==> #t

>>> (< (abs (- (tan 0.0) 0.0)) 1e-10)

==> #t

>>> (< (abs (- (atan 0.0) 0.0)) 1e-10)

==> #t

; sin^2 + cos^2 = 1
>>> (< (abs (- (+ (square (sin 1.0)) (square (cos 1.0))) 1.0)) 1e-10)

==> #t

; asin/sin and acos/cos inverse on a value in range
>>> (< (abs (- (asin (sin 0.5)) 0.5)) 1e-10)

==> #t

>>> (< (abs (- (acos (cos 0.5)) 0.5)) 1e-10)

==> #t

; two-argument atan
>>> (< (abs (- (atan 1.0 1.0) 0.7853981633974483)) 1e-10)

==> #t

; === number->string — negatives, fractions, radix edge cases

>>> (number->string -10)

==> "-10"

>>> (number->string -1/3)

==> "-1/3"

>>> (number->string 1 2)

==> "1"

>>> (number->string 7 2)

==> "111"

>>> (number->string -255 16)

==> "-ff"

>>> (number->string 100 10)

==> "100"

; === string->number — leading plus, fractions, negatives

>>> (string->number "+5")

==> 5

>>> (string->number "+1/2")

==> 1/2

>>> (string->number "-1/2")

==> -1/2

>>> (string->number "-3.5")

==> -3.5

; whitespace / garbage → #f

>>> (string->number " 5")

==> #f or ==> 5

>>> (string->number "5x")

==> #f

>>> (string->number "+")

==> #f

; === string->number — exactness prefixes combined with radix prefix

>>> (string->number "#e#xff")

==> 255

>>> (string->number "#x#eff")

==> 255

>>> (string->number "#i#b1010")

==> 10.0

>>> (exact? (string->number "#e1.0"))

==> #t

>>> (inexact? (string->number "#i10"))

==> #t

; === number->string / string->number radix round trips

>>> (= 255 (string->number (number->string 255 2) 2))

==> #t

>>> (= 4095 (string->number (number->string 4095 16) 16))

==> #t

>>> (= -100 (string->number (number->string -100 8) 8))

==> #t

; === rationalize — exactness preserved; inexact arg gives inexact result

>>> (exact? (rationalize 1/4 1/100))

==> #t

>>> (rationalize 3/10 1/10)

==> 1/3 or ==> 1/4

>>> (inexact? (rationalize 0.3 1/10))

==> #t
; ==========================================================================
; R7RS section 6.2.6 -- worked examples from the standard (Chibi-verified).
; ==========================================================================

>>> (floor -4.3)

==> -5.0

>>> (ceiling -4.3)

==> -4.0

>>> (truncate -4.3)

==> -4.0

>>> (round -4.3)

==> -4.0

>>> (round 7)

==> 7

>>> (square 42)

==> 1764

>>> (square 2.0)

==> 4.0

>>> (rationalize (exact .3) 1/10)

==> 1/3

>>> (string->number "100")

==> 100

>>> (string->number "100" 16)

==> 256

>>> (string->number "1e2")

==> 100.0

