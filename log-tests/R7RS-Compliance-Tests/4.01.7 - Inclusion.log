; Section 4.1.7 - Inclusion
;
; (include <string1> <string2> ...)
; (include-ci <string1> <string2> ...)
;
; include: reads and evaluates each named file in order, as if the file
; contents were wrapped in a begin form.  Filenames are relative to the
; directory of the file containing the include expression (or to the
; current directory at top level).  Returns the value of the last
; expression in the last file.
;
; include-ci: same as include but reads each file with case-folding
; enabled (as if #!fold-case were in effect for the entire file).
;
; Note: the test runner must set CWD to the directory containing this
; file so that relative paths ("4.1.7-aux1.scm" etc.) resolve correctly.

; Auxiliary files used by these tests:
;
;   4.1.7-aux1.scm  — defines included-var, included-double, included-list
;   4.1.7-aux2.scm  — defines aux2-var, aux2-sum, aux2-greeting
;   4.1.7-aux-ci.scm — defines MixedCase-Value, UPPERCASE-PROC, CamelCaseList

; ==========================================================================
; include — basic: definitions from included file become visible
; ==========================================================================

>>> (include "4.1.7-aux1.scm")

>>> included-var

==> 42

>>> (included-double 6)

==> 12

>>> included-list

==> (a b c)

; ==========================================================================
; include — second file: independent set of bindings
; ==========================================================================

>>> (include "4.1.7-aux2.scm")

>>> aux2-var

==> 99

>>> (aux2-sum 1 2 3 4 5)

==> 15

>>> aux2-greeting

==> "hello from aux2"

; ==========================================================================
; include — multiple files in one form (evaluated in order)
; ==========================================================================

; Both sets of definitions are available after a single include form
; that lists both files.

>>> (include "4.1.7-aux1.scm" "4.1.7-aux2.scm")

>>> included-var

==> 42

>>> aux2-var

==> 99

; ==========================================================================
; include — return value is last expression of last file
; ==========================================================================

; aux1 ends with: (define included-list '(a b c))
; The return value of include is implementation-defined (commonly unspecified),
; but the definitions take effect regardless.

>>> (define _ignored (include "4.1.7-aux1.scm"))

>>> included-var

==> 42

; ==========================================================================
; include inside a body (lambda)
; ==========================================================================

>>> (define (load-and-use)
...   (include "4.1.7-aux1.scm")
...   (included-double included-var))

>>> (load-and-use)

==> 84

; ==========================================================================
; include inside a let body
; ==========================================================================

>>> (let ()
...   (include "4.1.7-aux1.scm")
...   included-var)

==> 42

; ==========================================================================
; include inside a begin form
; ==========================================================================

>>> (begin
...   (include "4.1.7-aux1.scm")
...   (included-double 10))

==> 20

; ==========================================================================
; include — definitions are spliced, not scoped
; ==========================================================================

; Definitions from include at top level are top-level definitions.

>>> (include "4.1.7-aux1.scm")

>>> (procedure? included-double)

==> #t

>>> (list? included-list)

==> #t

; ==========================================================================
; include — files evaluated in left-to-right order
; ==========================================================================

; We verify ordering: aux1 defines included-var=42, aux2 defines aux2-var=99.
; After including both, both names are bound.

>>> (include "4.1.7-aux1.scm" "4.1.7-aux2.scm")

>>> (+ included-var aux2-var)

==> 141

; ==========================================================================
; include-ci — case-folding applies to the included file
; ==========================================================================

; aux-ci defines MixedCase-Value, UPPERCASE-PROC, CamelCaseList
; With include-ci, all identifiers in the file are folded to lowercase,
; so they become: mixedcase-value, uppercase-proc, camelcaselist

>>> (include-ci "4.1.7-aux-ci.scm")

>>> mixedcase-value

==> 7

>>> (uppercase-proc 4)

==> 12

>>> camelcaselist

==> (alpha beta gamma)

; The mixed-case names defined with include-ci are not accessible under
; their original mixed-case spelling in a case-sensitive environment.

>>> MixedCase-Value

%%% %any-error%

; ==========================================================================
; include-ci — folding applies to symbols in data (quoted) as well
; ==========================================================================

; CamelCaseList is '(Alpha Beta Gamma); after ci-folding the symbols
; in the list become lowercase: (alpha beta gamma)

>>> (eq? (car camelcaselist) 'alpha)

==> #t

>>> (eq? (cadr camelcaselist) 'beta)

==> #t

; ==========================================================================
; Error: including a non-existent file
; ==========================================================================

>>> (include "4.1.7-nonexistent.scm")

%%% %any-error%



; ==========================================================================
; ADDITIONAL R7RS COMPLIANCE TESTS
; ==========================================================================

; ===
; include is effectively a begin of the file contents: re-including a file
; re-runs its definitions, leaving the same bindings in effect
; ===

>>> (include "4.1.7-aux1.scm")

>>> (set! included-var 0)

>>> included-var

==> 0

>>> (include "4.1.7-aux1.scm")

>>> included-var

==> 42

; ===
; A procedure defined in an included file behaves like any other procedure
; and can be passed to higher-order procedures
; ===

>>> (include "4.1.7-aux1.scm")

>>> (map included-double '(1 2 3 4))

==> (2 4 6 8)

; ===
; include inside a lambda body splices the file's definitions into that
; body (letrec* region); they are visible to following body expressions
; ===

>>> (define (use-aux2)
...   (include "4.1.7-aux2.scm")
...   (aux2-sum 10 20 30))

>>> (use-aux2)

==> 60

; ===
; A single include form listing two files makes all definitions from both
; available, evaluated left to right
; ===

>>> (include "4.1.7-aux1.scm" "4.1.7-aux2.scm")

>>> (list included-var aux2-var)

==> (42 99)

>>> (included-double (aux2-sum 1 2 3))

==> 12

; ===
; include-ci folds identifiers to lowercase; the folded names are bound and
; the folded symbol in quoted data is eqv? to the lowercase symbol
; ===

>>> (include-ci "4.1.7-aux-ci.scm")

>>> (eqv? (caddr camelcaselist) 'gamma)

==> #t

>>> (map (lambda (x) x) camelcaselist)

==> (alpha beta gamma)

>>> (uppercase-proc 5)

==> 15

; ===
; "include does not" fold case: a plain include of the same file that
; include-ci folds preserves the original mixed-case identifiers AND the
; mixed-case symbols in quoted data (R7RS 4.1.7).
; ===

>>> (include "4.1.7-aux-ci.scm")

>>> MixedCase-Value

==> 7

>>> (UPPERCASE-PROC 2)

==> 6

>>> CamelCaseList

==> (Alpha Beta Gamma)

; With plain include the symbols in the quoted list keep their original case,
; so they are NOT eq? to the lowercase-folded symbols.

>>> (eq? (car CamelCaseList) 'Alpha)

==> #t

>>> (eq? (car CamelCaseList) 'alpha)

==> #f

; ===
; The #!fold-case effect of include-ci is confined to the file it reads;
; it does not persist to a later plain include in the same session, and a
; plain include never folds an identifier's case (the uppercased spelling of
; a lowercase definition stays unbound).
; ===

>>> (include-ci "4.1.7-aux-ci.scm")

>>> (include "4.1.7-aux1.scm")

>>> included-var

==> 42

>>> INCLUDED-VAR

%%% %any-error%
