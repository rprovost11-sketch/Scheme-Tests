; Section 6.9 - Bytevectors
;
; Bytevectors are mutable, fixed-length sequences of exact integers
; in the range 0–255 (bytes).  Written as #u8(byte ...).
;
; (bytevector? obj)
; (make-bytevector k)         — k bytes, all zero
; (make-bytevector k byte)    — k copies of byte
; (bytevector byte ...)       — bytevector from byte arguments
; (bytevector-length bv)      — number of bytes
; (bytevector-u8-ref bv k)    — byte at index k (0–255)
; (bytevector-u8-set! bv k b) — set byte at index k
; (bytevector-copy bv)
; (bytevector-copy bv start)
; (bytevector-copy bv start end)
; (bytevector-copy! to at from)
; (bytevector-copy! to at from start end)
; (bytevector-append bv ...)
; (utf8->string bv)
; (utf8->string bv start)
; (utf8->string bv start end)
; (string->utf8 str)
; (string->utf8 str start)
; (string->utf8 str start end)

; ==========================================================================
; bytevector? — true only for bytevectors
; ==========================================================================

>>> (bytevector? #u8(1 2 3))

==> #t

>>> (bytevector? #u8())

==> #t

>>> (bytevector? (make-bytevector 3))

==> #t

>>> (bytevector? '(1 2 3))

==> #f

>>> (bytevector? #(1 2 3))

==> #f

>>> (bytevector? "hello")

==> #f

>>> (bytevector? 42)

==> #f

>>> (bytevector? #t)

==> #f

; ==========================================================================
; make-bytevector
; ==========================================================================

>>> (make-bytevector 0)

==> #u8()

>>> (bytevector-length (make-bytevector 0))

==> 0

>>> (bytevector-length (make-bytevector 5))

==> 5

; Default fill is 0

>>> (make-bytevector 3)

==> #u8(0 0 0)

>>> (make-bytevector 4 0)

==> #u8(0 0 0 0)

>>> (make-bytevector 3 255)

==> #u8(255 255 255)

>>> (make-bytevector 4 42)

==> #u8(42 42 42 42)

>>> (make-bytevector 1 128)

==> #u8(128)

; ==========================================================================
; bytevector — from arguments
; ==========================================================================

>>> (bytevector)

==> #u8()

>>> (bytevector 0)

==> #u8(0)

>>> (bytevector 1 2 3)

==> #u8(1 2 3)

>>> (bytevector 0 127 255)

==> #u8(0 127 255)

>>> (bytevector 72 101 108 108 111)

==> #u8(72 101 108 108 111)

; All valid byte values

>>> (bytevector 0 1 254 255)

==> #u8(0 1 254 255)

; Error: value out of byte range

>>> (bytevector 256)

%%% %any-error%

>>> (bytevector -1)

%%% %any-error%

>>> (bytevector 1 2 300)

%%% %any-error%

; ==========================================================================
; bytevector-length
; ==========================================================================

>>> (bytevector-length #u8())

==> 0

>>> (bytevector-length #u8(1))

==> 1

>>> (bytevector-length #u8(1 2 3))

==> 3

>>> (bytevector-length (make-bytevector 100))

==> 100

; ==========================================================================
; bytevector-u8-ref — byte at index
; ==========================================================================

>>> (bytevector-u8-ref #u8(1 2 3) 0)

==> 1

>>> (bytevector-u8-ref #u8(1 2 3) 1)

==> 2

>>> (bytevector-u8-ref #u8(1 2 3) 2)

==> 3

>>> (bytevector-u8-ref #u8(0 127 255) 2)

==> 255

>>> (bytevector-u8-ref #u8(72 101 108) 0)

==> 72

; Result is always an exact integer

>>> (exact? (bytevector-u8-ref #u8(1 2 3) 0))

==> #t

; Error: out of range

>>> (bytevector-u8-ref #u8(1 2 3) 3)

%%% %any-error%

>>> (bytevector-u8-ref #u8(1 2 3) -1)

%%% %any-error%

>>> (bytevector-u8-ref #u8() 0)

%%% %any-error%

; ==========================================================================
; bytevector-u8-set! — mutate a byte
; ==========================================================================

>>> (define bv (bytevector 1 2 3))

>>> (bytevector-u8-set! bv 0 99)

>>> bv

==> #u8(99 2 3)

>>> (bytevector-u8-set! bv 2 255)

>>> bv

==> #u8(99 2 255)

>>> (define bv2 (make-bytevector 5 0))

>>> (bytevector-u8-set! bv2 2 128)

>>> bv2

==> #u8(0 0 128 0 0)

; Error: byte value out of range

>>> (bytevector-u8-set! (make-bytevector 3) 0 256)

%%% %any-error%

>>> (bytevector-u8-set! (make-bytevector 3) 0 -1)

%%% %any-error%

; Error: index out of range

>>> (bytevector-u8-set! (make-bytevector 3) 3 0)

%%% %any-error%

; ==========================================================================
; bytevector-copy
; ==========================================================================

>>> (define bv-orig #u8(1 2 3 4 5))

>>> (define bv-copy (bytevector-copy bv-orig))

>>> (equal? bv-orig bv-copy)

==> #t

>>> (eq? bv-orig bv-copy)

==> #f

; With start

>>> (bytevector-copy #u8(1 2 3 4 5) 2)

==> #u8(3 4 5)

>>> (bytevector-copy #u8(1 2 3 4 5) 0)

==> #u8(1 2 3 4 5)

>>> (bytevector-copy #u8(1 2 3 4 5) 5)

==> #u8()

; With start and end

>>> (bytevector-copy #u8(1 2 3 4 5) 1 4)

==> #u8(2 3 4)

>>> (bytevector-copy #u8(1 2 3 4 5) 2 2)

==> #u8()

>>> (bytevector-copy #u8(1 2 3 4 5) 0 3)

==> #u8(1 2 3)

; ==========================================================================
; bytevector-copy! — copy into a target bytevector
; ==========================================================================

>>> (define bvt (make-bytevector 5 0))

>>> (bytevector-copy! bvt 1 #u8(10 20 30))

>>> bvt

==> #u8(0 10 20 30 0)

>>> (define bvt2 (make-bytevector 5 0))

>>> (bytevector-copy! bvt2 0 #u8(1 2 3 4 5))

>>> bvt2

==> #u8(1 2 3 4 5)

>>> (define bvt3 (make-bytevector 5 0))

>>> (bytevector-copy! bvt3 2 #u8(10 20 30 40 50) 1 3)

>>> bvt3

==> #u8(0 0 20 30 0)

; Overlapping copy (same bytevector, moving data right)

>>> (define bvt4 (bytevector 1 2 3 4 5))

>>> (bytevector-copy! bvt4 1 bvt4 0 4)

>>> bvt4

==> #u8(1 1 2 3 4)

; ==========================================================================
; bytevector-append
; ==========================================================================

>>> (bytevector-append #u8(1 2) #u8(3 4))

==> #u8(1 2 3 4)

>>> (bytevector-append #u8(1) #u8(2) #u8(3))

==> #u8(1 2 3)

>>> (bytevector-append #u8() #u8(1 2))

==> #u8(1 2)

>>> (bytevector-append #u8(1 2) #u8())

==> #u8(1 2)

>>> (bytevector-append)

==> #u8()

>>> (bytevector-append #u8(0 127 255) #u8(1 2 3))

==> #u8(0 127 255 1 2 3)

; ==========================================================================
; utf8->string — decode UTF-8 bytes to string
; ==========================================================================

>>> (utf8->string #u8(104 101 108 108 111))

==> "hello"

>>> (utf8->string #u8(72 105))

==> "Hi"

>>> (utf8->string #u8())

==> ""

>>> (utf8->string #u8(65 66 67))

==> "ABC"

; With start

>>> (utf8->string #u8(104 101 108 108 111) 1)

==> "ello"

>>> (utf8->string #u8(104 101 108 108 111) 4)

==> "o"

; With start and end

>>> (utf8->string #u8(104 101 108 108 111) 1 4)

==> "ell"

>>> (utf8->string #u8(104 101 108 108 111) 0 0)

==> ""

; ==========================================================================
; string->utf8 — encode string to UTF-8 bytes
; ==========================================================================

>>> (string->utf8 "hello")

==> #u8(104 101 108 108 111)

>>> (string->utf8 "Hi")

==> #u8(72 105)

>>> (string->utf8 "")

==> #u8()

>>> (string->utf8 "ABC")

==> #u8(65 66 67)

; With start

>>> (string->utf8 "hello" 1)

==> #u8(101 108 108 111)

>>> (string->utf8 "hello" 4)

==> #u8(111)

; With start and end

>>> (string->utf8 "hello" 1 4)

==> #u8(101 108 108)

>>> (string->utf8 "hello" 0 0)

==> #u8()

; ==========================================================================
; utf8->string / string->utf8 roundtrip
; ==========================================================================

>>> (string=? "hello" (utf8->string (string->utf8 "hello")))

==> #t

>>> (string=? "" (utf8->string (string->utf8 "")))

==> #t

>>> (string=? "ABC" (utf8->string (string->utf8 "ABC")))

==> #t

>>> (equal? #u8(104 101 108 108 111)
...          (string->utf8 (utf8->string #u8(104 101 108 108 111))))

==> #t

; ==========================================================================
; Bytevector mutation affects the same object
; ==========================================================================

>>> (define bv-shared (make-bytevector 3 0))

>>> (define bv-alias bv-shared)

>>> (bytevector-u8-set! bv-shared 1 42)

>>> (bytevector-u8-ref bv-alias 1)

==> 42

; ==========================================================================
; Bytevector literal — self-evaluating
; ==========================================================================

>>> #u8(1 2 3)

==> #u8(1 2 3)

>>> #u8()

==> #u8()

>>> #u8(0 128 255)

==> #u8(0 128 255)

; ==========================================================================
; Bytevectors in data structures
; ==========================================================================

>>> (list #u8(1 2) #u8(3 4))

==> (#u8(1 2) #u8(3 4))

>>> (vector #u8(10 20) #u8(30 40))

==> #(#u8(10 20) #u8(30 40))

>>> (equal? #u8(1 2 3) #u8(1 2 3))

==> #t

>>> (equal? #u8(1 2 3) #u8(1 2 4))

==> #f

; ==========================================================================
; Byte range enforcement
; ==========================================================================

; All bytes in #u8(...) literal must be 0–255

>>> #u8(0)

==> #u8(0)

>>> #u8(255)

==> #u8(255)

>>> #u8(256)

%%% %any-error%

>>> #u8(-1)

%%% %any-error%

>>> #u8(1.5)

%%% %any-error%

>>> #u8(1/2)

%%% %any-error%

; ==========================================================================
; make-bytevector with out-of-range fill
; ==========================================================================

>>> (make-bytevector 3 256)

%%% %any-error%

>>> (make-bytevector 3 -1)

%%% %any-error%

; ==========================================================================
; ADDITIONAL R7RS COMPLIANCE TESTS
; ==========================================================================

; === bytevector-copy! — overlapping, source AFTER destination (move left) ===
; The existing file covers moving data right; this covers moving left.
; Spec: copying takes place as if source is first copied to a temporary.

>>> (define bvl (bytevector 1 2 3 4 5))

>>> (bytevector-copy! bvl 0 bvl 1 5)

>>> bvl

==> #u8(2 3 4 5 5)

; === bytevector-copy! — spec example ===

>>> (define bcb-a (bytevector 1 2 3 4 5))

>>> (define bcb-b (bytevector 10 20 30 40 50))

>>> (bytevector-copy! bcb-b 1 bcb-a 0 2)

>>> bcb-b

==> #u8(10 1 2 40 50)

; === bytevector-copy! — error: at out of range ===

>>> (bytevector-copy! (make-bytevector 3 0) 4 #u8(1))

%%% %any-error%

>>> (bytevector-copy! (make-bytevector 3 0) -1 #u8(1))

%%% %any-error%

; === bytevector-copy! — error: source too large for destination space ===

>>> (bytevector-copy! (make-bytevector 3 0) 1 #u8(1 2 3))

%%% %any-error%

; === Type errors — non-bytevector arguments ===

>>> (bytevector-length #(1 2 3))

%%% %any-error%

>>> (bytevector-u8-ref '(1 2 3) 0)

%%% %any-error%

>>> (bytevector-u8-set! "abc" 0 65)

%%% %any-error%

>>> (bytevector-append #u8(1 2) #(3 4))

%%% %any-error%

>>> (bytevector-copy #(1 2 3))

%%% %any-error%

; === bytevector-copy — error: invalid range ===

>>> (bytevector-copy #u8(1 2 3) 2 1)

%%% %any-error%

>>> (bytevector-copy #u8(1 2 3) 0 4)

%%% %any-error%

; === string->utf8 — multibyte (non-ASCII) encoding ===
; U+00E9 (e with acute) encodes as two bytes 195 169 in UTF-8.

>>> (string->utf8 "\xe9;")

==> #u8(195 169)

>>> (bytevector-length (string->utf8 "\xe9;"))

==> 2

; === utf8->string — decode multibyte back ===

>>> (utf8->string #u8(195 169))

==> "é"

>>> (string=? "\xe9;" (utf8->string (string->utf8 "\xe9;")))

==> #t

; === string->utf8 — partial range over a multibyte string ===
; "aé" is two characters; index 1 selects only the é (2 bytes).

>>> (string->utf8 "a\xe9;" 1)

==> #u8(195 169)

>>> (string->utf8 "a\xe9;" 0 1)

==> #u8(97)

; === utf8->string — type error on non-bytevector ===

>>> (utf8->string "abc")

%%% %any-error%

; === string->utf8 — type error on non-string ===

>>> (string->utf8 #u8(1 2 3))

%%% %any-error%

; === bytevector — type error on non-integer argument ===

>>> (bytevector 1 2.5 3)

%%% %any-error%

>>> (bytevector 1 'a 3)

%%% %any-error%

; ==========================================================================
; R7RS section 6.9 -- worked examples from the standard (Chibi-verified).
; ==========================================================================

>>> (make-bytevector 2 12)

==> #u8(12 12)

>>> (bytevector 1 3 5 1 3 5)

==> #u8(1 3 5 1 3 5)

>>> (bytevector-u8-ref '#u8(1 1 2 3 5 8 13 21) 5)

==> 8

>>> (let ((bv (bytevector 1 2 3 4))) (bytevector-u8-set! bv 1 3) bv)

==> #u8(1 3 3 4)

>>> (bytevector-copy #u8(1 2 3 4 5) 2 4)

==> #u8(3 4)

>>> (bytevector-append #u8(0 1 2) #u8(3 4 5))

==> #u8(0 1 2 3 4 5)

>>> (utf8->string #u8(#x41))

==> "A"

>>> (string->utf8 "λ")

==> #u8(206 187)

