#!/bin/sh
# pre-push — fast regression gate (test-coverage initiative, Phase 2, wave 1).
# The scheme-tests repo's signature concern is cross-port parity, so this runs the
# oracle-less cpp-vs-py differential (the curated cases) plus a pyScheme fast subset
# to catch broken feature/regression .log edits. Needs the sibling 3PyScheme and a
# cppScheme2 Release build. Bypass with: git push --no-verify
# Enable:  git config core.hooksPath hooks

REPO="$(git rev-parse --show-toplevel)"
COMMON="$(dirname "$REPO")"          # the pyscheme-cppscheme2-common container
LISP="$(dirname "$COMMON")"          # workspace root holding the interpreters
PY_DIR="$LISP/3PyScheme"

fail() { echo "pre-push: $1 -- push BLOCKED (use --no-verify to override)" >&2; exit 1; }

# pyScheme fast subset + the cpp-vs-py differential (cross-port + fuzz), all via
# ]suites (shell-free Scheme drivers).  cross-port/fuzz are py-hosted and launch the
# sibling cpp exe; py-hosting lets their py child inherit PYTHONPATH from the listener.
# Needs the sibling 3PyScheme and a cppScheme2 Release build.
if [ -d "$PY_DIR/pyscheme" ]; then
    echo "pre-push: pyScheme fast subset + cross-port + fuzz over these suites..."
    out="$(cd "$PY_DIR" && printf ']suites feature regression cross-port fuzz-smoke\n' | python -m pyscheme -T "$REPO" 2>&1)"
    echo "$out" | grep -E 'passed|FAIL|parity|diverg|fuzz|cross-port' | tail -6
    echo "$out" | grep -q 'ALL SUITES PASSED' || fail "suite/differential failure"
else
    echo "pre-push: sibling 3PyScheme not found -- skipping suite check." >&2
fi

echo "pre-push: OK"
exit 0
