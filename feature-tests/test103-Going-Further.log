;;; ============================================================
;;; 3.1  Syntactic Extension
;;; ============================================================

;;; Exercise 3.1.3: let* as nested lets

>>> (let* ([a 5] [b (+ a a)] [c (+ a b)])
...   (list a b c))
==> (5 10 15)

;;; Exercise 3.1.4: unless and when

>>> (let ([x 3])
...   (unless (= x 0) (set! x (+ x 1)))
...   (when (= x 4) (set! x (* x 2)))
...   x)
==> 8

;;; ============================================================
;;; 3.2  More Recursion
;;; ============================================================

;;; let does not allow self-reference in a lambda body

>>> (let ([sum (lambda (ls) (if (null? ls) 0 (+ (car ls) (sum (cdr ls)))))]) (sum '(1 2 3 4 5)))
%%% line 1, col 55: unbound variable: sum
%%% (let ([sum (lambda (ls) (if (null? ls) 0 (+ (car ls) (sum (cdr ls)))))]) (sum '(1 2 3 4 5)))
%%%                                                       ^

;;; workaround: pass the function as its own argument

>>> (let ([sum (lambda (sum ls)
...              (if (null? ls)
...                  0
...                  (+ (car ls) (sum sum (cdr ls)))))])
...   (sum sum '(1 2 3 4 5)))
==> 15

;;; letrec supports mutual recursion and self-reference

>>> (letrec ([sum (lambda (ls)
...                (if (null? ls)
...                    0
...                    (+ (car ls) (sum (cdr ls)))))])
...   (sum '(1 2 3 4 5)))
==> 15

>>> (letrec ([even?
...           (lambda (x)
...             (or (= x 0)
...                 (odd? (- x 1))))]
...          [odd?
...           (lambda (x)
...             (and (not (= x 0))
...                  (even? (- x 1))))])
...   (list (even? 20) (odd? 20)))
==> (#t #f)

;;; letrec: lambda bindings may refer to sibling variables by name

>>> (letrec ([f (lambda () (+ x 2))]
...          [x 1])
...   (f))
==> 3

;;; letrec: non-lambda init expressions must not reference sibling variables

>>> (letrec ([y (+ x 2)] [x 1]) y)
%%% SchemeTypeError: line 1, col 13: +: argument 1 is not a number
%%% (letrec ([y (+ x 2)] [x 1]) y)
%%%             ^

;;; list? using letrec with a race helper (Floyd's cycle detection)

>>> (define list?
...   (lambda (x)
...     (letrec ([race
...               (lambda (h t)
...                 (if (pair? h)
...                     (let ([h (cdr h)])
...                       (if (pair? h)
...                           (and (not (eq? h t))
...                                (race (cdr h) (cdr t)))
...                           (null? h)))
...                     (null? h)))])
...       (race x x))))
==>

;;; same definition using named let

>>> (define list?
...   (lambda (x)
...     (let race ([h x] [t x])
...       (if (pair? h)
...           (let ([h (cdr h)])
...             (if (pair? h)
...                 (and (not (eq? h t))
...                      (race (cdr h) (cdr t)))
...                 (null? h)))
...           (null? h)))))
==>

;;; named let: recursive factorial

>>> (define factorial
...   (lambda (n)
...     (let fact ([i n])
...       (if (= i 0)
...           1
...           (* i (fact (- i 1)))))))
==>

>>> (factorial 0)
==> 1

>>> (factorial 1)
==> 1

>>> (factorial 2)
==> 2

>>> (factorial 3)
==> 6

>>> (factorial 10)
==> 3628800

;;; named let: iterative factorial (accumulator)

>>> (define factorial
...   (lambda (n)
...     (let fact ([i n] [a 1])
...       (if (= i 0)
...           a
...           (fact (- i 1) (* a i))))))
==>

>>> (factorial 0)
==> 1

>>> (factorial 1)
==> 1

>>> (factorial 2)
==> 2

>>> (factorial 3)
==> 6

>>> (factorial 10)
==> 3628800

;;; named let: recursive Fibonacci

>>> (define fibonacci
...   (lambda (n)
...     (let fib ([i n])
...       (cond
...         [(= i 0) 0]
...         [(= i 1) 1]
...         [else (+ (fib (- i 1)) (fib (- i 2)))]))))
==>

>>> (fibonacci 0)
==> 0

>>> (fibonacci 1)
==> 1

>>> (fibonacci 2)
==> 1

>>> (fibonacci 3)
==> 2

>>> (fibonacci 4)
==> 3

>>> (fibonacci 5)
==> 5

>>> (fibonacci 6)
==> 8

>>> (fibonacci 20)
==> 6765

>>> (fibonacci 10)
==> 55

;;; named let: iterative Fibonacci

>>> (define fibonacci
...   (lambda (n)
...     (if (= n 0)
...         0
...         (let fib ([i n] [a1 1] [a2 0])
...           (if (= i 1)
...               a1
...               (fib (- i 1) (+ a1 a2) a1))))))
==>

>>> (fibonacci 0)
==> 0

>>> (fibonacci 1)
==> 1

>>> (fibonacci 2)
==> 1

>>> (fibonacci 3)
==> 2

>>> (fibonacci 4)
==> 3

>>> (fibonacci 5)
==> 5

>>> (fibonacci 6)
==> 8

>>> (fibonacci 20)
==> 6765

>>> (fibonacci 10)
==> 55

;;; named let: prime factorization

>>> (define factor
...   (lambda (n)
...     (let f ([n n] [i 2])
...       (cond
...         [(>= i n) (list n)]
...         [(integer? (/ n i))
...          (cons i (f (/ n i) i))]
...         [else (f n (+ i 1))]))))
==>

>>> (factor 0)
==> (0)

>>> (factor 1)
==> (1)

>>> (factor 12)
==> (2 2 3)

>>> (factor 3628800)
==> (2 2 2 2 2 2 2 2 3 3 3 3 5 5 7)

>>> (factor 9239)
==> (9239)

;;; ============================================================
;;; 3.3  Continuations
;;; ============================================================

>>> (call/cc
...   (lambda (k)
...     (* 5 4)))
==> 20

>>> (call/cc
...   (lambda (k)
...     (* 5 (k 4))))
==> 4

>>> (+ 2
...    (call/cc
...      (lambda (k)
...        (* 5 (k 4)))))
==> 6

;;; call/cc escape: product with early exit on zero

>>> (define product
...   (lambda (ls)
...     (call/cc
...       (lambda (break)
...         (let f ([ls ls])
...           (cond
...             [(null? ls) 1]
...             [(= (car ls) 0) (break 0)]
...             [else (* (car ls) (f (cdr ls)))]))))))
==>

>>> (product '(1 2 3 4 5))
==> 120

>>> (product '(7 3 8 0 1 9 5))
==> 0

;;; call/cc as a value: the continuation itself is returned and then invoked

>>> (let ([x (call/cc (lambda (k) k))])
...   (x (lambda (ignore) "hi")))
==> "hi"

>>> (((call/cc (lambda (k) k)) (lambda (x) x)) "HEY!")
==> "HEY!"

;;; saving a continuation for later use via retry

>>> (define retry #f)
==>

>>> (define factorial
...   (lambda (x)
...     (if (= x 0)
...         (call/cc (lambda (k) (set! retry k) 1))
...         (* x (factorial (- x 1))))))
==>

>>> (factorial 4)
==> 24

>>> (retry 1)
==> 24

>>> (retry 2)
==> 48

>>> (retry 5)
==> 120

;;; ============================================================
;;; 3.4  Continuation Passing Style
;;; ============================================================

;;; direct style: result of h is passed to cons

>>> (letrec ([f (lambda (x) (cons 'a x))]
...          [g (lambda (x) (cons 'b (f x)))]
...          [h (lambda (x) (g (cons 'c x)))])
...   (cons 'd (h '())))
==> (d b a c)

;;; CPS: pass a continuation callback instead of returning

>>> (define car&cdr
...   (lambda (p k)
...     (k (car p) (cdr p))))
==>

>>> (car&cdr '(a b c)
...   (lambda (x y)
...     (list y x)))
==> ((b c) a)

>>> (car&cdr '(a b c) cons)
==> (a b c)

>>> (car&cdr '(a b c a d) memv)
==> (a d)

;;; CPS with two continuations: success and failure

>>> (define integer-divide
...   (lambda (x y success failure)
...     (if (= y 0)
...         (failure "divide by zero")
...         (let ([q (quotient x y)])
...           (success q (- x (* q y)))))))
==>

>>> (integer-divide 10 3 list (lambda (x) x))
==> (3 1)

>>> (integer-divide 10 0 list (lambda (x) x))
==> "divide by zero"

;;; CPS product: continuation replaces call/cc escape

>>> (define product
...   (lambda (ls k)
...     (let ([break k])
...       (let f ([ls ls] [k k])
...         (cond
...           [(null? ls) (k 1)]
...           [(= (car ls) 0) (break 0)]
...           [else (f (cdr ls)
...                    (lambda (x)
...                      (k (* (car ls) x))))])))))
==>

>>> (product '(1 2 3 4 5) (lambda (x) x))
==> 120

>>> (product '(7 3 8 0 1 9 5) (lambda (x) x))
==> 0

;;; ============================================================
;;; 3.5  Internal Definitions
;;; ============================================================

;;; internal define creates a local binding, outer f is unaffected

>>> (define f (lambda (x) (* x x)))
==>

>>> (let ([x 3])
...   (define f (lambda (y) (+ y x)))
...   (f 4))
==> 7

>>> (f 4)
==> 16

;;; let body with mutually recursive internal defines

>>> (let ()
...   (define even?
...     (lambda (x)
...       (or (= x 0)
...           (odd? (- x 1)))))
...   (define odd?
...     (lambda (x)
...       (and (not (= x 0))
...            (even? (- x 1)))))
...   (even? 20))
==> #t

;;; internal define-syntax

>>> (let ([x 3])
...   (define-syntax set-x!
...     (syntax-rules ()
...       [(_ e) (set! x e)]))
...   (set-x! (+ x x))
...   x)
==> 6

;;; list? with internal define for the race helper

>>> (define list?
...   (lambda (x)
...     (define race
...       (lambda (h t)
...         (if (pair? h)
...             (let ([h (cdr h)])
...               (if (pair? h)
...                   (and (not (eq? h t))
...                        (race (cdr h) (cdr t)))
...                   (null? h)))
...             (null? h))))
...     (race x x)))
==>

;;; calculator using call/cc for structured error returns

>>> (define calc #f)
==>

>>> (let ()
...   (define do-calc
...     (lambda (ek expr)
...       (cond
...         [(number? expr) expr]
...         [(and (list? expr) (= (length expr) 3))
...          (let ([op (car expr)] [args (cdr expr)])
...            (case op
...              [(add) (apply-op ek + args)]
...              [(sub) (apply-op ek - args)]
...              [(mul) (apply-op ek * args)]
...              [(div) (apply-op ek / args)]
...              [else (complain ek "invalid operator" op)]))]
...         [else (complain ek "invalid expression" expr)])))
...   (define apply-op
...     (lambda (ek op args)
...       (op (do-calc ek (car args)) (do-calc ek (cadr args)))))
...   (define complain
...     (lambda (ek msg expr)
...       (ek (list msg expr))))
...   (set! calc
...     (lambda (expr)
...       (call/cc
...         (lambda (ek)
...           (do-calc ek expr))))))
==>

>>> (calc '(add (mul 3 2) -4))
==> 2

>>> (calc '(div 1/2 1/6))
==> 3

>>> (calc '(add (mul 3 2) (div 4)))
==> ("invalid expression" (div 4))

>>> (calc '(mul (add 1 -2) (pow 2 7)))
==> ("invalid operator" pow)

;;; ============================================================
;;; 3.6  Libraries
;;; ;;; (grades library adapted from R6RS to top-level definitions)
;;; ============================================================

>>> (define in-range?
...   (lambda (x n y)
...     (and (>= n x) (< n y))))
==>

>>> (define-syntax range-case
...   (syntax-rules (- else)
...     [(_ expr ((x - y) e1 e2 ...) ... [else ee1 ee2 ...])
...      (let ([tmp expr])
...        (cond
...          [(in-range? x tmp y) e1 e2 ...]
...          ...
...          [else ee1 ee2 ...]))]
...     [(_ expr ((x - y) e1 e2 ...) ...)
...      (let ([tmp expr])
...        (cond
...          [(in-range? x tmp y) e1 e2 ...]
...          ...))]))
==>

>>> (define letter->number
...   (lambda (x)
...     (case x
...       [(a) 4.0]
...       [(b) 3.0]
...       [(c) 2.0]
...       [(d) 1.0]
...       [(f) 0.0]
...       [else (error "invalid letter grade" x)])))
==>

>>> (define gpa->grade
...   (lambda (x)
...     (range-case x
...       [(0.0 - 0.5) 'f]
...       [(0.5 - 1.5) 'd]
...       [(1.5 - 2.5) 'c]
...       [(2.5 - 3.5) 'b]
...       [else 'a])))
==>

>>> (define-syntax gpa
...   (syntax-rules ()
...     [(_ g1 g2 ...)
...      (let ([ls (map letter->number '(g1 g2 ...))])
...        (/ (apply + ls) (length ls)))]))
==>

>>> (gpa c a c b b)
==> 2.8

>>> (gpa->grade 2.8)
==> b
