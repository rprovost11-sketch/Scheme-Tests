>>> (cond-expand
...   (r7rs 'yes)
...   (else 'no))
... ; windows feature is present on this platform
==> yes

>>> (cond-expand
...   (windows 'win)
...   (else 'other))
... ; windows feature is present on Windows platform
==> win

>>> (cond-expand
...   (no-such-feature 'bad)
...   (else 'fallback))
... ; and: both features present
==> fallback

>>> (cond-expand
...   ((and r7rs windows) 'both)
...   (else 'not-both))
... ; and: both features present on Windows platform
==> both

>>> (cond-expand
...   ((and r7rs no-such-feature) 'both)
...   (else 'fallback))
... ; or: at least one present
==> fallback

>>> (cond-expand
...   ((or no-such-feature r7rs) 'found)
...   (else 'not-found))
... ; not: negating absent feature
==> found

>>> (cond-expand
...   ((not no-such-feature) 'yes)
...   (else 'no))
... ; not: negating present feature
==> yes

>>> (cond-expand
...   ((not r7rs) 'yes)
...   (else 'no))
... ; ============================================================
... ; 11. cond-expand with (library ...)
... ; ============================================================
... ; (scheme base) is recognized as present
==> no

>>> (cond-expand
...   ((library (scheme base)) 'has-lib)
...   (else 'no-lib))
==> has-lib

>>> (cond-expand ((library (scheme complex)) 'has-complex) (else 'no-complex))
==> has-complex

>>> (cond-expand ((library (scheme inexact)) 'has-inexact) (else 'no-inexact))
==> has-inexact

>>> (cond-expand ((library (scheme char)) 'has-char) (else 'no-char))
==> has-char

>>> (cond-expand ((library (scheme eval)) 'has-eval) (else 'no-eval))
==> has-eval

>>> (cond-expand ((library (scheme write)) 'has-write) (else 'no-write))
... ; unknown library returns false, falls through to else
==> has-write

>>> (cond-expand ((library (scheme process-context)) 'has-proc) (else 'no-proc))
... ; and/or combining library checks
==> has-proc

>>> (cond-expand ((and (library (scheme base)) (library (scheme char))) 'both) (else 'not-both))
==> both

>>> (cond-expand ((or (library (scheme process-context)) (library (scheme base))) 'one-of) (else 'neither))
... ; ============================================================
... ; 12. cond-expand: multiple features, multi-expression body,
