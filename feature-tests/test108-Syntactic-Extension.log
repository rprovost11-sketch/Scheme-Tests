;;; ============================================================
;;; 8.1  Keyword Bindings
;;; ============================================================

;;; define-syntax visible to sibling define in same let body (two-pass scan)

>>> (let ()
...   (define even?
...     (lambda (x)
...       (or (= x 0) (odd? (- x 1)))))
...   (define-syntax odd?
...     (syntax-rules ()
...       [(_ x) (not (even? x))]))
...   (even? 10))
==> #t

;;; macro expanding to define

>>> (let ()
...   (define-syntax bind-to-zero
...     (syntax-rules ()
...       [(_ id) (define id 0)]))
...   (bind-to-zero x)
...   x)
==> 0

;;; let-syntax: g's (f x) reaches the outer lambda f because let-syntax
;;; siblings are NOT visible to each other (R7RS 4.3.1).

>>> (let ([f (lambda (x) (+ x 1))])
...   (let-syntax ([f (syntax-rules ()
...                        [(_ x) x])]
...                [g (syntax-rules ()
...                        [(_ x) (f x)])])
...     (list (f 1) (g 1))))
==> (1 2)

;;; letrec-syntax: g sees the syntax f from the same binding block

>>> (let ([f (lambda (x) (+ x 1))])
...   (letrec-syntax ([f (syntax-rules ()
...                        [(_ x) x])]
...                   [g (syntax-rules ()
...                        [(_ x) (f x)])])
...     (list (f 1) (g 1))))
==> (1 1)

;;; ============================================================
;;; 8.2  Syntax-Rules Transformers
;;; ============================================================

;;; or is hygienic: local bindings of if and t do not interfere with expansion

>>> (let ([if #f])
...   (let ([t 'okay])
...     (or if t)))
==> okay

;;; identifier-syntax requires (syntax-rules ...) as transformer in pyscheme

>>> (define-syntax a (identifier-syntax car))
%%% line 1, col 18: define-syntax: transformer must be (syntax-rules ...)
%%% (define-syntax a (identifier-syntax car))
%%%                  ^

;;; identifier-syntax with set! form also not supported

>>> (let ([ls (list 0)])
...   (define-syntax a
...     (identifier-syntax
...       [id (car ls)]
...       [(set! id e) (set-car! ls e)]))
...   (let ([before a])
...     (set! a 1)
...     (list before a ls)))
%%% line 3, col 5: define-syntax: transformer must be (syntax-rules ...)
%%%     (identifier-syntax
%%%     ^

;;; ============================================================
;;; 8.3  Syntax-Case Transformers
;;; ============================================================

;;; syntax-case transformers require #' (syntax) notation -- not supported in pyscheme

>>> (define-syntax my-or (lambda (x) #'x))
%%% line 1, col 34: unknown #-syntax: '#'
%%% (define-syntax my-or (lambda (x) #'x))
%%%                                  ^

;;; R7RS hygienic cond: when 'else' is lexically shadowed, the cond clause
;;; treats it as a regular test expression -- the value #f is falsy, so
;;; the body does NOT run.

>>> (let ([else #f])
...   (cond [else (write "oops")]))
==>

;;; R7RS 4.2.2: a let binding name must not appear twice (syntax violation).

>>> (let ([a 3] [a 4]) (+ a a))
%%% line 1, col 1: duplicate variable name in let bindings: a
%%% (let ([a 3] [a 4]) (+ a a))
%%% ^

;;; pcar: syntax-case with fender -- #' not supported

>>> (let ([p (cons 0 #f)])
...   (define-syntax pcar
...     (lambda (x)
...       (syntax-case x ()
...         [_ (identifier? x) #'(car p)]
...         [(_ e) #'(set-car! p e)])))
...   (let ([a pcar])
...     (pcar 1)
...     (list a pcar)))
%%% line 5, col 28: unknown #-syntax: '#'
%%%         [_ (identifier? x) #'(car p)]
%%%                            ^

;;; let-syntax with lambda transformer: pyscheme requires syntax-rules

>>> (let ([a 0])
...   (let-syntax ([dolet (lambda (x)
...                         (syntax-case x ()
...                           [(_ b)
...                            #'(let ([a 3] [b 4]) (+ a b))]))])
...     (dolet a)))
%%% line 5, col 28: unknown #-syntax: '#'
%%%                            #'(let ([a 3] [b 4]) (+ a b))]))])
%%%                            ^

;;; with-syntax, syntax->datum, datum->syntax: R6RS/Chez -- unbound in pyscheme

>>> (with-syntax ([x 'foo]) x)
%%% line 1, col 2: unbound variable: with-syntax
%%% (with-syntax ([x 'foo]) x)
%%%  ^

>>> (syntax->datum '(a b c))
%%% line 1, col 2: unbound variable: syntax->datum
%%% (syntax->datum '(a b c))
%%%  ^

>>> (datum->syntax 'foo '(+ 1 2))
%%% line 1, col 2: unbound variable: datum->syntax
%%% (datum->syntax 'foo '(+ 1 2))
%%%  ^

;;; generate-temporaries, make-variable-transformer: unbound in pyscheme

>>> (generate-temporaries '(a b c))
%%% line 1, col 2: unbound variable: generate-temporaries
%%% (generate-temporaries '(a b c))
%%%  ^

>>> (make-variable-transformer (lambda (x) x))
%%% line 1, col 2: unbound variable: make-variable-transformer
%%% (make-variable-transformer (lambda (x) x))
%%%  ^

;;; symbolic-identifier=? uses syntax->datum (unbound at call time) -- define succeeds

>>> (define symbolic-identifier=?
...   (lambda (x y)
...     (eq? (syntax->datum x)
...          (syntax->datum y))))
==>

;;; loop using datum->syntax: #' not supported

>>> (define-syntax loop
...   (lambda (x)
...     (syntax-case x ()
...       [(k e ...)
...        (with-syntax ([break (datum->syntax #'k 'break)])
...          #'(call/cc
...              (lambda (break)
...                (let f () e ... (f)))))])))
%%% line 5, col 44: unknown #-syntax: '#'
%%%        (with-syntax ([break (datum->syntax #'k 'break)])
%%%                                            ^

;;; ============================================================
;;; 8.4  Examples
;;; ============================================================

;;; rec: self-referential lambda via letrec

>>> (define-syntax rec
...   (syntax-rules ()
...     [(_ x e) (letrec ([x e]) x)]))
==>

>>> (map (rec sum
...        (lambda (x)
...          (if (= x 0)
...              0
...              (+ x (sum (- x 1))))))
...      '(0 1 2 3 4 5))
==> (0 1 3 6 10 15)

;;; let with named-let form using rec

>>> (define-syntax let
...   (syntax-rules ()
...     [(_ f ((x e) ...) b1 b2 ...)
...      ((rec f (lambda (x ...) b1 b2 ...)) e ...)]
...     [(_ ((x e) ...) b1 b2 ...)
...      ((lambda (x ...) b1 b2 ...) e ...)]))
==>

>>> (let fact ((n 5))
...   (if (= n 0) 1 (* n (fact (- n 1)))))
==> 120

;;; be-like-begin: macro that installs a new macro name

>>> (define-syntax be-like-begin
...   (syntax-rules ()
...     [(_ name)
...      (define-syntax name
...        (syntax-rules ()
...          [(_ e0 e1 (... ...))
...           (begin e0 e1 (... ...))]))]))
==>

>>> (be-like-begin sequence)
==>

>>> (sequence (display "Say what?") (newline))
Say what?
==>

;;; loop using syntax-rules: under R7RS hygiene 'break' introduced by the
;;; macro template is renamed and is not visible to the user's body.
;;; A non-hygienic version would require syntax-case + datum->syntax,
;;; which pyscheme does not implement.

>>> (define-syntax loop
...   (syntax-rules ()
...     [(_ e ...)
...      (call/cc
...        (lambda (break)
...          (let f () e ... (f))))]))
==>

>>> (let ([n 3] [ls '()])
...   (loop
...     (if (= n 0) (break ls))
...     (set! ls (cons 'a ls))
...     (set! n (- n 1))))
%%% line 3, col 18: unbound variable: break
%%%     (if (= n 0) (break ls))
%%%                  ^

;;; let-syntax with lambda transformer: #' triggers parse error before transformer check

>>> (let-syntax ([if (lambda (x)
...                    (syntax-case x ()
...                      [(_ e1 e2 e3)
...                       #'(if e1 e2 e3)]))])
...   (if (< 1 5) 2 3))
%%% line 4, col 23: unknown #-syntax: '#'
%%%                       #'(if e1 e2 e3)]))])
%%%                       ^

;;; define-integrable: nested define-syntax uses syntax-case -- #' not supported

>>> (define-syntax define-integrable
...   (syntax-rules (lambda)
...     [(_ name (lambda formals form1 form2 ...))
...      (begin
...        (define xname (lambda formals form1 form2 ...))
...        (define-syntax name
...          (lambda (x)
...            (syntax-case x ()
...              [_ (identifier? x) #'xname]
...              [(_ arg (... ...))
...               #'((lambda formals form1 form2 ...)
...                  arg
...                  (... ...))]))))]))
%%% line 9, col 33: unknown #-syntax: '#'
%%%              [_ (identifier? x) #'xname]
%%%                                 ^

;;; define-structure: uses datum->syntax -- unbound, and syntax-case not supported

>>> (define-syntax define-structure
...   (lambda (x)
...     (syntax-case x ()
...       [(_ name field ...)
...        (with-syntax ([constructor (datum->syntax #'name "constructor")])
...          #'(begin))])))
%%% line 5, col 50: unknown #-syntax: '#'
%%%        (with-syntax ([constructor (datum->syntax #'name "constructor")])
%%%                                                  ^
