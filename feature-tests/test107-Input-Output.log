;;; ============================================================
;;; 7.4  String and Bytevector Ports
;;; ============================================================

;;; open-bytevector-input-port, get-u8: R6RS names -- unbound in pyscheme

>>> (let ([ip (open-bytevector-input-port #u8(1 2))])
...   (let* ([x1 (get-u8 ip)] [x2 (get-u8 ip)] [x3 (get-u8 ip)])
...     (list x1 x2 (eof-object? x3))))
%%% line 1, col 12: unbound variable: open-bytevector-input-port
%%% (let ([ip (open-bytevector-input-port #u8(1 2))])
%%%            ^

;;; get-line, open-string-input-port: R6RS names -- unbound in pyscheme

>>> (get-line (open-string-input-port "hi.\nwhat's up?\n"))
%%% line 1, col 2: unbound variable: get-line
%%% (get-line (open-string-input-port "hi.\nwhat's up?\n"))
%%%  ^

;;; R7RS equivalent: read-line / open-input-string

>>> (read-line (open-input-string "hi.\nwhat's up?\n"))
==> "hi."

;;; open-bytevector-output-port: R6RS -- unbound in pyscheme

>>> (let-values ([(op g) (open-bytevector-output-port)])
...   (put-u8 op 15)
...   (put-u8 op 73)
...   (put-u8 op 115)
...   (set-port-position! op 2)
...   (let ([bv1 (g)])
...     (put-u8 op 27)
...     (list bv1 (g))))
%%% line 1, col 23: unbound variable: open-bytevector-output-port
%%% (let-values ([(op g) (open-bytevector-output-port)])
%%%                       ^

;;; R7RS bytevector output port: get-output-bytevector

>>> (let ([op (open-output-bytevector)])
...   (write-u8 1 op)
...   (write-u8 2 op)
...   (get-output-bytevector op))
==> #u8(1 2)

;;; open-string-output-port: R6RS -- unbound in pyscheme

>>> (let-values ([(op g) (open-string-output-port)])
...   (put-string op "some data")
...   (let ([str1 (g)])
...     (put-string op "new stuff")
...     (list str1 (g))))
%%% line 1, col 23: unbound variable: open-string-output-port
%%% (let-values ([(op g) (open-string-output-port)])
%%%                       ^

;;; R7RS string output port: get-output-string accumulates all content since port opened
;;; (unlike R6RS open-string-output-port extractor which resets on each call)

>>> (let ([op (open-output-string)])
...   (write-string "some data" op)
...   (let ([str1 (get-output-string op)])
...     (write-string "new stuff" op)
...     (list str1 (get-output-string op))))
==> ("some data" "some datanew stuff")

;;; call-with-string-output-port: R6RS -- unbound in pyscheme

>>> (call-with-string-output-port
...   (lambda (p) (put-datum p '(a b c))))
%%% line 1, col 2: unbound variable: call-with-string-output-port
%%% (call-with-string-output-port
%%%  ^

;;; ============================================================
;;; 7.6  Port Operations
;;; ============================================================

>>> (port? (open-input-string "test"))
==> #t

>>> (input-port? (open-input-string "test"))
==> #t

>>> (output-port? (open-output-string))
==> #t

>>> (binary-port? (open-input-bytevector #u8(1 2)))
==> #t

>>> (textual-port? (open-input-string "test"))
==> #t

;;; string ports are textual, not binary

>>> (binary-port? (open-input-string "test"))
==> #f

>>> (call-with-port (open-input-string "hello")
...   (lambda (p) (read-char p)))
==> #\h

>>> (close-port (open-input-string "test"))
==>

>>> (close-input-port (open-input-string "test"))
==>

>>> (close-output-port (open-output-string))
==>

;;; port-eof?, port-position: R6RS -- unbound in pyscheme

>>> (port-eof? (open-input-string ""))
%%% line 1, col 2: unbound variable: port-eof?
