;;; R7RS output operations

>>> (write-char #\a (open-output-string))
==>

>>> (write-u8 65 (open-output-bytevector))
==>

>>> (write-string "hello" (open-output-string))
==>

;;; write-string accepts optional start/end arguments

>>> (write-string "hello world" (open-output-string) 6 11)
==>

>>> (write-bytevector #u8(1 2 3) (open-output-bytevector))
==>

>>> (newline (open-output-string))
==>

>>> (flush-output-port (open-output-string))
==>

