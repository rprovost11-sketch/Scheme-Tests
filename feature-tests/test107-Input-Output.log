;;; 7.7  Input Operations
;;; ============================================================

>>> (eof-object? (eof-object))
==> #t

;;; get-datum, lookahead-char, port-eof?: R6RS -- open-string-input-port unbound in pyscheme

>>> (let ([sip (open-string-input-port "; a\n\n one (two)\n")])
...   (let* ([x1 (get-datum sip)]
...          [c1 (lookahead-char sip)]
...          [x2 (get-datum sip)])
...     (list x1 c1 x2 (port-eof? sip))))
%%% line 1, col 13: unbound variable: open-string-input-port
%%% (let ([sip (open-string-input-port "; a\n\n one (two)\n")])
%%%             ^

>>> (let ([sip (open-string-input-port "one\ntwo\n")])
...   (let* ([s1 (get-line sip)] [s2 (get-line sip)])
...     (list s1 s2 (port-eof? sip))))
%%% line 1, col 13: unbound variable: open-string-input-port
%%% (let ([sip (open-string-input-port "one\ntwo\n")])
%%%             ^

;;; R7RS input operations

>>> (read-char (open-input-string "hello"))
==> #\h

>>> (peek-char (open-input-string "hello"))
==> #\h

>>> (read-line (open-input-string "one\ntwo\n"))
==> "one"

>>> (read-u8 (open-input-bytevector #u8(10 20 30)))
==> 10

>>> (peek-u8 (open-input-bytevector #u8(10 20)))
==> 10

>>> (read-bytevector 3 (open-input-bytevector #u8(1 2 3 4 5)))
==> #u8(1 2 3)

>>> (read-bytevector! (make-bytevector 3 0) (open-input-bytevector #u8(10 20 30 40)))
==> 3

>>> (char-ready? (open-input-string "hi"))
==> #t

