;;; ============================================================
;;; 7.9  Convenience I/O
;;; ============================================================

>>> (read (open-input-string "(a b c)"))
==> (a b c)

>>> (read (open-input-string ""))
==> #<eof>

>>> (let ([op (open-output-string)])
...   (write '(a b c) op)
...   (get-output-string op))
==> "(a b c)"

