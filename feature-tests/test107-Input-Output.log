%%%  ^

>>> (port-position (open-input-string "hello"))
%%% line 1, col 2: unbound variable: port-position
%%% (port-position (open-input-string "hello"))
%%%  ^

;;; port-open? is an extension present in pyscheme

>>> (port-open? (open-input-string "test"))
==> #t

