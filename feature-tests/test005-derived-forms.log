;;; ============================================================
;;; test05-derived-forms
;;; Derived forms: cond, case, and/or, when/unless, let variants, do, define-values
;;; ============================================================

>>> (begin 1 2 3)
==> 3

>>> (begin 42)
==> 42

>>> (define counter 0)
==>

>>> (begin (set! counter 1) (set! counter 2) counter)
... ;;; -------- when / unless (R7RS 4.2.1) --------
==> 2

>>> (when #t 1 2 3)
==> 3

>>> (when #f 99)
==>

>>> (when 0 'truthy)
==> truthy

>>> (when (null? (list)) (cons 1 (list)))
==> (1)

>>> (unless #f 1 2 3)
==> 3

>>> (unless #t 99)
==>

>>> (unless (null? (list 1)) 'runs)
... ;;; -------- and / or (R7RS 4.2.1) --------
==> runs

>>> (and)
==> #t

>>> (and 1)
==> 1

>>> (and 1 2 3)
==> 3

>>> (and #f 99)
==> #f

>>> (and 1 #f 3)
==> #f

>>> (or)
==> #f

>>> (or 1)
==> 1

>>> (or #f #f 3)
==> 3

>>> (or #f #f #f)
==> #f

>>> (or 1 'would-not-evaluate)
... ;;; -------- cond (R7RS 4.2.1) - all three clause forms --------
==> 1

>>> (cond (#t 1))
==> 1

>>> (cond (#f 1) (#t 2) (else 3))
==> 2

>>> (cond (#f 1) (#f 2) (else 'fallback))
==> fallback

>>> (cond (#f 1))
==>

>>> (cond (42))
==> 42

>>> (cond (#f) (else 99))
==> 99

>>> (cond ((cons 1 2) => car))
==> 1

>>> (cond (#f => car) (else 'skipped))
==> skipped

>>> (cond ((cons 10 20) => cdr) (else 0))
... ;;; -------- case (R7RS 4.2.1) - eqv?-based literal dispatch --------
==> 20

>>> (case 2 ((1 2 3) 'small) ((4 5) 'med) (else 'big))
==> small

>>> (case 5 ((1 2 3) 'small) ((4 5) 'med) (else 'big))
==> med

>>> (case 99 ((1 2 3) 'small) ((4 5) 'med) (else 'big))
... ;;; Symbol datums are implicitly quoted.
==> big

>>> (case 'b ((a) 1) ((b c) 2) (else 3))
... ;;; No match, no else - unspecified value.
==> 2

>>> (case 99 ((1) 'one))
... ;;; Multi-expression bodies (last value returned).
==>

>>> (case 2 ((1 2) 'a 'b 'c) (else 'd))
... ;;; Single-datum singleton clause.
==> c

>>> (case 7 ((7) 'found) (else 'missing))
... ;;; Numeric exactness: eqv? distinguishes 2 and 2.0.
==> found

>>> (case 2 ((2.0) 'real) (else 'int))
==> int

>>> (case 2.0 ((2) 'int) (else 'real))
... ;;; Shape errors caught by the analyzer.
==> real

>>> (case)
%%% line 1, col 1: case requires a key and at least one clause
%%% (case)
%%% ^
>>> (case 1 (else 1) (else 2))
%%% line 1, col 9: case 'else' clause must be the last clause
%%% (case 1 (else 1) (else 2))
%%%         ^
>>> (case 1 (else 1) ((2) 'b))
%%% line 1, col 9: case 'else' clause must be the last clause
%%% (case 1 (else 1) ((2) 'b))
%%%         ^
>>> (case 1 ())
%%% line 1, col 9: case clause must be (<datum-list> <expr>...) or (else <expr>...), got ()
%%% (case 1 ())
%%%         ^
>>> (let ((x 1)) x)
==> 1

>>> (let () 42)
==> 42

>>> (let ((x 1) (y 2)) (cons x y))
==> (1 . 2)

>>> (let ((a 1) (b 2) (c 3)) (list a b c))
==> (1 2 3)

>>> (define outer 10)
==>

>>> (let ((outer 1)) outer)
==> 1

>>> outer
... ;;; let binds vals in OUTER env - (y x) sees outer x, not the new x.
==> 10

>>> (let ((x 99) (y outer)) (cons x y))
... ;;; -------- let* (R7RS 4.2.2) --------
==> (99 . 10)

>>> (let* ((x 1) (y x)) y)
==> 1

>>> (let* ((x 1) (y (cons x (list)))) y)
==> (1)

>>> (let* ((a 1) (b (cons a (list))) (c (cons 2 b))) c)
... ;;; -------- letrec / letrec* (R7RS 4.2.2) --------
==> (2 1)

>>> (letrec ((f (lambda (x) x))) (f 42))
==> 42

>>> (letrec ((last (lambda (lst) (if (null? (cdr lst)) (car lst) (last (cdr lst)))))) (last (list 1 2 3 4)))
... ;;; Mutual recursion via letrec
==> 4

>>> (letrec ((p? (lambda (lst) (if (null? lst) #t (q? (cdr lst))))) (q? (lambda (lst) (if (null? lst) #f (p? (cdr lst)))))) (p? (list 1 2 3 4)))
==> #t

>>> (letrec* ((f (lambda (x) x)) (g (lambda (x) (f x)))) (g 99))
... ;;; -------- named let (R7RS 4.2.4) --------
==> 99

>>> (do ((i 0 (+ i 1))) ((= i 5) i))
... ;;; Multiple bindings, single result expression.
==> 5

>>> (do ((i 0 (+ i 1)) (s 0 (+ s i))) ((= i 5) s))
... ;;; Empty result list - unspecified value.
==> 10

>>> (do ((i 0 (+ i 1))) ((= i 3)))
... ;;; Accumulator using cons; steps see current binding of i.
==>

>>> (do ((i 0 (+ i 1)) (acc (list) (cons i acc))) ((= i 4) acc))
... ;;; Steps run in parallel (like let, not let*): both a and b see old values.
==> (3 2 1 0)

>>> (do ((a 1 b) (b 2 (+ a b))) ((> a 10) a))
... ;;; A binding with no step: variable keeps its initial value.
==> 13

>>> (do ((i 0 (+ i 1)) (v 'a)) ((= i 2) v))
... ;;; Zero-iteration case: test true immediately.
==> a

>>> (do ((x 'hi)) (#t x))
... ;;; Multi-expression result (last value returned).
==> hi

>>> (do ((i 0 (+ i 1))) ((= i 3) 'first 'second 'third))
... ;;; Shape errors caught by the analyzer.
==> third

>>> (do)
%%% line 1, col 1: do requires a binding list and a test clause
%%% (do)
%%% ^
>>> (do () ())
%%% line 1, col 8: do test clause must be a list starting with a test expression
%%% (do () ())
%%%        ^
>>> (do ((i)) ((= i 0) i))
%%% line 1, col 6: do binding must be (var init) or (var init step), got (i)
%%% (do ((i)) ((= i 0) i))
%%%      ^
>>> (do ((1 0)) ((= 1 0)))
%%% line 1, col 7: expected an identifier in do binding, got 1
%%% (do ((1 0)) ((= 1 0)))
%%%       ^
>>> (do ((i 0 (+ i 1)) (i 0)) ((= i 5) i))
%%% line 1, col 21: duplicate variable name in do bindings: i
%%% (do ((i 0 (+ i 1)) (i 0)) ((= i 5) i))
%%%                     ^
>>> (define-values (p q r) (values 1 2 3)) (list p q r)
... ;;; define-values with dotted rest.
==> (1 2 3)

>>> (define-values (head . tail) (values 10 20 30 40)) (list head tail)
... ;;; define-values with pure-variadic formals.
==> (10 (20 30 40))

>>> (define-values all (values 'x 'y 'z)) all
... ;;; Single-value init becomes single binding.
==> (x y z)

>>> (define-values (solo) 77) solo
... ;;; -------- multi-values as single-value error --------
... ;;; Delivering multi-values into an argument slot is an error.  The
... ;;; error position points at the offending (values ...) call site.
==> 77

