;;; ============================================================
;;; quasiquote / unquote arity errors
;;; ============================================================

>>> (quasiquote (unquote 1 2))
... ; unquote must take exactly one argument
%%% line 1, col 13: unquote requires exactly one argument
%%% (quasiquote (unquote 1 2))
%%%             ^

>>> (quasiquote (quasiquote 1 2))
... ; nested quasiquote must take exactly one argument
%%% line 1, col 13: quasiquote requires exactly one argument
%%% (quasiquote (quasiquote 1 2))
%%%             ^

>>> (quasiquote (unquote-splicing 1 2))
... ; top-level unquote-splicing must take exactly one argument
%%% line 1, col 13: unquote-splicing requires exactly one argument
%%% (quasiquote (unquote-splicing 1 2))
%%%             ^

>>> (quasiquote ((unquote-splicing 1 2)))
... ; element-position unquote-splicing must take exactly one argument
%%% line 1, col 14: unquote-splicing requires exactly one argument
%%% (quasiquote ((unquote-splicing 1 2)))
%%%              ^
