;;; ============================================================
;;; test02-expander
;;; Expander: cond-expand, include, include-ci
;;; ============================================================

>>> (cond-expand ((library (scheme base)) 'yes) (else 'no))
==> yes

>>> (cond-expand ((library (srfi 1)) 'yes) (else 'no))
==> no

>>> (cond-expand ((library (no such lib)) 'yes) (else 'no))
... ;;; -------- list? on circular structures --------
==> no

>>> (cond-expand (r7rs 'yes-r7rs) (else 'no))
==> yes-r7rs

>>> (cond-expand (nosuch-feature 'no) (else 'fallback))
==> fallback

>>> (cond-expand ((and r7rs pyscheme) 'both) (else 'partial))
==> both

>>> (cond-expand ((or nosuch r7rs) 'matched) (else 'no))
==> matched

>>> (cond-expand ((not nosuch) 'yes) (else 'no))
==> yes

>>> (cond-expand ((library (srfi 1)) 'have-srfi) (else 'no-srfi))
... ;;; Definitions spliced at top level persist.
==> no-srfi

>>> (cond-expand (r7rs (define sq (lambda (x) (* x x)))) (else 'skip)) (sq 9)
... ;;; Shape errors.
==> 81

>>> (cond-expand)
%%% line 1, col 1: cond-expand requires at least one clause
%%% (cond-expand)
%%% ^
>>> (cond-expand (nosuch 1))
%%% line 1, col 1: cond-expand: no clause matched
%%% (cond-expand (nosuch 1))
%%% ^

;;; ============================================================
;;; define-syntax shape errors
;;; ============================================================

>>> (define-syntax)
... ; define-syntax with no name/transformer
%%% line 1, col 1: define-syntax: expected (define-syntax <name> <transformer>)
%%% (define-syntax)
%%% ^

>>> (define-syntax foo)
... ; define-syntax with a name but no transformer
%%% line 1, col 1: define-syntax: missing transformer
%%% (define-syntax foo)
%%% ^

;;; ============================================================
;;; let-syntax shape errors
;;; ============================================================

>>> (let-syntax)
... ; let-syntax with no bindings list or body
%%% line 1, col 1: let-syntax: malformed
%%% (let-syntax)
%%% ^

>>> (let-syntax ())
... ; let-syntax with an empty body
%%% line 1, col 1: let-syntax: empty body
%%% (let-syntax ())
%%% ^

>>> (let-syntax ((m)) 1)
... ; let-syntax binding missing its transformer
%%% line 1, col 14: let-syntax: malformed binding
%%% (let-syntax ((m)) 1)
%%%              ^

>>> (let-syntax ((m 5)) 1)
... ; let-syntax transformer is not (syntax-rules ...)
%%% line 1, col 17: let-syntax: transformer must be (syntax-rules ...)
%%% (let-syntax ((m 5)) 1)
%%%                 ^

;;; ============================================================
;;; macro expansion runaway guards
;;; ============================================================

>>> (letrec-syntax ((lp (syntax-rules () ((lp) (lp))))) (lp))
... ; recursive macro use trips the expansion-iteration limit
%%% line 1, col 53: macro expansion limit exceeded - possible infinite loop
%%% (letrec-syntax ((lp (syntax-rules () ((lp) (lp))))) (lp))
%%%                                                     ^

>>> (letrec-syntax ((p (syntax-rules () ((p) (q)))) (q (syntax-rules () ((q) (begin (p)))))) (p))
... ; mutually-recursive macros nest until the expansion-depth guard fires
%%% line 1, col 75: macro expansion depth exceeded - possible mutually-recursive macro loop
%%% (letrec-syntax ((p (syntax-rules () ((p) (q)))) (q (syntax-rules () ((q) (begin (p)))))) (p))
%%%                                                                           ^

;;; ============================================================
;;; body structure error
;;; ============================================================

>>> (let () 1 (define x 2) x)
... ; a definition may not follow an expression in a body
%%% line 1, col 11: definition not allowed after an expression in a body
%%% (let () 1 (define x 2) x)
%%%           ^

