>>> (define-record-type tag (make-tag) tag?) (tag? (make-tag))
==> #t

>>> (define-record-type tag (make-tag) tag?) (make-tag)
... ;;; -------- synthesized-name hygiene --------
... ;;; The desugarings for do, let-values, let*-values, define-values, and
... ;;; define-record-type used to build synthetic identifiers ('%do-loop%',
... ;;; '%mv0', '%mv-tmp0', '%record-type:NAME').  Those would collide with
... ;;; user-chosen names.  Each is now produced by hygiene_gensym.
... ;;; let-values: a user binding named %mv0 must survive the let-values body.
==> #<tag>

