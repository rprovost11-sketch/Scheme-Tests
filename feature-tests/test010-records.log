>>> (define-record-type point (make-point x y) point? (x point-x) (y point-y)) (point-x (make-point 3 4))
==> 3

>>> (define-record-type point (make-point x y) point? (x point-x) (y point-y)) (point-y (make-point 3 4))
... ;;; Predicate distinguishes records from other values.
==> 4

>>> (define-record-type point (make-point x y) point? (x point-x) (y point-y)) (point? (make-point 0 0))
==> #t

>>> (define-record-type point (make-point x y) point? (x point-x) (y point-y)) (point? 42)
==> #f

>>> (define-record-type point (make-point x y) point? (x point-x) (y point-y)) (point? '(3 4))
==> #f

>>> (define-record-type point (make-point x y) point? (x point-x) (y point-y)) (point? "hi")
... ;;; pair? and null? reject records (disjoint type).
==> #f

>>> (define-record-type point (make-point x y) point? (x point-x) (y point-y)) (pair? (make-point 1 2))
==> #f

>>> (define-record-type point (make-point x y) point? (x point-x) (y point-y)) (null? (make-point 1 2))
... ;;; Mutator changes the field.
==> #f

>>> (define-record-type box (make-box v) box? (v box-v set-box-v!)) (define b (make-box 10)) (set-box-v! b 99) (box-v b)
... ;;; Mutator returns void.
==> 99

>>> (define-record-type box (make-box v) box? (v box-v set-box-v!)) (define b (make-box 10)) (set-box-v! b 42)
... ;;; Records print inline with their field values.
==>

>>> (define-record-type point (make-point x y) point? (x point-x) (y point-y)) (make-point 3 4)
... ;;; Field spec with no mutator: accessor works, no mutator bound.
==> #<point 3 4>

>>> (define-record-type box (make-box v) box? (v box-v)) (box-v (make-box 7))
==> 7

