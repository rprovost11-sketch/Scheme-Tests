;;; ============================================================
;;; test10-records
;;; define-record-type
;;; ============================================================

>>> (define-record-type point
...   (make-point x y)
...   point?
...   (x point-x)
...   (y point-y))
==>

>>> (define p (make-point 3 4))
==>

>>> (point? p)
==> #t

>>> (point? '(3 4))
==> #f

>>> (point? 42)
==> #f

>>> (point-x p)
==> 3

>>> (point-y p)
... ; --- record with mutable fields ---
==> 4

>>> (define-record-type counter
...   (make-counter value)
...   counter?
...   (value counter-value set-counter-value!))
==>

>>> (define c (make-counter 0))
==>

>>> (counter-value c)
==> 0

>>> (set-counter-value! c 42)
==>

>>> (counter-value c)
... ; --- record with mix of mutable and immutable fields ---
==> 42

>>> (define-record-type person
...   (make-person name age)
...   person?
...   (name person-name)
...   (age  person-age set-person-age!))
==>

>>> (define alice (make-person "Alice" 30))
==>

>>> (person-name alice)
==> "Alice"

>>> (person-age alice)
==> 30

>>> (set-person-age! alice 31)
==>

>>> (person-age alice)
... ; name is immutable — no modifier
==> 31

>>> (person? alice)
==> #t

>>> (person? "Alice")
... ; --- constructor not required to include all fields ---
... ; Fields not in constructor are initialized to #f
==> #f

>>> (define-record-type node
...   (make-node value)
...   node?
...   (value node-value)
...   (next  node-next set-node-next!))
==>

>>> (define n (make-node 10))
==>

>>> (node-value n)
==> 10

>>> (node-next n)
==>

>>> (set-node-next! n 'end)
==>

>>> (node-next n)
... ; --- multiple instances are independent ---
==> end

>>> (define p1 (make-point 1 2))
==>

>>> (define p2 (make-point 5 6))
==>

>>> (point-x p1)
==> 1

>>> (point-x p2)
... ; --- record predicate distinguishes different record types ---
==> 5

>>> (point? (make-counter 0))
==> #f

>>> (counter? (make-point 0 0))
... ; --- records are values and can be stored in lists/vectors ---
==> #f

>>> (define pts (list (make-point 1 2) (make-point 3 4)))
==>

>>> (point-x (car pts))
==> 1

>>> (point-y (cadr pts))
... ; --- zero-field record ---
==> 4

>>> (define-record-type empty-rec
...   (make-empty-rec)
...   empty-rec?)
==>

>>> (empty-rec? (make-empty-rec))
==> #t

>>> (empty-rec? 42)
... ; ============================================================
... ; 2. environment procedure (R7RS §6.12)
... ; ============================================================
... ; environment creates a restricted env from import specs
==> #f

>>> (eval '(+ 1 2) (environment '(scheme base)))
... ; restricted env does NOT have names outside the imported libraries
==> 3

>>> (guard (e (#t 'caught))
...   (eval 'sin (environment '(scheme base))))
... ; environment with (scheme inexact) has trig functions
==> caught

>>> (eval '(finite? 1.0) (environment '(scheme inexact)))
... ; combining multiple libraries
==> #t

>>> (eval '(+ (string-length "hi") 1)
...   (environment '(scheme base) '(scheme char)))
... ; empty environment (no imports) — even + is unbound
==> 3

>>> (guard (e (#t 'caught))
...   (eval '(+ 1 2) (environment)))
... ; ============================================================
... ; 3. eval with interaction-environment
... ; ============================================================
... ; --- eval (default environment) ---
==> caught

>>> (eval '(define x 42))
==>

>>> (eval 'x)
==> 42

>>> (eval '(list 1 2 3))
... ; eval with quoted expression
==> (1 2 3)

>>> (eval (list '+ 1 2 3))
... ; eval evaluates in current global env
==> 6

>>> (eval '(let ((n 5)) (* n n)))
==> 25

