>>> '(1 2 3)
... ; quasiquote (`) — basic form without computed unquoting
==> (1 2 3)

>>> `(a b c)
... ; unquote (,) — basic form
==> (a b c)

>>> (char=? #\x61 #\a)
==> #t

>>> (char=? #\x0a #\newline)
==> #t

>>> (char=? #\x20 #\space)
==> #t

>>> (char->integer #\x7f)
... ; --- String literals ---
==> 127

>>> (string-ref "\x61;" 0)
==> #\a

>>> (string-ref "\x0a;" 0)
==> #\newline

>>> (string-length "\x41;\x42;\x43;")
==> 3

>>> (string=? "\x41;" "A")
==> #t

>>> (string=? "\x61;\x62;\x63;" "abc")
==> #t

>>> (string=? "ab\
...   cd" "abcd")
... ; intraline whitespace continuation: \ + newline folds whitespace
==> #t

>>> (string-length "ab\
...   cd")
... ; \| escape in strings
==> 4

>>> (string-ref "\|" 0)
... ; --- Symbol literals ---
==> #\|

>>> (symbol? '|has (parens)|)
==> #t

>>> (symbol->string '|hello world|)
... ; empty symbol
==> "hello world"

>>> (symbol->string '||)
... ; digits that would otherwise parse as a number
==> ""

>>> (symbol? '|123|)
... ; interning of escaped symbols
==> #t

>>> (eq? '|foo| '|foo|)
... ; |foo| and foo are the same symbol
==> #t

>>> (eq? '|foo| 'foo)
... ; escaped bar inside escaped symbol
==> #t

>>> (symbol? '|has \| bar|)
... ; quotes inside escaped symbol
==> #t

>>> (symbol? '|has "quotes"|)
... ; --- Empty list ---
==> #t

