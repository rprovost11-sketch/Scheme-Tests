... ; #x hexadecimal
==> 10
>>> (+ #xFF 1)
==> 256

>>> (* #x10 #x10)
... ; #b binary
==> 256

>>> (exact? #e3.7)
==> #t

>>> (exact? #e0.0)
... ; #i inexact (convert to flonum)
==> #t

>>> (inexact? #i42)
==> #t

>>> (inexact? #i0)
... ; #i on already-inexact value
==> #t

>>> (= #b1111 #o17 #d15 #xF)
==> #t

>>> (= #b11111111 #o377 #d255 #xFF)
... ; radix literals in list context
==> #t

>>> (list #xFF #b1010 #o17)
... ; --- Quote / quasiquote reader syntax ---
... ; quote (')
==> (255 10 15)

>>> (let ((x 5)) `(a ,x c))
... ; unquote-splicing (,@) — basic form
==> (a 5 c)

>>> (let ((xs '(1 2 3))) `(a ,@xs b))
... ; --- Datum labels (#N= / #N#) ---
... ; shared atoms
==> (a 1 2 3 b)

>>> (read (open-input-string "#0=hello"))
==> hello

>>> (read (open-input-string "(#0=hello #0#)"))
... ; shared cons cells (non-cyclic)
==> (hello hello)

>>> (let* ((x (read (open-input-string "(#0=(a b) #0#)"))))
...   (eq? (car x) (cadr x)))
... ; cyclic list #0=(1 2 . #0#)
==> #t

>>> (let ((x (read (open-input-string "#0=(1 2 . #0#)"))))
...   (list (car x) (cadr x) (eq? x (cddr x))))
... ; cyclic list with single element
==> (1 2 #t)

>>> (let ((x (read (open-input-string "#0=(1 . #0#)"))))
...   (list (car x) (eq? x (cdr x))))
... ; multi-digit label
==> (1 #t)

>>> (read (open-input-string "(#10=foo #10#)"))
... ; write-shared for shared structure (non-cyclic)
==> (foo foo)

>>> (let* ((p (cons 1 2))
...        (q (list p p)))
...   (with-output-to-string (lambda () (write-shared q))))
... ; write-shared for cyclic list round-trip
%%% line 3, col 4: unbound variable: with-output-to-string
%%%   (with-output-to-string (lambda () (write-shared q))))
%%%    ^
>>> (let* ((x (list 1 2 3))
...        (_ (set-cdr! (cddr x) x))
...        (s (with-output-to-string (lambda () (write-shared x))))
...        (y (read (open-input-string s))))
...   (list (car y) (cadr y) (caddr y) (eq? y (cdddr y))))
... ; write-shared produces datum labels for shared cons
%%% line 3, col 12: unbound variable: with-output-to-string
%%%        (s (with-output-to-string (lambda () (write-shared x))))
%%%            ^
>>> (let* ((p (cons 'a 'b))
...        (q (cons p p))
...        (s (with-output-to-string (lambda () (write-shared q)))))
...   (string=? s "(#0=(a . b) . #0#)"))
... ; round-trip of shared dotted pair
%%% line 3, col 12: unbound variable: with-output-to-string
%%%        (s (with-output-to-string (lambda () (write-shared q)))))
%%%            ^
>>> (let* ((s "(#0=(a . b) . #0#)")
...        (x (read (open-input-string s))))
...   (list (caar x) (cdar x) (eq? (car x) (cdr x))))
... ; write (not write-shared) also handles cycles
==> (a b #t)

>>> (let* ((x (list 1 2))
...        (_ (set-cdr! (cdr x) x)))
...   (with-output-to-string (lambda () (write x))))
... ; --- Unbound variable error ---
%%% line 3, col 4: unbound variable: with-output-to-string
%%%   (with-output-to-string (lambda () (write x))))
%%%    ^

... ; --- Square-bracket notation (R7RS §2.1) ---
>>> '[1 2 3]
... ; [] is equivalent to () for grouping
==> (1 2 3)

>>> '[]
... ; empty bracket list
==> ()

>>> (let ([x 1]) x)
... ; bracket binding form (common Scheme style)
==> 1

>>> (let ([x 1] [y 2]) (+ x y))
... ; multiple bracket bindings
==> 3

>>> '[[1 2] [3 4]]
... ; nested brackets
==> ((1 2) (3 4))

>>> '[1 . 2]
... ; dotted pair with brackets
==> (1 . 2)

>>> '[1 2 . 3]
==> (1 2 . 3)

>>> (car '[a b])
... ; bracket list in expression context
==> a

>>> (equal? '(1 2 3) '[1 2 3])
... ; bracket and paren lists are equal
==> #t

>>> (read (open-input-string "]"))
... ; stray ] is a syntax error
%%% "<input-string>" line 1, col 1: unexpected ']'
%%% ]
%%% ^

>>> (read (open-input-string "[1 2)"))
... ; mismatched bracket: [ closed by )
%%% "<input-string>" line 1, col 5: mismatched bracket: expected ']'
%%% [1 2)
%%%     ^

>>> (read (open-input-string "(1 2]"))
... ; mismatched bracket: ( closed by ]
%%% "<input-string>" line 1, col 5: mismatched bracket: expected ')'
%%% (1 2]
%%%     ^

