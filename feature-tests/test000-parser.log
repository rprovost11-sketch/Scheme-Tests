>>> #b101/10
==> 5/2

>>> #o7/4
==> 7/4

>>> #d3/4
==> 3/4

>>> (= #b101/10 5/2)
==> #t

... ; --- #!fold-case / #!no-fold-case directives (R7RS §2.1) ---
>>> (read (open-input-string "#!fold-case ABC"))
==> abc

>>> (read (open-input-string "#!fold-case #!no-fold-case ABC"))
==> ABC

>>> (eq? (read (open-input-string "#!fold-case Foo")) 'foo)
==> #t

