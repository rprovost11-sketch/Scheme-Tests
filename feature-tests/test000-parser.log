>>> (symbol? '+.foo)
==> #t

>>> (symbol? '-.bar)
==> #t

>>> (symbol? '+..)
==> #t

... ; --- Exactness prefix on rationals (#e/#i applied to n/d) ---
>>> (exact? #e3/4)
==> #t

>>> (= #e3/4 3/4)
==> #t

>>> (inexact? #i3/4)
==> #t

>>> (= #i3/4 0.75)
==> #t

