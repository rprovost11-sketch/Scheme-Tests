>>> (assoc '(a) '(((a) . a) (-1 . b)))
==> ((a) . a)

>>> (assoc '(a) '(((b) . b) (a . c)))
==> #f

>>> (let ([alist (list (cons 2 'a) (cons 3 'b))])
...   (set-cdr! (assv 3 alist) 'c)
...   alist)
==> ((2 . a) (3 . c))

