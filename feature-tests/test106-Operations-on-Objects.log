>>> (assq 'c '((a . 1) (b . 2)))
==> #f

>>> (assv 2/3 '((1/3 . 1) (2/3 . 2)))
==> (2/3 . 2)

>>> (assv 2/3 '((1/3 . a) (3/4 . b)))
