>>> 3.2
==> 3.2

>>> #f
==> #f

>>> #\c
==> #\c

>>> "hi"
==> "hi"

>>> '#u8(3 4 5)
==> #u8(3 4 5)

>>> (+ 2 3)
==> 5

>>> '(+ 2 3)
==> (+ 2 3)

>>> (quote (+ 2 3))
==> (+ 2 3)

>>> 'a
==> a

>>> 'cons
==> cons

>>> '()
==> ()

>>> '7
==> 7

>>> `(+ 2 3)
==> (+ 2 3)

>>> `(+ 2 ,(* 3 4))
==> (+ 2 12)

>>> `(a b (,(+ 2 3) c) d)
==> (a b (5 c) d)

>>> `(a b ,(reverse '(c d e)) f g)
==> (a b (e d c) f g)

>>> (let ([a 1] [b 2]) `(,a . ,b))
==> (1 . 2)

>>> `(+ ,@(cdr '(* 2 3)))
==> (+ 2 3)

>>> `(a b ,@(reverse '(c d e)) f g)
==> (a b e d c f g)

;;; pyscheme: quote/quasiquote printed in expanded form, not abbreviated

>>> '`,(cons 'a 'b)
==> (quasiquote (unquote (cons (quote a) (quote b))))

>>> `',(cons 'a 'b)
==> (quote (a . b))

>>> `#(,@(list 1 2 3))
==> #(1 2 3)

;;; Chez-specific quasiquote extensions removed:
;;; - non-list unquote-splicing creates dotted pair
;;; - nullary unquote
;;; - multi-arg unquote
