==> ("b" "c")

>>> (let ()
...   (define member?
...     (lambda (x ls)
...       (and (member x ls) #t)))
...   (member? '(b) '((a) (b) (c))))
==> #t

>>> (define count-occurrences
...   (lambda (x ls)
...     (cond
...       [(memq x ls) =>
...        (lambda (ls)
...          (+ (count-occurrences x (cdr ls)) 1))]
...       [else 0])))
==>

>>> (count-occurrences 'a '(a b c d a))
==> 2

