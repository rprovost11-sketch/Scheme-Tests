>>> 42
==> 42

>>> -7
==> -7

>>> 3.14
==> 3.14

>>> 3/4
==> 3/4

>>> #t
==> #t

>>> #f
==> #f

>>> #\a
==> #\a

>>> #\space
==> #\space

>>> "hello"
==> "hello"

