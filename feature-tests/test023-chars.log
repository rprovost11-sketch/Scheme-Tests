;;; ============================================================
;;; test23-chars
;;; chars.py: character predicates, comparison, conversion
;;; ============================================================

>>> (char->integer (string-ref "\x3BB;" 0))
... ;;; -------- \| string pipe escape --------
==> 955

>>> (char->integer #\x41)
==> 65

>>> (char->integer #\x0)
==> 0

>>> (char->integer #\x3BB)
==> 955

>>> (char=? #\x41 #\A)
==> #t

>>> (char=? #\x0 #\null)
... ;;; -------- |...| vertical-bar symbol (read) --------
==> #t

>>> (char? #\a)
==> #t

>>> (char? #\A)
==> #t

>>> (char? #\space)
==> #t

>>> (char? 65)
==> #f

>>> (char? "a")
==> #f

>>> (char? #t)
... ; --- char=? ---
==> #f

>>> (char=? #\a #\a)
==> #t

>>> (char=? #\a #\b)
==> #f

>>> (char=? #\A #\A #\A)
==> #t

>>> (char=?)
%%% SchemeArityError: line 1, col 1: char=?: 0 arguments provided; at least 1 expected
%%% (char=?)
%%% ^
>>> (char<? #\a #\b)
==> #t

>>> (char<? #\b #\a)
==> #f

>>> (char<? #\a #\b #\c)
... ; --- char>? ---
==> #t

>>> (char>? #\b #\a)
==> #t

>>> (char>? #\a #\b)
... ; --- char<=? ---
==> #f

>>> (char<=? #\a #\a)
==> #t

>>> (char<=? #\a #\b)
==> #t

>>> (char<=? #\b #\a)
... ; --- char>=? ---
==> #f

>>> (char>=? #\a #\a)
==> #t

>>> (char>=? #\b #\a)
==> #t

>>> (char>=? #\a #\b)
... ; --- eq? on chars ---
==> #f

>>> (char-ci=? #\a #\A)
==> #t

>>> (char-ci=? #\a #\b)
==> #f

>>> (char-ci=? #\A #\A #\a)
==> #t

>>> (char-ci=?)
%%% SchemeArityError: line 1, col 1: char-ci=?: 0 arguments provided; at least 1 expected
%%% (char-ci=?)
%%% ^
>>> (char-ci<? #\a #\B)
==> #t

>>> (char-ci<? #\B #\a)
==> #f

>>> (char-ci<? #\a #\A)
... ; --- char-ci>? ---
==> #f

>>> (char-ci>? #\a #\B)
... ; --- char-ci<=? ---
==> #f

>>> (char-ci<=? #\a #\A)
==> #t

>>> (char-ci<=? #\a #\B)
==> #t

>>> (char-ci<=? #\B #\a)
... ; --- char-ci>=? ---
==> #f

>>> (char-ci>=? #\A #\a)
==> #t

>>> (char-ci>=? #\B #\a)
==> #t

>>> (char-ci>=? #\a #\B)
... ; ============================================================
... ; 3. Character classification
... ; ============================================================
... ; --- char-alphabetic? ---
... ; uppercase letter
==> #f

>>> (char-alphabetic? #\A)
... ; lowercase letter
==> #t

>>> (char-alphabetic? #\a)
... ; digit is not alphabetic
==> #t

>>> (char-alphabetic? #\1)
... ; space is not alphabetic
==> #f

>>> (char-alphabetic? #\space)
==> #f

>>> (char-alphabetic?)
%%% SchemeArityError: line 1, col 1: char-alphabetic?: 0 arguments provided; 1 expected
%%% (char-alphabetic?)
%%% ^
>>> (char-numeric? #\0)
==> #t

>>> (char-numeric? #\9)
==> #t

>>> (char-numeric? #\A)
==> #f

>>> (char-numeric?)
%%% SchemeArityError: line 1, col 1: char-numeric?: 0 arguments provided; 1 expected
%%% (char-numeric?)
%%% ^
>>> (char-whitespace? #\space)
... ; tab
==> #t

>>> (char-whitespace? #\tab)
... ; newline
==> #t

>>> (char-whitespace? #\newline)
... ; letter A is not whitespace
==> #t

>>> (char-whitespace? #\A)
==> #f

>>> (char-whitespace?)
%%% SchemeArityError: line 1, col 1: char-whitespace?: 0 arguments provided; 1 expected
%%% (char-whitespace?)
%%% ^
