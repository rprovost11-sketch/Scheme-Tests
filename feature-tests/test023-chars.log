%%% ^
>>> (integer->char 65)
==> #\A

>>> (integer->char 97)
==> #\a

>>> (integer->char 32)
==> #\space

>>> (integer->char 48)
==> #\0

>>> (integer->char 10)
==> #\newline

>>> (integer->char)
%%% SchemeArityError: line 1, col 1: integer->char: 0 arguments provided; 1 expected
%%% (integer->char)
%%% ^
>>> (integer->char (char->integer #\z))
==> #\z

>>> (char->integer (integer->char 90))
... ; --- char-upcase ---
... ; a -> A
==> 90

>>> (char-upcase #\a)
... ; A stays A
==> #\A

>>> (char-upcase #\A)
... ; digit unchanged
==> #\A

>>> (char-upcase #\0)
==> #\0

>>> (char-upcase)
%%% SchemeArityError: line 1, col 1: char-upcase: 0 arguments provided; 1 expected
%%% (char-upcase)
%%% ^
>>> (char-downcase #\A)
... ; a stays a
==> #\a

>>> (char-downcase #\a)
... ; digit unchanged
==> #\a

>>> (char-downcase #\0)
==> #\0

>>> (char-downcase)
%%% SchemeArityError: line 1, col 1: char-downcase: 0 arguments provided; 1 expected
%%% (char-downcase)
%%% ^
>>> (char-foldcase #\a)
==> #\a

>>> (char-foldcase #\0)
==> #\0

>>> (char-foldcase)
%%% SchemeArityError: line 1, col 1: char-foldcase: 0 arguments provided; 1 expected
