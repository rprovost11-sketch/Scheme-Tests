>>> (force (delay 42))
==> 42

>>> (force (delay (+ 1 2 3)))
... ;;; delay produces a promise; force unwraps it.
==> 6

>>> (promise? (delay 1))
==> #t

>>> (promise? 1)
==> #f

>>> (promise? "hi")
==> #f

>>> (promise? (lambda () 1))
... ;;; A forced promise stays a promise (still answers #t to promise?).
==> #f

>>> (define p (delay 7)) (force p) (promise? p)
... ;;; Memoization: the thunk runs at most once.  We count effects by set!-ing
... ;;; a counter in the delayed body.
==> #t

>>> (define c 0) (define p (delay (begin (set! c (+ c 1)) 42))) (force p) (force p) (force p) c
... ;;; The value is cached across forces.
==> 1

>>> (define c 0) (define p (delay (begin (set! c (+ c 1)) 99))) (force p) (force p)
... ;;; make-promise: already-forced, no thunk ever runs.
==> 99

>>> (force (make-promise 100))
==> 100

>>> (promise? (make-promise 5))
... ;;; make-promise + force is idempotent.
==> #t

>>> (define q (make-promise 'hello)) (force q) (force q)
... ;;; Closure captures the env at delay time.
==> hello

>>> (define x 10) (define p (delay (* x x))) (set! x 99) (force p)
... ;;; A promise whose body yields another promise unwraps transparently.
==> 9801

>>> (force (delay (delay 42)))
==> 42

>>> (force (delay (make-promise 'inner)))
... ;;; delay-force - same observable semantics as delay in our implementation.
==> inner

>>> (force (delay-force 42))
==> 42

>>> (force (delay-force (delay 17)))
... ;;; Stack-safe iterative forcing: a long chain of delay-force collapses
... ;;; without building native stack.  100k is well past the recursion limit.
==> 17

>>> (define (loop n) (if (zero? n) (delay 'done) (delay-force (loop (- n 1))))) (force (loop 100000))
... ;;; force on a non-promise returns the value unchanged (R7RS leaves this
... ;;; implementation-defined; pyscheme follows SRFI 155 and most R6RS impls,
... ;;; treating non-promises as if already forced).
==> done

