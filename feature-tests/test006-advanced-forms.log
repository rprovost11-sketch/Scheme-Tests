>>> (call-with-values (lambda () (dynamic-wind (lambda () #f) (lambda () (values 1 2)) (lambda () #f))) +)
... ;;; with-exception-handler that doesn't fire is also transparent.
==> 3

>>> (call-with-values (lambda () (with-exception-handler (lambda (v) 'unused) (lambda () (values 5 7)))) +)
... ;;; Deep tail recursion through call-with-values: each iteration tail-calls
... ;;; loop via call-with-values.  Without CEK-level dispatch this would blow
... ;;; Python stack.
==> 12

