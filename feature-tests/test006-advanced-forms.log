>>> (make-parameter 10)
==> #<parameter>

>>> (parameter? (make-parameter 10))
==> #t

>>> (parameter? 42)
... ;;; parameter? sits with the type predicates; procedure? also says yes.
==> #f

>>> (procedure? (make-parameter 10))
... ;;; Reading a parameter: 0-arg call returns the current dynamic value.
==> #t

>>> (define p (make-parameter 10)) (p)
... ;;; parameterize binds dynamically for the body's extent.
==> 10

>>> (define p (make-parameter 10)) (parameterize ((p 99)) (p))
... ;;; After parameterize returns, the old value is restored.
==> 99

>>> (define p (make-parameter 10)) (parameterize ((p 99)) (p)) (p)
... ;;; Nested parameterize: the inner binding wins, then is restored.
==> 10

>>> (define p (make-parameter 1)) (parameterize ((p 2)) (parameterize ((p 3)) (p)))
==> 3

>>> (define p (make-parameter 1)) (parameterize ((p 2)) (parameterize ((p 3)) (p)) (p))
... ;;; Multiple parameters in one parameterize.
==> 2

>>> (define p (make-parameter 1)) (define q (make-parameter 2)) (parameterize ((p 10) (q 20)) (+ (p) (q)))
... ;;; Converter applied at make-parameter time and at each parameterize binding.
==> 30

>>> (define c (make-parameter 3 (lambda (x) (* x x)))) (c)
==> 9

>>> (define c (make-parameter 3 (lambda (x) (* x x)))) (parameterize ((c 5)) (c))
... ;;; Converter applies to each parameterize value, not just once.
==> 25

>>> (define c (make-parameter 1 (lambda (x) (+ x 100)))) (list (c) (parameterize ((c 2)) (c)) (parameterize ((c 3)) (c)) (c))
... ;;; Deep tail recursion through parameterize: each iteration tail-calls
... ;;; loop inside a parameterize body.  Without CEK-level integration this
... ;;; would blow Python stack.  K grows O(n) here but Python stack does not.
==> (101 102 103 101)

>>> (define p (make-parameter 0)) (define (loop n) (if (zero? n) (p) (parameterize ((p (+ (p) 1))) (loop (- n 1))))) (loop 100000)
... ;;; Exception safety: parameterize restores even when body raises.
==> 100000

