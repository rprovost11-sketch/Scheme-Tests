>>> (help 'delay)
Special Form  |  args: unevaluated

   Usage: (delay <expr>)

   Return a promise whose forced value is the value of <expr>.
   <expr> is not evaluated until the promise is forced; its value is
   then cached so subsequent forces are O(1).  R7RS 4.2.5.  Use force
   to retrieve the value.
==>

>>> (help force)
... ;;; -------- values / call-with-values / let-values / let*-values / define-values (R7RS 4.2.2, 5.3.3, 6.10) --------
... ;;; (values) returns an empty multi-values.
Primitive  |  args: pre-evaluated

   Usage: (force a)

   Force a promise, returning its value.  The promise's thunk runs
   at most once; subsequent forces return the cached value.  If the
   thunk yields another promise, force follows the chain iteratively,
   so (delay-force ...) promise chains run in constant stack.  A
   non-promise argument is returned unchanged (R7RS-small 6.10 leaves
   this implementation-defined; we follow SRFI 155).
==>

>>> (values)
... ;;; Zero-argument (values) returns no values; REPL prints nothing.
==>


>>> (values 42)
==> 42

>>> (values "hi")
... ;;; (values x) is one value, so it works in single-value contexts: this
... ;;; is a correctness requirement, not a convention.  R7RS 6.10.
==> "hi"

>>> (+ 1 (values 2))
==> 3

>>> (define values-single (values 42)) values-single
==> 42

>>> (if (values #t) (quote yes) (quote no))
... ;;; Two+ values wrap into a multi-values container.
==> yes

>>> (values 1 2 3)
... ;;; call-with-values unpacks multi-values into the consumer's args.
==> #<values 1 2 3>

>>> (call-with-values (lambda () (values 10 20 30)) +)
==> 60

>>> (call-with-values (lambda () (values 1 2)) list)
... ;;; Single-value producer: consumer gets one argument.
==> (1 2)

>>> (call-with-values (lambda () 42) (lambda (x) (* x 2)))
... ;;; Zero-value producer: consumer must take zero args.
==> 84

>>> (call-with-values (lambda () (values)) (lambda () 'ok))
... ;;; Primitive producer and consumer work too.
==> ok

>>> (call-with-values (lambda () (values 3 4)) (lambda (a b) (* a b)))
... ;;; Consumer can be variadic.
==> 12

>>> (call-with-values (lambda () (values 1 2 3 4)) (lambda args args))
... ;;; -------- let-values: parallel semantics --------
==> (1 2 3 4)

>>> (let-values (((a b) (values 1 2))) (+ a b))
==> 3

>>> (let-values (((a b) (values 10 20)) ((c) (values 30))) (list a b c))
... ;;; Parallel: init2 does NOT see clause-1 bindings.  Define x in the
... ;;; outer env; let-values shadows with its own x only when the body runs.
==> (10 20 30)

>>> (define x 100) (let-values (((x) (values 1)) ((y) (values x))) (list x y))
... ;;; Variadic rest in formals: rest gets the tail of the value list.
==> (1 100)

>>> (let-values (((head . rest) (values 1 2 3 4))) (list head rest))
... ;;; Pure-variadic formals: the single identifier gets the whole value list.
==> (1 (2 3 4))

>>> (let-values ((all (values 'a 'b 'c))) all)
... ;;; Empty bindings degenerates to begin.
==> (a b c)

>>> (let-values () 1 2 3)
... ;;; Zero-value init is legal when formals is ().
==> 3

>>> (let-values ((() (values))) 'body-ran)
... ;;; -------- let*-values: sequential semantics --------
==> body-ran

>>> (let*-values (((a b) (values 1 2)) ((c) (values (+ a b)))) c)
==> 3

>>> (let*-values (((x) (values 10)) ((x) (values (* x x)))) x)
... ;;; -------- define-values --------
==> 100

