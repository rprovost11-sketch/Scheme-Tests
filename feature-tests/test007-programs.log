;;; ============================================================
;;; test07-programs
;;; TCO, named let, practical recursive programs
;;; ============================================================

>>> (define (fact n) (if (zero? n) 1 (* n (fact (- n 1)))))
==>

>>> (fact 0)
==> 1

>>> (fact 5)
==> 120

>>> (fact 10)
==> 3628800

>>> (define (fib n) (if (< n 2) n (+ (fib (- n 1)) (fib (- n 2)))))
==>

>>> (fib 10)
==> 55

>>> (define (length lst) (if (null? lst) 0 (+ 1 (length (cdr lst)))))
==>

>>> (length (list 10 20 30 40 50))
==> 5

>>> (define (reverse lst) (let loop ((xs lst) (acc '())) (if (null? xs) acc (loop (cdr xs) (cons (car xs) acc)))))
==>

>>> (reverse (list 1 2 3 4 5))
==> (5 4 3 2 1)

>>> (define (map1 f lst) (if (null? lst) '() (cons (f (car lst)) (map1 f (cdr lst)))))
==>

>>> (map1 (lambda (x) (* x x)) (list 1 2 3 4))
==> (1 4 9 16)

>>> (define (sum-list lst) (if (null? lst) 0 (+ (car lst) (sum-list (cdr lst)))))
==>

>>> (sum-list (list 1 2 3 4 5))
==> 15

>>> (define (gcd a b) (if (zero? b) a (gcd b (modulo a b))))
==>

>>> (gcd 48 18)
==> 6

>>> (gcd 17 5)
... ;;; Iterative accumulators via named let
==> 1

>>> (let loop ((i 1) (acc 1)) (if (> i 10) acc (loop (+ i 1) (* acc i))))
==> 3628800

>>> (let loop ((lst (list 5 4 3 2 1)) (acc 0)) (if (null? lst) acc (loop (cdr lst) (+ acc (car lst)))))
==> 15

>>> (let loop ((lst (list 1 2 3))) (if (null? lst) 'done (loop (cdr lst))))
==> done

>>> (let loop ((lst (list 1 2 3)) (acc (list))) (if (null? lst) acc (loop (cdr lst) (cons (car lst) acc))))
... ;;; -------- do (R7RS 4.2.4) - iteration --------
==> (3 2 1)

