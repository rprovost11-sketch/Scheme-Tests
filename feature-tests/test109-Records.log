;;; print-fields: define succeeds; call fails on make-cpoint (record types not defined)

>>> (define print-fields
...   (lambda (r)
...     (unless (record? r)
...       (assertion-violation 'print-fields "not a record" r))
...     (let loop ([rtd (record-rtd r)])
...       (let ([prtd (record-type-parent rtd)])
...         (when prtd (loop prtd)))
...       (let* ([v (record-type-field-names rtd)]
...              [n (vector-length v)])
...         (do ([i 0 (+ i 1)])
...             ((= i n))
...           (write (vector-ref v i))
...           (display "=")
...           (write ((record-accessor rtd i) r))
...           (newline))))))
==>

>>> (define-record-type point (fields x y))
%%% SchemeArityError: line 1, col 1: define-record-type: 2 arguments provided; at least 4 expected
%%% (define-record-type point (fields x y))
%%% ^

>>> (define-record-type cpoint (parent point) (fields color))
%%% SchemeArityError: line 1, col 1: define-record-type: 3 arguments provided; at least 4 expected
%%% (define-record-type cpoint (parent point) (fields color))
%%% ^

>>> (print-fields (make-cpoint -3 7 'blue))
%%% line 1, col 16: unbound variable: make-cpoint
%%% (print-fields (make-cpoint -3 7 'blue))
%%%                ^
