;;; ============================================================
;;; test109-Records
;;; The Scheme Programming Language, 4th ed. - Chapter 9
;;; R. Kent Dybvig  (examples used for educational testing)
;;; ============================================================
;;; pyscheme supports R7RS define-record-type only:
;;;   (define-record-type <name> (<ctor> <field>...) <pred> (<field> <acc> [<mut>])...)
;;; R6RS clause-based define-record-type (fields/parent/protocol/nongenerative/etc.),
;;; the procedural interface, and the inspection API are all unsupported.
;;; ============================================================

;;; ============================================================
;;; 9.1  Defining Records
;;; ============================================================

;;; R6RS form with (fields ...) clause: 2 args provided -- at least 4 expected

>>> (define-record-type point (fields x y))
%%% SchemeArityError: line 1, col 1: define-record-type: 2 arguments provided; at least 4 expected
%%% (define-record-type point (fields x y))
%%% ^

;;; make-point, point?, point-x, point-y all unbound after failed define-record-type

>>> (define p (make-point 36 -17))
%%% line 1, col 12: unbound variable: make-point
%%% (define p (make-point 36 -17))
%%%            ^

>>> (point? p)
%%% line 1, col 2: unbound variable: point?
%%% (point? p)
%%%  ^

>>> (point? '(cons 36 -17))
%%% line 1, col 2: unbound variable: point?
%%% (point? '(cons 36 -17))
%%%  ^

>>> (point-x p)
%%% line 1, col 2: unbound variable: point-x
%%% (point-x p)
%%%  ^

>>> (point-y p)
%%% line 1, col 2: unbound variable: point-y
%%% (point-y p)
%%%  ^

;;; mutable field: (fields (mutable x) y) -- still 2 args, same error

>>> (define-record-type point (fields (mutable x) y))
%%% SchemeArityError: line 1, col 1: define-record-type: 2 arguments provided; at least 4 expected
%%% (define-record-type point (fields (mutable x) y))
%%% ^

>>> (point-x-set! p (- (point-x p) 12))
%%% line 1, col 2: unbound variable: point-x-set!
%%% (point-x-set! p (- (point-x p) 12))
%%%  ^

;;; explicit immutable: same arity error

>>> (define-record-type point (fields (mutable x) (immutable y)))
%%% SchemeArityError: line 1, col 1: define-record-type: 2 arguments provided; at least 4 expected
%%% (define-record-type point (fields (mutable x) (immutable y)))
%%% ^

;;; custom constructor/predicate/accessor names: still 2 args

>>> (define-record-type (point mkpoint ispoint?)
...   (fields (mutable x x-val set-x-val!)
...           (immutable y y-val)))
%%% SchemeArityError: line 1, col 1: define-record-type: 2 arguments provided; at least 4 expected
%%% (define-record-type (point mkpoint ispoint?)
%%% ^

;;; generative records (default): define-record-type inside body at line 2, col 3

>>> (define (f p)
...   (define-record-type point (fields x y))
...   (if (eq? p 'make) (make-point 3 4) (point? p)))
%%% SchemeArityError: line 2, col 3: define-record-type: 2 arguments provided; at least 4 expected
%%%   (define-record-type point (fields x y))
%%%   ^

>>> (f (f 'make))
%%% line 1, col 2: unbound variable: f
%%% (f (f 'make))
%%%  ^

;;; nongenerative: (fields x y) (nongenerative) -- 3 args, "3 arguments provided"

>>> (define (f p)
...   (define-record-type point (fields x y) (nongenerative))
...   (if (eq? p 'make) (make-point 3 4) (point? p)))
%%% SchemeArityError: line 2, col 3: define-record-type: 3 arguments provided; at least 4 expected
%%%   (define-record-type point (fields x y) (nongenerative))
%%%   ^

>>> (define (g p)
...   (define-record-type point (fields x y) (nongenerative))
...   (point? p))
%%% SchemeArityError: line 2, col 3: define-record-type: 3 arguments provided; at least 4 expected
%%%   (define-record-type point (fields x y) (nongenerative))
%%%   ^

>>> (g (f))
%%% line 1, col 2: unbound variable: g
%%% (g (f))
%%%  ^

;;; nongenerative with uid: same error pattern

>>> (define (f)
...   (define-record-type point (fields x y)
...     (nongenerative really-the-same-point))
...   (make-point 3 4))
%%% SchemeArityError: line 2, col 3: define-record-type: 3 arguments provided; at least 4 expected
%%%   (define-record-type point (fields x y)
%%%   ^

>>> (define (g p)
...   (define-record-type point (fields x y)
...     (nongenerative really-the-same-point))
...   (point? p))
%%% SchemeArityError: line 2, col 3: define-record-type: 3 arguments provided; at least 4 expected
%%%   (define-record-type point (fields x y)
%%%   ^

>>> (g (f))
%%% line 1, col 2: unbound variable: g
%%% (g (f))
%%%  ^

;;; parent clause: (parent point) (fields color) -- 3 args

>>> (define-record-type point (fields x y))
%%% SchemeArityError: line 1, col 1: define-record-type: 2 arguments provided; at least 4 expected
%%% (define-record-type point (fields x y))
%%% ^

>>> (define-record-type cpoint (parent point) (fields color))
%%% SchemeArityError: line 1, col 1: define-record-type: 3 arguments provided; at least 4 expected
%%% (define-record-type cpoint (parent point) (fields color))
%%% ^

>>> (define cp (make-cpoint 3 4 'red))
%%% line 1, col 13: unbound variable: make-cpoint
%%% (define cp (make-cpoint 3 4 'red))
%%%             ^

>>> (point? (make-cpoint 3 4 'red))
%%% line 1, col 2: unbound variable: point?
%%% (point? (make-cpoint 3 4 'red))
%%%  ^

>>> (cpoint? (make-point 3 4))
%%% line 1, col 2: unbound variable: cpoint?
%%% (cpoint? (make-point 3 4))
%%%  ^

>>> (cpoint-color cp)
%%% line 1, col 2: unbound variable: cpoint-color
%%% (cpoint-color cp)
%%%  ^

;;; protocol clause: (fields ...) (protocol ...) -- 3 args, same arity error

>>> (define-record-type point
...   (fields x y d)
...   (protocol
...     (lambda (new)
...       (lambda (x y)
...         (new x y (sqrt (+ (* x x) (* y y))))))))
%%% SchemeArityError: line 1, col 1: define-record-type: 3 arguments provided; at least 4 expected
%%% (define-record-type point
%%% ^

;;; protocol with parent: 4 clauses -- pred_sexpr is (fields ...) not a symbol,
;;; expander falls through: cpoint treated as unbound variable

>>> (define-record-type cpoint
...   (parent point)
...   (fields color)
...   (protocol
...     (lambda (pargs->new)
...       (lambda (c x y)
...         ((pargs->new x y) c)))))
%%% %any-error% non-standard (parent ...) clause or malformed record type

;;; ============================================================
;;; 9.2  Procedural Interface
;;; ============================================================

;;; make-record-type-descriptor: R6RS/Chez -- unbound in pyscheme

>>> (define point-rtd (make-record-type-descriptor 'point #f #f #f #f
...                     '#((mutable x) (immutable y))))
%%% line 1, col 20: unbound variable: make-record-type-descriptor
%%% (define point-rtd (make-record-type-descriptor 'point #f #f #f #f
%%%                    ^

>>> (define point-rcd (make-record-constructor-descriptor point-rtd #f #f))
%%% line 1, col 20: unbound variable: make-record-constructor-descriptor
%%% (define point-rcd (make-record-constructor-descriptor point-rtd #f #f))
%%%                    ^

>>> (define make-point (record-constructor point-rcd))
%%% line 1, col 21: unbound variable: record-constructor
%%% (define make-point (record-constructor point-rcd))
%%%                     ^

>>> (define point? (record-predicate point-rtd))
%%% line 1, col 17: unbound variable: record-predicate
%%% (define point? (record-predicate point-rtd))
%%%                 ^

>>> (define point-x (record-accessor point-rtd 0))
%%% line 1, col 18: unbound variable: record-accessor
%%% (define point-x (record-accessor point-rtd 0))
%%%                  ^

>>> (define point-y (record-accessor point-rtd 1))
%%% line 1, col 18: unbound variable: record-accessor
%%% (define point-y (record-accessor point-rtd 1))
%%%                  ^

>>> (define point-x-set! (record-mutator point-rtd 0))
%%% line 1, col 23: unbound variable: record-mutator
%%% (define point-x-set! (record-mutator point-rtd 0))
%%%                       ^

;;; record-type-descriptor?: R6RS -- unbound in pyscheme

>>> (define rtd/parent
...   (make-record-type-descriptor 'parent #f #f #f #f
...     '#((mutable x))))
%%% line 2, col 4: unbound variable: make-record-type-descriptor
%%%   (make-record-type-descriptor 'parent #f #f #f #f
%%%    ^

>>> (record-type-descriptor? rtd/parent)
%%% line 1, col 2: unbound variable: record-type-descriptor?
%%% (record-type-descriptor? rtd/parent)
%%%  ^

>>> (record-type-descriptor? rcd/parent)
%%% line 1, col 2: unbound variable: record-type-descriptor?
%%% (record-type-descriptor? rcd/parent)
%%%  ^

;;; record-mutator on immutable field raises an exception -- but record-mutator is unbound

>>> (record-mutator rtd/child 1)
%%% line 1, col 2: unbound variable: record-mutator
%%% (record-mutator rtd/child 1)
%%%  ^

;;; ============================================================
;;; 9.3  Inspection
;;; ============================================================

;;; record->name: define succeeds (lambda body not evaluated); call fails on make-dim

>>> (define record->name
...   (lambda (x)
...     (and (record? x) (record-type-name (record-rtd x)))))
==>

>>> (define-record-type dim (fields w l h))
%%% SchemeArityError: line 1, col 1: define-record-type: 2 arguments provided; at least 4 expected
%%% (define-record-type dim (fields w l h))
%%% ^

>>> (record->name (make-dim 10 15 6))
%%% line 1, col 16: unbound variable: make-dim
%%% (record->name (make-dim 10 15 6))
%%%                ^

;;; opaque record: same error

>>> (define-record-type dim (fields w l h) (opaque #t))
%%% SchemeArityError: line 1, col 1: define-record-type: 3 arguments provided; at least 4 expected
%%% (define-record-type dim (fields w l h) (opaque #t))
%%% ^

>>> (record->name (make-dim 10 15 6))
%%% line 1, col 16: unbound variable: make-dim
%%% (record->name (make-dim 10 15 6))
%%%                ^

