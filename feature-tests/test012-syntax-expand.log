;;; ============================================================
;;; test012-syntax-expand
;;; Two-part file:
;;;   Part A - syntax-expand primitive: verifies that the expander
;;;     produces the correct output for built-in sugar and user macros.
;;;     These tests pin the structural shape of expansions so that the
;;;     Option B (alpha-rename) refactor cannot silently change the
;;;     surface form that programs see.
;;;   Part B - hygiene regression tests: the seven scenarios most
;;;     likely to break under the Option B refactor.  Each test is
;;;     purely behavioral; it does not depend on internal scope-set
;;;     representation.
;;; ============================================================

;;; ============================================================
;;; Part A: syntax-expand
;;; ============================================================

;;; ------------------------------------------------------------
;;; A1. Built-in sugar: (define (f x) body) shorthand
;;; ------------------------------------------------------------

>>> (syntax-expand '(define (f x) x))
==> (define f (lambda (x) x))

>>> (syntax-expand '(define (g a b) a))
==> (define g (lambda (a b) a))

;;; ------------------------------------------------------------
;;; A2. Built-in sugar: two-arm (if t e) gets void branch
;;; ------------------------------------------------------------

>>> (syntax-expand '(if #t 1))
==> (if #t 1 #<void>)

;;; Three-arm if passes through unchanged.
>>> (syntax-expand '(if #t 1 2))
==> (if #t 1 2)

;;; ------------------------------------------------------------
;;; A3. Built-in sugar: let passes through with same names
;;; (scope annotations are internal and do not appear in output)
;;; ------------------------------------------------------------

>>> (syntax-expand '(let ((x 1)) x))
==> (let ((x 1)) x)

>>> (syntax-expand '(let ((a 1) (b 2)) (+ a b)))
==> (let ((a 1) (b 2)) (+ a b))

;;; ------------------------------------------------------------
;;; A4. User macro expansion: introduced variable visible by name
;;; Define h12-or with an internal `t' binding; syntax-expand shows
;;; the let that the template produces.
;;; ------------------------------------------------------------

>>> (define-syntax h12-or
...   (syntax-rules ()
...     ((_ e1 e2)
...      (let ((t e1)) (if t t e2)))))
==>

>>> (syntax-expand '(h12-or a b))
==> (let ((t a)) (if t t b))

;;; ------------------------------------------------------------
;;; A5. User macro expansion: swap! shows the introduced tmp
;;; ------------------------------------------------------------

>>> (define-syntax h12-swap!
...   (syntax-rules ()
...     ((_ a b)
...      (let ((tmp a)) (set! a b) (set! b tmp)))))
==>

>>> (syntax-expand '(h12-swap! p q))
==> (let ((tmp p)) (set! p q) (set! q tmp))

;;; ------------------------------------------------------------
;;; A6. Literal keyword: syntax-expand shows the matched pattern
;;; ------------------------------------------------------------

>>> (define-syntax h12-my-cond
...   (syntax-rules (else)
...     ((_ (else e)) e)
...     ((_ (test e) clause ...)
...      (if test e (h12-my-cond clause ...)))))
==>

>>> (syntax-expand '(h12-my-cond (#f 1) (else 2)))
==> (if #f 1 2)

;;; ============================================================
;;; Part B: hygiene regression tests
;;; ============================================================

;;; ------------------------------------------------------------
;;; B1. Introduced binding hygiene
;;; The `t' introduced by h12-or's let must NOT capture the user's
;;; `t' at the call site.  Expected: #t (not the user's #f).
;;; ------------------------------------------------------------

>>> (let ((t #f)) (h12-or t #t))
==> #t

;;; Multiple levels of nesting: both introduced t's are distinct
;;; from each other and from the user's t.
>>> (let ((t #f)) (h12-or #f (h12-or t #t)))
==> #t

;;; ------------------------------------------------------------
;;; B2. Literal matching: declared literal matches at definition site
;;; ------------------------------------------------------------

>>> (define-syntax h12-lit
...   (syntax-rules (foo)
...     ((_ foo) 'matched)
...     ((_ x)   'not-matched)))
==>

>>> (h12-lit foo)
==> matched

;;; ------------------------------------------------------------
;;; B3. Literal matching: shadowing the literal at the call site
;;; prevents it from matching as the keyword.
;;; A `let'-bound `foo' is a different binding than the literal `foo'
;;; from the macro's definition environment; the second pattern fires.
;;; ------------------------------------------------------------

>>> (let ((foo 99)) (h12-lit foo))
==> not-matched

;;; ------------------------------------------------------------
;;; B4. Definition-site scoping: free reference in template resolves
;;; to the definition environment, not the use-site environment.
;;; ------------------------------------------------------------

>>> (define h12-x 'outer)
==>

>>> (define-syntax h12-get-x (syntax-rules () ((_ ) h12-x)))
==>

>>> (let ((h12-x 'inner)) (h12-get-x))
==> outer

;;; ------------------------------------------------------------
;;; B5. Pattern variable hygiene: swap! introduces `tmp'; the user's
;;; `tmp' must not be clobbered and must not shadow the macro's tmp.
;;; ------------------------------------------------------------

>>> (let ((tmp 1) (other 2))
...   (h12-swap! tmp other)
...   tmp)
==> 2

;;; ------------------------------------------------------------
;;; B6. Nested macro hygiene: h12-and uses an internal `t' in each
;;; recursive expansion; none of them should capture the user's `t'.
;;; ------------------------------------------------------------

>>> (define-syntax h12-and
...   (syntax-rules ()
...     ((_) #t)
...     ((_ e) e)
...     ((_ e1 e2 ...)
...      (let ((t e1)) (if t (h12-and e2 ...) #f)))))
==>

;;; The critical hygiene test: the user's `t = #f' must NOT leak into
;;; the macro's internal `t' binding when `t' is not passed as an argument.
;;; If hygiene is broken, `(if t ...)' inside the template resolves to
;;; the user's `t = #f' and returns #f instead of #t.
>>> (let ((t #f)) (h12-and #t #t #t))
==> #t

;;; Passing `t' explicitly as an argument is correct short-circuit behavior:
;;; h12-and returns #f when any argument is #f.
>>> (let ((t #f)) (h12-and t #t #t))
==> #f

>>> (let ((t #f)) (h12-and #t t #t))
==> #f

>>> (let ((t #f)) (h12-and #t #t t))
==> #f

;;; ------------------------------------------------------------
;;; B7. let-syntax scoping: the transformer sees the environment at
;;; its definition point, not the inner let's environment.
;;; get-x sees `x = outer-x'; the inner `x = inner-x' is invisible.
;;; ------------------------------------------------------------

>>> (let ((x 'outer-x))
...   (let-syntax ((get-x (syntax-rules () ((_ ) x))))
...     (let ((x 'inner-x)) (get-x))))
==> outer-x

;;; letrec-syntax: sibling transformers see each other at expand time.
;;; `a' expands to `(b x)'; under letrec-syntax `b' is visible so this
;;; expands to `x'.  Under let-syntax, `b' would be invisible and `(b x)'
;;; would remain, causing a runtime unbound error.
>>> (letrec-syntax
...     ((a (syntax-rules () ((_ x) (b x))))
...      (b (syntax-rules () ((_ x) x))))
...   (a 42))
==> 42
